@{
    var code = ViewBag.StatusCode as int? ?? 404;
    var title = code == 404 ? "Không tìm thấy nội dung" : $"Lỗi {code}";
}

<div class="card p-5 text-center" style="max-width:760px;margin:48px auto;">
    <div class="mx-auto mb-3 d-grid place-items-center" style="width:68px;height:68px;border-radius:24px;background:rgba(139,92,246,.16);color:#a78bfa;font-weight:950;display:grid;place-items:center;">
        @code
    </div>
    <h2 class="fw-bold mb-2">@title</h2>
    <p class="text-muted mb-4">Đường dẫn này không thuộc không gian Editor hoặc bạn không có quyền truy cập.</p>
    <div class="d-flex gap-2 justify-content-center flex-wrap">
        <a class="btn btn-secondary" href="javascript:history.back()"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
        <a class="btn btn-primary" href="/Editor"><i class="fa-solid fa-pen-ruler"></i> Về Editor</a>
    </div>
</div>
