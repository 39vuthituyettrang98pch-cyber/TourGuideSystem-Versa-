@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var pageTitle = ViewData["Title"]?.ToString() ?? currentController;
    var isPoiSection = currentController is "Poi" or "PoiTranslation";
    var isTourSection = currentController is "Tour" or "TourTranslation";
    var isCategorySection = currentController is "Category" or "CategoryTranslation";
    var isWorkspaceBoard = currentController == "Workspace" && currentAction == "Board";
    var isWorkspaceQuality = currentController == "Workspace" && currentAction == "Quality";
    var isMyContent = currentController == "MyContent";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - VERSA Editor</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />
    <!-- V17: render page-specific CSS sections -->
    @RenderSection("Styles", required: false)
</head>
<body class="editor-shell">
    <div class="app-layout">
        <div class="sidebar-overlay" data-sidebar-close></div>
        <aside class="sidebar" id="editorSidebar">
            <a class="sidebar-logo" asp-area="Editor" asp-controller="Dashboard" asp-action="Index">
                <span class="logo-icon"><i class="fa-solid fa-pen-ruler"></i></span>
                <span class="logo-text">VERSA <strong>EDITOR</strong></span>
            </a>

            <nav class="sidebar-nav">
                <div class="sidebar-section">
                    <div class="sidebar-section-label">Không gian làm việc</div>
                    <a class="nav-item @(currentController == "Dashboard" ? "active" : "")" asp-area="Editor" asp-controller="Dashboard" asp-action="Index">
                        <i class="fa-solid fa-house"></i><span>Tổng quan biên tập</span>
                    </a>
                    <a class="nav-item @(isWorkspaceBoard ? "active" : "")" asp-area="Editor" asp-controller="Workspace" asp-action="Board">
                        <i class="fa-solid fa-table-list"></i><span>Bảng làm việc</span>
                    </a>
                    <a class="nav-item @(isWorkspaceQuality ? "active" : "")" asp-area="Editor" asp-controller="Workspace" asp-action="Quality">
                        <i class="fa-solid fa-shield-heart"></i><span>Kiểm tra chất lượng</span>
                    </a>
                    <a class="nav-item @(isMyContent ? "active" : "")" asp-area="Editor" asp-controller="MyContent" asp-action="Index">
                        <i class="fa-solid fa-folder-tree"></i><span>Nội dung của tôi</span>
                    </a>
                </div>
                <div class="sidebar-section">
                    <div class="sidebar-section-label">Nội dung</div>
                    <a class="nav-item @(isPoiSection ? "active" : "")" asp-area="Editor" asp-controller="Poi" asp-action="Index">
                        <i class="fa-solid fa-map-pin"></i><span>Điểm tham quan</span>
                    </a>
                    <a class="nav-item @(isTourSection ? "active" : "")" asp-area="Editor" asp-controller="Tour" asp-action="Index">
                        <i class="fa-solid fa-route"></i><span>Tour du lịch</span>
                    </a>
                    <a class="nav-item @(isCategorySection ? "active" : "")" asp-area="Editor" asp-controller="Category" asp-action="Index">
                        <i class="fa-solid fa-tags"></i><span>Danh mục</span>
                    </a>
                    <a class="nav-item @(currentController == "Media" ? "active" : "")" asp-area="Editor" asp-controller="Media" asp-action="Library">
                        <i class="fa-solid fa-photo-film"></i><span>Thư viện media</span>
                    </a>
                </div>
                <div class="sidebar-section">
                    <div class="sidebar-section-label">AI hỗ trợ</div>
                    <a class="nav-item @(currentController == "AudioTasks" ? "active" : "")" href="/Editor/AudioTasks">
                        <i class="fa-solid fa-wand-magic-sparkles"></i><span>Tác vụ AI Media</span>
                    </a>
                </div>
            </nav>

            <div class="sidebar-footer dropdown">
                <button class="user-card" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="user-avatar"><i class="fa-solid fa-user-pen"></i></span>
                    <span class="user-info">
                        <span class="user-name">@User.Identity?.Name</span>
                        <span class="user-role">Biên tập viên</span>
                    </span>
                    <i class="fa-solid fa-chevron-up user-chevron"></i>
                </button>
                <ul class="dropdown-menu app-dropdown">
                    <li><span class="dropdown-item-text small text-muted">Tài khoản nhân sự chỉ dùng trong cổng này.</span></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form action="/Editor/Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button class="dropdown-item text-danger" type="submit"><i class="fa-solid fa-right-from-bracket"></i> Đăng xuất</button>
                        </form>
                    </li>
                </ul>
            </div>
        </aside>

        <main class="main">
            <header class="header">
                <button class="icon-btn sidebar-toggle" type="button" data-sidebar-toggle aria-label="Mở menu"><i class="fa-solid fa-bars"></i></button>
                <div class="header-title">
                    <span class="header-kicker">Không gian biên tập</span>
                    <strong>@pageTitle</strong>
                </div>
                <form class="global-search" asp-area="Editor" asp-controller="Workspace" asp-action="Board" method="get">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="search" name="q" placeholder="Tìm nhanh điểm tham quan..." aria-label="Tìm POI" />
                    <kbd>Enter</kbd>
                </form>
                <div class="header-actions">
                    <button type="button" class="icon-btn" id="theme-toggle" title="Đổi giao diện sáng/tối" aria-label="Đổi giao diện"><i class="fa-solid fa-moon"></i></button>
                    <a class="icon-btn" title="Bảng làm việc" asp-area="Editor" asp-controller="Workspace" asp-action="Board"><i class="fa-solid fa-table-list"></i></a>
                    <a class="icon-btn" title="Tạo POI" asp-area="Editor" asp-controller="Poi" asp-action="Create"><i class="fa-solid fa-plus"></i></a>
                </div>
            </header>

            <div class="content">
                <div class="content-inner">
                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert app-alert success" role="alert"><i class="fa-solid fa-circle-check"></i><span>@successMessage</span><button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button></div>
                    }
                    @if (TempData["ErrorMessage"] is string errorMessage)
                    {
                        <div class="alert app-alert error" role="alert"><i class="fa-solid fa-circle-exclamation"></i><span>@errorMessage</span><button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button></div>
                    }
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const root = document.documentElement;
            const sidebar = document.getElementById('editorSidebar');
            const themeToggle = document.getElementById('theme-toggle');
            const applyTheme = theme => {
                root.dataset.theme = theme;
                const icon = themeToggle?.querySelector('i');
                icon?.classList.toggle('fa-sun', theme === 'light');
                icon?.classList.toggle('fa-moon', theme !== 'light');
            };
            applyTheme(localStorage.getItem('versa-theme') || 'dark');
            themeToggle?.addEventListener('click', () => {
                const next = root.dataset.theme === 'light' ? 'dark' : 'light';
                localStorage.setItem('versa-theme', next);
                applyTheme(next);
            });
            const sidebarNav = sidebar?.querySelector('.sidebar-nav');
            const sidebarScrollKey = 'versa-editor-sidebar-scroll';
            const normalizePath = value => value.replace(/\/+$/, '') || '/';
            const saveSidebarScroll = () => {
                if (sidebarNav) {
                    sessionStorage.setItem(sidebarScrollKey, String(sidebarNav.scrollTop));
                }
            };
            const restoreSidebarScroll = () => {
                if (!sidebarNav) return;

                const saved = Number(sessionStorage.getItem(sidebarScrollKey) || '0');
                if (!Number.isNaN(saved) && saved > 0) {
                    sidebarNav.scrollTop = saved;
                }
            };

            requestAnimationFrame(restoreSidebarScroll);
            window.addEventListener('pageshow', restoreSidebarScroll);
            window.addEventListener('beforeunload', saveSidebarScroll);
            sidebarNav?.addEventListener('scroll', saveSidebarScroll, { passive: true });

            document.querySelector('[data-sidebar-toggle]')?.addEventListener('click', () => document.body.classList.toggle('sidebar-open'));
            document.querySelectorAll('[data-sidebar-close]').forEach(target => target.addEventListener('click', () => document.body.classList.remove('sidebar-open')));
            sidebar?.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', event => {
                    const rawHref = link.getAttribute('href');
                    document.body.classList.remove('sidebar-open');
                    saveSidebarScroll();

                    if (!rawHref || rawHref === '#' || link.target === '_blank') {
                        return;
                    }

                    const nextUrl = new URL(link.href, window.location.href);
                    const currentUrl = new URL(window.location.href);
                    const isSamePage = nextUrl.origin === currentUrl.origin
                        && normalizePath(nextUrl.pathname) === normalizePath(currentUrl.pathname)
                        && nextUrl.search === currentUrl.search
                        && nextUrl.hash === currentUrl.hash;

                    if (isSamePage) {
                        event.preventDefault();
                    }
                });
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
