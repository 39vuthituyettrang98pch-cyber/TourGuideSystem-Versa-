@model ReviewerDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan kiểm duyệt";
}

<div class="page-heading">
    <div>
        <div class="page-title">Không gian kiểm duyệt POI</div>
        <div class="page-subtitle">Kiểm tra nội dung do biên tập viên gửi trước khi xuất bản lên ứng dụng.</div>
    </div>
    <div class="page-actions">
        <a asp-area="Reviewer" asp-controller="Approval" asp-action="PoiPending" class="btn btn-primary"><i class="fa-solid fa-list-check"></i> Mở hàng chờ duyệt</a>
    </div>
</div>

<div class="reviewer-notice">
    <span class="stat-icon"><i class="fa-solid fa-shield-halved"></i></span>
    <div>
        <strong>Vai trò kiểm duyệt viên</strong>
        <p>Bạn có thể phê duyệt hoặc từ chối POI. Khi từ chối, hãy nhập lý do rõ ràng để biên tập viên chỉnh sửa.</p>
    </div>
</div>

<div class="stats-grid">
    <a class="stat-card" asp-area="Reviewer" asp-controller="Approval" asp-action="PoiPending">
        <span class="stat-icon"><i class="fa-solid fa-hourglass-half"></i></span>
        <span><span class="stat-value">@Model.PendingPois</span><span class="stat-label">Đang chờ duyệt</span></span>
    </a>
    <div class="stat-card">
        <span class="stat-icon"><i class="fa-solid fa-circle-check"></i></span>
        <span><span class="stat-value">@Model.ApprovedPois</span><span class="stat-label">Đã phê duyệt</span></span>
    </div>
    <div class="stat-card">
        <span class="stat-icon"><i class="fa-solid fa-circle-xmark"></i></span>
        <span><span class="stat-value">@Model.RejectedPois</span><span class="stat-label">Đã từ chối</span></span>
    </div>
</div>

<section class="card" style="margin-top:18px">
    <div class="card-header">
        <div>
            <div class="card-title"><i class="fa-solid fa-clock-rotate-left"></i> POI chờ duyệt gần nhất</div>
            <div class="card-subtitle">Ưu tiên kiểm tra các nội dung mới được gửi.</div>
        </div>
        <a asp-area="Reviewer" asp-controller="Approval" asp-action="PoiPending" class="btn btn-secondary btn-sm">Xem tất cả</a>
    </div>
    <div class="table-wrapper">
        <table class="data-table">
            <thead><tr><th>POI</th><th>Tọa độ</th><th>Ngày gửi</th><th></th></tr></thead>
            <tbody>
            @if (Model.RecentPendingPois.Count > 0)
            {
                foreach (var poi in Model.RecentPendingPois)
                {
                    var name = poi.Translations.FirstOrDefault(item => item.LanguageCode == "vi")?.Name ?? $"POI #{poi.Id}";
                    <tr>
                        <td><strong>@name</strong><br /><small style="color:var(--text-soft)">#@poi.Id · @poi.Translations.Count ngôn ngữ</small></td>
                        <td><code>@poi.Latitude, @poi.Longitude</code></td>
                        <td>@poi.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><a asp-area="Reviewer" asp-controller="Approval" asp-action="PoiPending" class="btn btn-primary btn-sm">Kiểm duyệt</a></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4"><div class="empty-state"><i class="fa-solid fa-circle-check"></i><h2>Hàng chờ đã trống</h2><p>Hiện không có POI nào cần kiểm duyệt.</p></div></td></tr>
            }
            </tbody>
        </table>
    </div>
</section>
