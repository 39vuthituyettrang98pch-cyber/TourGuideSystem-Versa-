@{
    ViewData["Title"] = "Không có quyền truy cập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Không có quyền - VERSA Owner</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        * { box-sizing: border-box; }
        body { margin:0; min-height:100vh; display:grid; place-items:center; padding:24px; color:#f8fbff; background:radial-gradient(circle at 10% 10%, rgba(251,113,133,.18), transparent 34%), radial-gradient(circle at 90% 20%, rgba(56,189,248,.16), transparent 34%), #06111f; font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; }
        .card { width:min(620px,100%); border:1px solid rgba(148,163,184,.22); border-radius:30px; background:rgba(12,24,44,.92); box-shadow:0 28px 90px rgba(0,0,0,.36); padding:40px; text-align:center; }
        .icon { width:76px; height:76px; margin:0 auto 20px; border-radius:28px; display:grid; place-items:center; color:#fff; background:linear-gradient(135deg,#fb7185,#f97316); font-size:30px; }
        h1 { margin:0 0 10px; font-size:34px; letter-spacing:-.04em; }
        p { margin:0; color:#a9bad7; line-height:1.7; font-weight:700; }
        .actions { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:24px; }
        .btn { min-height:48px; padding:0 18px; border-radius:999px; border:1px solid rgba(148,163,184,.22); display:inline-flex; align-items:center; justify-content:center; gap:9px; color:#f8fbff; background:rgba(148,163,184,.10); font-weight:950; text-decoration:none; }
        .btn-primary { border:0; color:#03131d; background:linear-gradient(135deg,#34d399,#38bdf8); }
    </style>
</head>
<body>
    <main class="card">
        <div class="icon"><i class="fa-solid fa-lock"></i></div>
        <h1>Không có quyền truy cập</h1>
        <p>
            Trang này chỉ dành cho tài khoản chủ gian hàng đã được duyệt.
            Admin, Editor, Reviewer và Du khách không dùng khu vực Owner Center.
        </p>
        <div class="actions">
            <a href="/Owner/Account/Login" class="btn btn-primary"><i class="fa-solid fa-right-to-bracket"></i> Đăng nhập Owner</a>
            <a href="/DuKhach" class="btn"><i class="fa-solid fa-house"></i> Về web du khách</a>
        </div>
    </main>
</body>
</html>
