@{
    ViewData["Title"] = "Đăng ký chủ gian hàng";
    Layout = null;

    var username = ViewBag.Username as string ?? "";
    var email = ViewBag.Email as string ?? "";
    var businessName = ViewBag.BusinessName as string ?? "";
    var representativeName = ViewBag.RepresentativeName as string ?? "";
    var phone = ViewBag.Phone as string ?? "";
    var address = ViewBag.Address as string ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng ký chủ gian hàng - VERSA Travel</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 24px;
            color: #f8fbff;
            background:
                radial-gradient(circle at 12% 8%, rgba(52, 211, 153, .22), transparent 34%),
                radial-gradient(circle at 92% 18%, rgba(56, 189, 248, .20), transparent 32%),
                linear-gradient(180deg, #06111f, #091a2e);
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .register-shell {
            width: min(980px, 100%);
            display: grid;
            grid-template-columns: .9fr 1.1fr;
            overflow: hidden;
            border-radius: 30px;
            border: 1px solid rgba(148, 163, 184, .22);
            background: rgba(12, 24, 44, .90);
            box-shadow: 0 28px 90px rgba(0, 0, 0, .36);
        }

        .register-intro {
            padding: 42px;
            display: grid;
            align-content: space-between;
            min-height: 640px;
            background:
                linear-gradient(145deg, rgba(52, 211, 153, .20), rgba(56, 189, 248, .10)),
                rgba(148, 163, 184, .06);
        }

        .brand { display: flex; align-items: center; gap: 12px; font-weight: 950; }
        .brand-icon {
            width: 52px;
            height: 52px;
            border-radius: 20px;
            display: grid;
            place-items: center;
            color: #03131d;
            background: linear-gradient(135deg, #34d399, #38bdf8);
            box-shadow: 0 16px 40px rgba(52, 211, 153, .28);
        }
        .brand small { display: block; margin-top: 3px; color: #a9bad7; font-weight: 800; font-size: 12px; }
        .register-intro h1 { margin: 0 0 14px; font-size: clamp(34px, 5vw, 58px); line-height: 1; letter-spacing: -.06em; }
        .register-intro p { margin: 0; color: #a9bad7; line-height: 1.75; font-weight: 650; }

        .register-form-wrap { padding: 42px; }
        .register-form-wrap h2 { margin: 0 0 6px; font-size: 28px; font-weight: 950; letter-spacing: -.04em; }
        .register-form-wrap > p { margin: 0 0 24px; color: #a9bad7; font-size: 14px; line-height: 1.6; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .field { display: grid; gap: 8px; }
        .field.full { grid-column: 1 / -1; }
        label { color: #a9bad7; font-size: 12px; font-weight: 900; }
        input {
            width: 100%;
            min-height: 48px;
            border-radius: 16px;
            border: 1px solid rgba(148, 163, 184, .22);
            outline: none;
            color: #f8fbff;
            background: rgba(148, 163, 184, .10);
            padding: 0 14px;
            font: inherit;
            font-size: 14px;
            font-weight: 750;
        }
        input:focus { border-color: #38bdf8; box-shadow: 0 0 0 4px rgba(56, 189, 248, .12); }
        .error {
            margin-bottom: 16px;
            padding: 14px 15px;
            border-radius: 18px;
            border: 1px solid rgba(251, 113, 133, .28);
            background: rgba(251, 113, 133, .12);
            color: #fecdd3;
            font-weight: 750;
            line-height: 1.55;
        }
        .actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px; }
        .btn {
            min-height: 48px;
            padding: 0 18px;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, .22);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            color: #f8fbff;
            background: rgba(148, 163, 184, .10);
            font-weight: 950;
            text-decoration: none;
            cursor: pointer;
        }
        .btn-primary { border: 0; color: #03131d; background: linear-gradient(135deg, #34d399, #38bdf8); }
        .note { margin-top: 18px; color: #a9bad7; font-size: 13px; line-height: 1.65; }
        @@media (max-width: 820px) { .register-shell { grid-template-columns: 1fr; } .register-intro { min-height: auto; gap: 26px; } }
        @@media (max-width: 560px) { body { padding: 12px; } .register-intro, .register-form-wrap { padding: 26px; } .form-grid { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <main class="register-shell">
        <section class="register-intro">
            <div class="brand">
                <span class="brand-icon"><i class="fa-solid fa-store"></i></span>
                <span>
                    VERSA Owner
                    <small>Chủ gian hàng / Chủ POI</small>
                </span>
            </div>

            <div>
                <h1>Đưa gian hàng lên bản đồ du lịch.</h1>
                <p>
                    Đăng ký tài khoản chủ gian hàng để quản lý POI, xem đánh giá, theo dõi lượt quét QR,
                    lượt nghe thuyết minh và đăng ký gói dịch vụ.
                </p>
            </div>
        </section>

        <section class="register-form-wrap">
            <h2>Đăng ký chủ gian hàng</h2>
            <p>Sau khi gửi đăng ký, admin sẽ duyệt tài khoản trước khi bạn đăng nhập vào Owner Center.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(item => item.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form action="/Owner/Account/Register" method="post">
                @Html.AntiForgeryToken()

                <div class="form-grid">
                    <div class="field">
                        <label>Username</label>
                        <input name="username" value="@username" autocomplete="username" required />
                    </div>

                    <div class="field">
                        <label>Email</label>
                        <input name="email" type="email" value="@email" autocomplete="email" required />
                    <small style="color:var(--muted);">Chỉ dùng Gmail: ví dụ tenban@gmail.com</small>
                    </div>

                    <div class="field">
                        <label>Mật khẩu</label>
                        <input name="password" type="password" autocomplete="new-password" required />
                    </div>

                    <div class="field">
                        <label>Xác nhận mật khẩu</label>
                        <input name="confirmPassword" type="password" autocomplete="new-password" required />
                    </div>

                    <div class="field full">
                        <label>Tên gian hàng / tên quán</label>
                        <input name="businessName" value="@businessName" placeholder="VD: Cà phê Sài Gòn Xưa" required />
                    </div>

                    <div class="field">
                        <label>Người đại diện</label>
                        <input name="representativeName" value="@representativeName" />
                    </div>

                    <div class="field">
                        <label>Số điện thoại</label>
                        <input name="phone" value="@phone" />
                    </div>

                    <div class="field full">
                        <label>Địa chỉ gian hàng</label>
                        <input name="address" value="@address" />
                    </div>
                </div>

                <div class="actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-paper-plane"></i>
                        Gửi đăng ký
                    </button>

                    <a href="/Owner/Account/Login" class="btn">
                        <i class="fa-solid fa-right-to-bracket"></i>
                        Đã có tài khoản Owner
                    </a>

                    <a href="/DuKhach" class="btn">
                        <i class="fa-solid fa-house"></i>
                        Về web du khách
                    </a>
                </div>

                <div class="note">
                    Trạng thái sau đăng ký là <b>Pending</b>. Admin vào mục <b>Chủ gian hàng</b> để duyệt, sau đó tài khoản mới đăng nhập được.
                </div>
            </form>
        </section>
    </main>
</body>
</html>
