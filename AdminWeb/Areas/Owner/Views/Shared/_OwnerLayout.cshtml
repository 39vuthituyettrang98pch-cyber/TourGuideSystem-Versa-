@{
    var title = ViewData["Title"]?.ToString() ?? "Chủ gian hàng";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Dashboard";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

    var businessName = User.FindFirst("BusinessName")?.Value
        ?? User.Identity?.Name
        ?? "Owner";

    var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
        ?? User.FindFirst("Email")?.Value
        ?? "";

    Func<string, bool> Active = name =>
        string.Equals(controller, name, StringComparison.OrdinalIgnoreCase);

    Func<string[], bool> ActiveAny = names =>
        names.Any(name => string.Equals(controller, name, StringComparison.OrdinalIgnoreCase));

    var avatarText = string.IsNullOrWhiteSpace(businessName)
        ? "O"
        : businessName.Trim()[0].ToString().ToUpperInvariant();
}

<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@title - VERSA Owner</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/owner-portal.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --owner-bg: #06111f;
            --owner-bg-2: #0a1a2e;
            --owner-sidebar: rgba(9, 20, 38, 0.92);
            --owner-card: rgba(15, 30, 54, 0.86);
            --owner-card-2: rgba(20, 40, 70, 0.72);
            --owner-text: #f6f9ff;
            --owner-muted: #a9bad7;
            --owner-soft: #7589ad;
            --owner-border: rgba(148, 163, 184, 0.20);
            --owner-accent: #34d399;
            --owner-accent-2: #38bdf8;
            --owner-danger: #fb7185;
            --owner-warning: #fbbf24;
            --owner-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
            --owner-radius: 26px;
        }

        html[data-theme="light"] {
            --owner-bg: #f4f8ff;
            --owner-bg-2: #e9f3ff;
            --owner-sidebar: rgba(255, 255, 255, 0.92);
            --owner-card: rgba(255, 255, 255, 0.94);
            --owner-card-2: rgba(248, 250, 252, 0.88);
            --owner-text: #102033;
            --owner-muted: #536783;
            --owner-soft: #71809a;
            --owner-border: rgba(15, 23, 42, 0.12);
            --owner-shadow: 0 24px 70px rgba(15, 23, 42, 0.12);
        }

        html,
        body {
            width: 100%;
            min-height: 100%;
            height: 100%;
            overflow: hidden !important;
        }

        body {
            margin: 0;
            color: var(--owner-text);
            background:
                radial-gradient(circle at 8% 10%, rgba(52, 211, 153, 0.18), transparent 30%),
                radial-gradient(circle at 90% 18%, rgba(56, 189, 248, 0.16), transparent 32%),
                radial-gradient(circle at 50% 95%, rgba(167, 139, 250, 0.12), transparent 34%),
                linear-gradient(180deg, var(--owner-bg), var(--owner-bg-2));
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -1;
            background-image:
                linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
            background-size: 44px 44px;
            mask-image: linear-gradient(to bottom, rgba(0,0,0,.78), transparent);
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .owner-shell {
            width: 100%;
            min-height: 100vh !important;
            height: 100vh !important;
            display: grid;
            grid-template-columns: 292px minmax(0, 1fr);
            overflow: hidden !important;
        }

        .owner-sidebar {
            position: sticky;
            top: 0;
            align-self: start;
            height: 100vh;
            min-height: 100vh;
            max-height: 100vh;
            overflow-y: auto;
            padding: 22px 18px;
            border-right: 1px solid var(--owner-border);
            background:
                radial-gradient(circle at 20% 0%, rgba(52, 211, 153, .14), transparent 34%),
                var(--owner-sidebar);
            backdrop-filter: blur(22px);
            z-index: 2000;
        }

        .owner-sidebar::-webkit-scrollbar {
            width: 8px;
        }

        .owner-sidebar::-webkit-scrollbar-thumb {
            border-radius: 999px;
            background: rgba(148, 163, 184, .28);
        }

        .owner-brand {
            display: flex;
            align-items: center;
            gap: 13px;
            padding: 12px;
            border-radius: 24px;
            margin-bottom: 22px;
            border: 1px solid var(--owner-border);
            background: rgba(148, 163, 184, 0.08);
        }

        .owner-brand:hover {
            color: var(--owner-text);
            background: rgba(148, 163, 184, 0.13);
        }

        .owner-brand-icon {
            width: 48px;
            height: 48px;
            min-width: 48px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            color: #03131d;
            background: linear-gradient(135deg, var(--owner-accent), var(--owner-accent-2));
            box-shadow: 0 18px 42px rgba(52, 211, 153, .22);
        }

        .owner-brand strong {
            display: block;
            font-size: 16px;
            font-weight: 950;
            letter-spacing: -.02em;
        }

        .owner-brand small {
            display: block;
            margin-top: 3px;
            color: var(--owner-muted);
            font-size: 10px;
            font-weight: 900;
            letter-spacing: .12em;
        }

        .owner-nav-section {
            margin-top: 18px;
        }

        .owner-nav-label {
            padding: 0 12px;
            margin-bottom: 9px;
            color: var(--owner-soft);
            font-size: 11px;
            font-weight: 950;
            text-transform: uppercase;
            letter-spacing: .12em;
        }

        .owner-nav {
            display: grid;
            gap: 7px;
        }

        .owner-nav a {
            position: relative;
            min-height: 46px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 13px;
            border-radius: 17px;
            color: var(--owner-muted);
            border: 1px solid transparent;
            font-size: 14px;
            font-weight: 850;
            transition: .18s ease;
        }

        .owner-nav a i {
            width: 20px;
            text-align: center;
            font-size: 14px;
        }

        .owner-nav a:hover {
            color: var(--owner-text);
            background: rgba(148, 163, 184, 0.10);
            border-color: var(--owner-border);
            transform: translateX(2px);
        }

        .owner-nav a.active {
            color: #03131d;
            background: linear-gradient(135deg, var(--owner-accent), var(--owner-accent-2));
            border-color: transparent;
            box-shadow: 0 16px 34px rgba(52, 211, 153, .18);
        }

        .owner-nav a.active::before {
            content: "";
            position: absolute;
            left: -8px;
            width: 4px;
            height: 24px;
            border-radius: 999px;
            background: linear-gradient(180deg, var(--owner-accent), var(--owner-accent-2));
        }

        .owner-sidebar-card {
            margin-top: 20px;
            padding: 17px;
            border-radius: 24px;
            border: 1px solid var(--owner-border);
            background:
                radial-gradient(circle at 85% 0%, rgba(56, 189, 248, .18), transparent 42%),
                rgba(148, 163, 184, .08);
        }

        .owner-sidebar-card strong {
            display: block;
            font-size: 15px;
            font-weight: 950;
            margin-bottom: 7px;
        }

        .owner-sidebar-card p {
            margin: 0;
            color: var(--owner-muted);
            font-size: 12.5px;
            line-height: 1.6;
        }

        .owner-main {
            min-width: 0;
            height: 100vh !important;
            min-height: 100vh !important;
            overflow-x: hidden !important;
            overflow-y: auto !important;
            scroll-behavior: smooth;
        }

        .owner-main::-webkit-scrollbar {
            width: 9px;
        }

        .owner-main::-webkit-scrollbar-thumb {
            border-radius: 999px;
            background: rgba(148, 163, 184, .30);
        }

        .owner-topbar {
            position: sticky;
            top: 0;
            z-index: 1500;
            min-height: 84px;
            padding: 16px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            border-bottom: 1px solid var(--owner-border);
            background: rgba(6, 17, 31, .72);
            backdrop-filter: blur(22px);
        }

        html[data-theme="light"] .owner-topbar {
            background: rgba(244, 248, 255, .82);
        }

        .owner-mobile-toggle {
            display: none;
            width: 42px;
            height: 42px;
            border-radius: 15px;
            border: 1px solid var(--owner-border);
            color: var(--owner-text);
            background: rgba(148, 163, 184, .10);
        }

        .owner-title-wrap {
            min-width: 0;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .owner-page-kicker {
            color: var(--owner-accent);
            font-size: 12px;
            font-weight: 950;
            letter-spacing: .12em;
            text-transform: uppercase;
        }

        .owner-topbar-context {
            display: grid;
            gap: 3px;
            min-width: 0;
        }

        .owner-topbar-subtitle {
            color: var(--owner-muted);
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .owner-page-title {
            margin: 2px 0 0;
            color: var(--owner-text);
            font-size: clamp(22px, 2.6vw, 34px);
            font-weight: 950;
            line-height: 1.05;
            letter-spacing: -.04em;
        }

        .owner-top-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 9px;
            flex-wrap: wrap;
        }

        .owner-account-pill {
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 5px 12px 5px 5px;
            border-radius: 999px;
            border: 1px solid var(--owner-border);
            color: var(--owner-text);
            background: rgba(148, 163, 184, .10);
            font-size: 13px;
            font-weight: 900;
        }

        .owner-avatar {
            width: 32px;
            height: 32px;
            min-width: 32px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            color: #03131d;
            background: linear-gradient(135deg, var(--owner-accent), var(--owner-accent-2));
            font-weight: 950;
        }

        .owner-account-info {
            display: grid;
            line-height: 1.15;
        }

        .owner-account-info small {
            max-width: 170px;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--owner-muted);
            font-size: 10.5px;
            font-weight: 800;
        }

        .owner-btn-soft {
            min-height: 42px;
            border-radius: 15px;
            border: 1px solid var(--owner-border);
            color: var(--owner-text);
            background: rgba(148, 163, 184, .10);
            font-size: 13px;
            font-weight: 850;
        }

        .owner-btn-soft:hover {
            color: var(--owner-text);
            border-color: rgba(52, 211, 153, .32);
            background: rgba(52, 211, 153, .10);
            transform: translateY(-1px);
        }

        .owner-content {
            min-height: calc(100vh - 84px) !important;
            height: auto !important;
            overflow: visible !important;
            padding: 28px 28px 48px;
        }

        .owner-alert-stack {
            display: grid;
            gap: 12px;
            margin-bottom: 18px;
        }

        .owner-alert {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border-radius: 18px;
            border: 1px solid var(--owner-border);
            color: var(--owner-text);
            background: var(--owner-card);
            box-shadow: 0 14px 38px rgba(0, 0, 0, .12);
        }

        .owner-alert.success {
            border-color: rgba(52, 211, 153, .30);
            background: rgba(52, 211, 153, .12);
        }

        .owner-alert.success i {
            color: var(--owner-accent);
        }

        .owner-alert.error {
            border-color: rgba(251, 113, 133, .30);
            background: rgba(251, 113, 133, .12);
        }

        .owner-alert.error i {
            color: var(--owner-danger);
        }

        .owner-sidebar-backdrop {
            display: none;
        }

        @@media (max-width: 1180px) {
            .owner-shell {
                grid-template-columns: 260px minmax(0, 1fr);
            }

            .owner-sidebar {
                padding: 18px 14px;
            }

            .owner-nav a {
                font-size: 13px;
            }
        }

        @@media (max-width: 980px) {
            html,
            body {
                height: auto;
                overflow-x: hidden !important;
                overflow-y: auto !important;
            }

            .owner-shell {
                display: block;
                height: auto !important;
                min-height: 100vh !important;
                overflow: visible !important;
            }

            .owner-main {
                height: auto !important;
                min-height: 100vh !important;
                overflow: visible !important;
            }

            .owner-sidebar {
                position: fixed;
                inset: 0 auto 0 0;
                width: min(320px, calc(100vw - 48px));
                max-height: 100vh;
                transform: translateX(-105%);
                transition: transform .22s ease;
                box-shadow: 30px 0 90px rgba(0, 0, 0, .35);
            }

            body.owner-sidebar-open .owner-sidebar {
                transform: translateX(0);
            }

            .owner-sidebar-backdrop {
                position: fixed;
                inset: 0;
                display: none;
                background: rgba(0, 0, 0, .52);
                z-index: 1900;
            }

            body.owner-sidebar-open .owner-sidebar-backdrop {
                display: block;
            }

            .owner-mobile-toggle {
                display: inline-grid;
                place-items: center;
            }

            .owner-topbar {
                padding: 14px 16px;
                align-items: flex-start;
            }

            .owner-title-wrap {
                align-items: flex-start;
            }

            .owner-top-actions {
                gap: 7px;
            }

            .owner-content {
                padding: 18px 14px 34px;
            }
        }

        @@media (max-width: 680px) {
            .owner-topbar {
                flex-direction: column;
                align-items: stretch;
            }

            .owner-top-actions {
                justify-content: flex-start;
                overflow-x: auto;
                flex-wrap: nowrap;
                padding-bottom: 2px;
            }

            .owner-account-info small {
                display: none;
            }

            .owner-btn-soft span {
                display: none;
            }

            .owner-btn-soft {
                width: 42px;
                padding-inline: 0;
            }

            .owner-page-title {
                font-size: 24px;
            }
        }
    </style>
</head>

<body>
    <div class="owner-sidebar-backdrop" id="ownerSidebarBackdrop"></div>

    <div class="owner-shell">
        <aside class="owner-sidebar" id="ownerSidebar">
            <a asp-area="Owner" asp-controller="Dashboard" asp-action="Index" class="owner-brand">
                <span class="owner-brand-icon">
                    <i class="fa-solid fa-store"></i>
                </span>

                <span>
                    <strong>VERSA Owner</strong>
                    <small>MERCHANT CENTER</small>
                </span>
            </a>

            <div class="owner-nav-section">
                <div class="owner-nav-label">Vận hành</div>

                <nav class="owner-nav">
                    <a class="@(Active("Dashboard") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Dashboard"
                       asp-action="Index">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Tổng quan</span>
                    </a>

                    <a class="@(Active("Poi") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Poi"
                       asp-action="Index">
                        <i class="fa-solid fa-map-pin"></i>
                        <span>Gian hàng / POI</span>
                    </a>

                    <a class="@(Active("Map") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Map"
                       asp-action="Index">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <span>Bản đồ POI của tôi</span>
                    </a>

                    <a class="@(Active("MenuItems") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="MenuItems"
                       asp-action="Index">
                        <i class="fa-solid fa-utensils"></i>
                        <span>Menu / sản phẩm</span>
                    </a>

                    <a class="@(Active("MenuOrders") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="MenuOrders"
                       asp-action="Index">
                        <i class="fa-solid fa-receipt"></i>
                        <span>Đơn mua menu</span>
                    </a>

                    <a class="@(Active("Reviews") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Reviews"
                       asp-action="Index">
                        <i class="fa-solid fa-star"></i>
                        <span>Đánh giá</span>
                    </a>

                    <a class="@(Active("Reports") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Reports"
                       asp-action="Index">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Báo cáo & doanh thu</span>
                    </a>
                </nav>
            </div>

            <div class="owner-nav-section">
                <div class="owner-nav-label">Kinh doanh</div>

                <nav class="owner-nav">
                    <a class="@(Active("Payments") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Payments"
                       asp-action="Index">
                        <i class="fa-solid fa-credit-card"></i>
                        <span>Gói & thanh toán</span>
                    </a>

                    <a class="@(Active("Profile") ? "active" : "")"
                       asp-area="Owner"
                       asp-controller="Profile"
                       asp-action="Index">
                        <i class="fa-solid fa-id-card"></i>
                        <span>Hồ sơ gian hàng</span>
                    </a>

                    <a asp-area="DuKhach"
                       asp-controller="Home"
                       asp-action="Index"
                       target="_blank">
                        <i class="fa-solid fa-globe"></i>
                        <span>Xem web du khách</span>
                    </a>
                </nav>
            </div>

            <div class="owner-sidebar-card">
                <strong>@businessName</strong>
                <p>
                    Quản lý gian hàng, POI, menu/sản phẩm, đơn hàng, đánh giá,
                    báo cáo hoạt động và gói dịch vụ của bạn.
                </p>
            </div>
        </aside>

        <main class="owner-main">
            <header class="owner-topbar">
                <div class="owner-title-wrap">
                    <button type="button"
                            class="owner-mobile-toggle"
                            id="ownerSidebarToggle"
                            title="Mở menu">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <div class="owner-topbar-context" aria-label="Owner Center">
                        <div class="owner-page-kicker">Owner Center</div>
                        <div class="owner-topbar-subtitle">Khu vực chủ gian hàng / POI</div>
                    </div>
                </div>

                <div class="owner-top-actions">
                    <span class="owner-account-pill">
                        <span class="owner-avatar">@avatarText</span>

                        <span class="owner-account-info">
                            <span>@businessName</span>

                            @if (!string.IsNullOrWhiteSpace(email))
                            {
                                <small>@email</small>
                            }
                            else
                            {
                                <small>Chủ gian hàng</small>
                            }
                        </span>
                    </span>

                    <button type="button"
                            class="btn owner-btn-soft"
                            id="ownerThemeToggle"
                            title="Đổi giao diện">
                        <i class="fa-solid fa-moon"></i>
                    </button>

                    <form asp-area="Owner"
                          asp-controller="Account"
                          asp-action="Logout"
                          method="post"
                          style="display:inline;">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="btn owner-btn-soft" title="Đăng xuất">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span>Đăng xuất</span>
                        </button>
                    </form>
                </div>
            </header>

            <section class="owner-content">
                <div class="owner-alert-stack">
                    @if (TempData["OwnerSuccessMessage"] is string ownerSuccess)
                    {
                        <div class="owner-alert success">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>@ownerSuccess</span>
                        </div>
                    }

                    @if (TempData["OwnerErrorMessage"] is string ownerError)
                    {
                        <div class="owner-alert error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <span>@ownerError</span>
                        </div>
                    }

                    @if (TempData["SuccessMessage"] is string success)
                    {
                        <div class="owner-alert success">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>@success</span>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] is string error)
                    {
                        <div class="owner-alert error">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <span>@error</span>
                        </div>
                    }
                </div>

                @RenderBody()
            </section>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            const html = document.documentElement;
            const button = document.getElementById('ownerThemeToggle');
            const savedTheme = localStorage.getItem('versa-owner-theme') || 'dark';

            html.setAttribute('data-theme', savedTheme);

            function syncIcon() {
                if (!button) return;

                const theme = html.getAttribute('data-theme') || 'dark';

                button.innerHTML = theme === 'dark'
                    ? '<i class="fa-solid fa-moon"></i>'
                    : '<i class="fa-solid fa-sun"></i>';
            }

            syncIcon();

            button?.addEventListener('click', function () {
                const current = html.getAttribute('data-theme') || 'dark';
                const next = current === 'dark' ? 'light' : 'dark';

                html.setAttribute('data-theme', next);
                localStorage.setItem('versa-owner-theme', next);
                syncIcon();
            });
        })();

        (function () {
            const body = document.body;
            const toggle = document.getElementById('ownerSidebarToggle');
            const backdrop = document.getElementById('ownerSidebarBackdrop');

            function openSidebar() {
                body.classList.add('owner-sidebar-open');
            }

            function closeSidebar() {
                body.classList.remove('owner-sidebar-open');
            }

            toggle?.addEventListener('click', openSidebar);
            backdrop?.addEventListener('click', closeSidebar);

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeSidebar();
                }
            });

            document.querySelectorAll('.owner-sidebar a').forEach(function (link) {
                link.addEventListener('click', function () {
                    if (window.innerWidth <= 980) {
                        closeSidebar();
                    }
                });
            });
        })();
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>