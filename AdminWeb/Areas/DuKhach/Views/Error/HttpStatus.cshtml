@{
    var code = ViewBag.StatusCode as int? ?? 404;
    ViewData["Title"] = code == 404 ? "Không tìm thấy" : $"Lỗi {code}";
}

<section class="dk-empty" style="max-width:760px;margin:70px auto;text-align:center;">
    <i class="fa-solid fa-triangle-exclamation"></i>
    <h1>@code - Không tìm thấy nội dung</h1>
    <p>Đường dẫn này không thuộc khu vực du khách hoặc phiên đăng nhập đã hết hạn.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:20px;">
        <a class="dk-btn dk-btn-ghost" href="javascript:history.back()"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
        <a class="dk-btn dk-btn-primary" asp-area="DuKhach" asp-controller="Home" asp-action="Index"><i class="fa-solid fa-house"></i> Về trang du khách</a>
        <a class="dk-btn dk-btn-ghost" asp-area="DuKhach" asp-controller="Payments" asp-action="Plans"><i class="fa-solid fa-crown"></i> Gói dịch vụ</a>
    </div>
</section>
