@model IEnumerable<AdminWeb.Models.OwnerMenuItem>
@{
    var poi = ViewBag.Poi as AdminWeb.Models.Poi;
    var poiName = poi?.Translations.FirstOrDefault(t => t.LanguageCode == "vi")?.Name
        ?? poi?.Translations.FirstOrDefault()?.Name
        ?? "POI";
    ViewData["Title"] = "Menu / sản phẩm";
}

@section Styles {
<style>
    .poi-menu-hero {
        border: 1px solid var(--border);
        border-radius: 34px;
        padding: 32px;
        background: var(--surface);
        box-shadow: var(--shadow);
        margin-bottom: 22px;
    }

    .poi-menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(236px, 1fr));
        gap: 22px;
        align-items: stretch;
    }

    .poi-menu-card {
        border: 1px solid var(--border);
        border-radius: 28px;
        background: var(--card);
        box-shadow: var(--shadow);
        overflow: hidden;
        height: 100%;
        min-height: 438px;
        display: flex;
        flex-direction: column;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }

    .poi-menu-card:hover {
        transform: translateY(-4px);
        border-color: rgba(34, 211, 238, .55);
        box-shadow: 0 24px 60px rgba(15, 23, 42, .14);
    }

    .poi-menu-media {
        width: 100%;
        height: 170px;
        flex: 0 0 170px;
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, rgba(34, 211, 238, .16), rgba(52, 211, 153, .14));
    }

    .poi-menu-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .poi-menu-placeholder {
        width: 100%;
        height: 100%;
        display: grid;
        place-items: center;
        font-size: 46px;
        background:
            radial-gradient(circle at 15% 20%, rgba(255, 255, 255, .45), transparent 12%),
            radial-gradient(circle at 85% 85%, rgba(255, 255, 255, .28), transparent 18%),
            linear-gradient(135deg, rgba(94, 234, 212, .72), rgba(34, 211, 238, .70));
    }

    .poi-menu-body {
        padding: 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .poi-menu-title {
        font-weight: 950;
        margin: 0 0 8px;
        color: var(--text);
        line-height: 1.12;
        min-height: 86px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .poi-menu-description {
        color: var(--muted);
        min-height: 46px;
        line-height: 1.45;
        margin: 0 0 12px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .poi-menu-price {
        font-size: 24px;
        font-weight: 950;
        color: var(--accent);
        margin-top: auto;
        white-space: nowrap;
    }

    .poi-menu-buy {
        width: 100%;
        margin-top: 14px;
        justify-content: center;
    }

    @@media (min-width: 1500px) {
        .poi-menu-grid {
            grid-template-columns: repeat(6, minmax(0, 1fr));
        }
    }

    @@media (max-width: 900px) {
        .poi-menu-grid {
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
            gap: 16px;
        }

        .poi-menu-card {
            min-height: 420px;
        }

        .poi-menu-title {
            min-height: 76px;
            font-size: 20px;
        }
    }
</style>
}

<div class="poi-menu-hero">
    <div class="dk-kicker"><i class="fa-solid fa-store"></i> Gian hàng</div>
    <h1 style="font-weight:950;letter-spacing:-.04em;margin:8px 0;">Menu / sản phẩm tại @poiName</h1>
    <p style="color:var(--muted);max-width:760px;">Du khách có thể xem menu và đặt mua món/sản phẩm. Đơn sẽ gửi tới chủ gian hàng để xác nhận, thanh toán trực tiếp tại quầy hoặc khi nhận hàng.</p>
    <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;">
        <a href="/DuKhach/Map#poi-@(poi?.Id ?? 0)" class="dk-btn dk-btn-ghost"><i class="fa-solid fa-map-location-dot"></i> Quay lại bản đồ</a>
        @if (Model.Any())
        {
            <a asp-area="DuKhach" asp-controller="MenuOrders" asp-action="Create" asp-route-poiId="@(poi?.Id ?? 0)" class="dk-btn dk-btn-primary"><i class="fa-solid fa-bag-shopping"></i> Đặt món / mua ngay</a>
        }
        <a asp-area="DuKhach" asp-controller="MenuOrders" asp-action="My" class="dk-btn dk-btn-ghost"><i class="fa-solid fa-receipt"></i> Đơn của tôi</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="poi-menu-hero"><strong>Chưa có menu/sản phẩm.</strong><p style="color:var(--muted);margin:8px 0 0;">Chủ gian hàng chưa cập nhật nội dung cho POI này.</p></div>
}
else
{
    <div class="poi-menu-grid">
        @foreach (var item in Model)
        {
            var imageUrl = item.ImageUrl;
            if (!string.IsNullOrWhiteSpace(imageUrl) && imageUrl.StartsWith("/uploads/demo/menu-items/", StringComparison.OrdinalIgnoreCase))
            {
                imageUrl = $"{imageUrl}?v=29";
            }

            <article class="poi-menu-card">
                <div class="poi-menu-media">
                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                    {
                        <img src="@imageUrl" alt="@item.Name" loading="lazy" />
                    }
                    else
                    {
                        <div class="poi-menu-placeholder" aria-label="Chưa có hình món ăn">🍽️</div>
                    }
                </div>

                <div class="poi-menu-body">
                    <h3 class="poi-menu-title" title="@item.Name">@item.Name</h3>
                    <p class="poi-menu-description">@item.Description</p>
                    <div class="poi-menu-price">@item.Price.ToString("N0") @item.Currency</div>
                    <a asp-area="DuKhach"
                       asp-controller="MenuOrders"
                       asp-action="Create"
                       asp-route-poiId="@item.PoiId"
                       asp-route-itemId="@item.Id"
                       class="dk-btn dk-btn-primary poi-menu-buy">
                        <i class="fa-solid fa-cart-plus"></i> Chọn mua
                    </a>
                </div>
            </article>
        }
    </div>
}
