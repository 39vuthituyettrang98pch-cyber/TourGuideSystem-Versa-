@{
    ViewData["Title"] = "Quét QR";
    var selectedLanguageCode = ViewBag.SelectedLanguageCode as string ?? "vi";
}

@section Styles {
    <style>
        .qr-scan-page {
            display: grid;
            gap: 24px;
        }

        .qr-hero {
            border-radius: 34px;
            padding: 34px;
            border: 1px solid var(--border);
            background:
                radial-gradient(circle at 10% 20%, rgba(52, 211, 153, .22), transparent 34%),
                radial-gradient(circle at 92% 10%, rgba(56, 189, 248, .18), transparent 32%),
                var(--surface);
            box-shadow: var(--shadow);
        }

        .qr-kicker {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 8px 13px;
            border-radius: 999px;
            color: #052e24;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            font-size: 12px;
            font-weight: 950;
            margin-bottom: 14px;
        }

        .qr-hero h1 {
            margin: 0;
            font-size: clamp(34px, 5vw, 64px);
            font-weight: 950;
            line-height: .98;
            letter-spacing: -.055em;
        }

        .qr-hero p {
            max-width: 760px;
            margin: 16px 0 0;
            color: var(--muted);
            font-size: 16px;
            line-height: 1.7;
        }

        .qr-layout {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 360px;
            gap: 22px;
            align-items: start;
        }

        .qr-card {
            border-radius: 30px;
            border: 1px solid var(--border);
            background: var(--card);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .qr-card-header {
            padding: 20px 22px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .qr-card-title {
            margin: 0;
            font-size: 18px;
            font-weight: 950;
        }

        .qr-card-subtitle {
            margin-top: 4px;
            color: var(--muted);
            font-size: 13px;
        }

        .qr-card-body {
            padding: 22px;
        }

        #qr-reader {
            width: 100%;
            min-height: 360px;
            border-radius: 24px;
            overflow: hidden;
            border: 1px dashed rgba(52, 211, 153, .36);
            background: rgba(148, 163, 184, .08);
        }

        #qr-reader video {
            border-radius: 22px;
        }

        .qr-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 16px;
        }

        .qr-message {
            margin-top: 14px;
            padding: 13px 15px;
            border-radius: 18px;
            display: none;
            font-weight: 800;
            border: 1px solid var(--border);
            background: rgba(148, 163, 184, .08);
        }

        .qr-message.ok {
            display: block;
            color: #34d399;
            border-color: rgba(52, 211, 153, .28);
            background: rgba(52, 211, 153, .12);
        }

        .qr-message.err {
            display: block;
            color: #fb7185;
            border-color: rgba(251, 113, 133, .28);
            background: rgba(251, 113, 133, .12);
        }

        .qr-manual-form {
            display: grid;
            gap: 10px;
        }

        .qr-manual-form input {
            min-height: 48px;
            border-radius: 17px;
            border: 1px solid var(--border);
            color: var(--text);
            background: rgba(148, 163, 184, .1);
            padding: 0 14px;
            outline: none;
            font-weight: 750;
        }

        .qr-tip {
            padding: 18px;
            border-radius: 24px;
            border: 1px solid var(--border);
            background: rgba(148, 163, 184, .08);
            color: var(--muted);
            line-height: 1.65;
            font-size: 14px;
        }

        .qr-tip strong {
            color: var(--text);
        }

        @@media (max-width: 980px) {
            .qr-layout {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="qr-scan-page">
    <section class="qr-hero">
        <div class="qr-kicker">
            <i class="fa-solid fa-qrcode"></i>
            QR POI
        </div>

        <h1>Quét QR điểm tham quan.</h1>

        <p>
            Dùng camera để quét mã QR tại điểm tham quan. Sau khi quét thành công,
            hệ thống sẽ mở trang chi tiết POI trên web. QR không cộng điểm; điểm chỉ tính khi check-in bằng GPS.
        </p>
    </section>

    <section class="qr-layout">
        <div class="qr-card">
            <div class="qr-card-header">
                <div>
                    <h2 class="qr-card-title">Camera quét QR</h2>
                    <div class="qr-card-subtitle">Cho phép trình duyệt truy cập camera để bắt đầu quét.</div>
                </div>
            </div>

            <div class="qr-card-body">
                <div id="qr-reader"></div>

                <div class="qr-actions">
                    <button type="button" class="dk-btn dk-btn-primary" id="btnStartQr">
                        <i class="fa-solid fa-camera"></i>
                        Mở camera
                    </button>

                    <button type="button" class="dk-btn dk-btn-ghost" id="btnStopQr">
                        <i class="fa-solid fa-stop"></i>
                        Dừng quét
                    </button>

                    <a asp-area="DuKhach" asp-controller="Map" asp-action="Index" asp-route-lang="@selectedLanguageCode" class="dk-btn dk-btn-ghost">
                        <i class="fa-solid fa-map-location-dot"></i>
                        Về bản đồ
                    </a>
                </div>

                <div class="qr-message" id="qrMessage"></div>
            </div>
        </div>

        <aside class="qr-card">
            <div class="qr-card-header">
                <div>
                    <h2 class="qr-card-title">Nhập mã thủ công</h2>
                    <div class="qr-card-subtitle">Dùng khi camera không mở được.</div>
                </div>
            </div>

            <div class="qr-card-body">
                <form class="qr-manual-form" id="qrManualForm">
                    <input type="text"
                           id="qrManualValue"
                           placeholder="Dán nội dung QR hoặc token POI..." />

                    <button type="submit" class="dk-btn dk-btn-primary">
                        <i class="fa-solid fa-arrow-right"></i>
                        Mở POI
                    </button>
                </form>

                <div class="qr-tip" style="margin-top:16px;">
                    <strong>Lưu ý:</strong><br />
                    Camera dùng được trên <b>localhost</b>. Khi đưa lên hosting thật,
                    web cần chạy bằng <b>HTTPS</b> thì trình duyệt mới cho phép mở camera.
                </div>
            </div>
        </aside>
    </section>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

    <script>
        const selectedLanguageCode = '@selectedLanguageCode';
        const openQrUrl = '@Url.Action("Open", "Qr", new { area = "DuKhach" })';

        const messageEl = document.getElementById('qrMessage');
        const btnStart = document.getElementById('btnStartQr');
        const btnStop = document.getElementById('btnStopQr');
        const manualForm = document.getElementById('qrManualForm');
        const manualInput = document.getElementById('qrManualValue');

        let qrScanner = null;
        let isScanning = false;
        let hasNavigated = false;

        function setQrMessage(message, type) {
            messageEl.textContent = message || '';
            messageEl.className = `qr-message ${type || ''}`;
        }

        function openQrValue(value) {
            if (!value || hasNavigated) return;

            hasNavigated = true;
            setQrMessage('Đã quét được mã QR. Đang mở trang chi tiết POI...', 'ok');

            const url = `${openQrUrl}?value=${encodeURIComponent(value)}&lang=auto`;
            window.location.href = url;
        }

        async function startScanner() {
            if (!window.Html5Qrcode) {
                setQrMessage('Không tải được thư viện quét QR. Kiểm tra kết nối mạng hoặc CDN.', 'err');
                return;
            }

            if (isScanning) return;

            try {
                qrScanner = qrScanner || new Html5Qrcode('qr-reader');

                const config = {
                    fps: 10,
                    qrbox: { width: 250, height: 250 },
                    aspectRatio: 1.0
                };

                await qrScanner.start(
                    { facingMode: 'environment' },
                    config,
                    decodedText => {
                        if (!decodedText) return;

                        qrScanner.stop().catch(() => { });
                        isScanning = false;
                        openQrValue(decodedText);
                    },
                    () => { }
                );

                isScanning = true;
                setQrMessage('Camera đã bật. Đưa mã QR vào khung quét.', 'ok');
            } catch (error) {
                console.error(error);
                setQrMessage('Không mở được camera. Hãy cấp quyền Camera hoặc thử nhập mã thủ công.', 'err');
            }
        }

        async function stopScanner() {
            if (!qrScanner || !isScanning) return;

            try {
                await qrScanner.stop();
                isScanning = false;
                setQrMessage('Đã dừng quét QR.', 'ok');
            } catch (error) {
                console.error(error);
            }
        }

        btnStart?.addEventListener('click', startScanner);
        btnStop?.addEventListener('click', stopScanner);

        manualForm?.addEventListener('submit', function (event) {
            event.preventDefault();
            openQrValue(manualInput.value.trim());
        });
    </script>
}
