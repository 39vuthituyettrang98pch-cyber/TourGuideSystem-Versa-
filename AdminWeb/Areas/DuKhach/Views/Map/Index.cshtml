@using System.Text.Json
@model DuKhachMapViewModel

@{
    ArgumentNullException.ThrowIfNull(Model);
    ViewData["Title"] = "Bản đồ du khách";

    var poiJson = JsonSerializer.Serialize(
        Model.Pois,
        new JsonSerializerOptions
        {
            PropertyNamingPolicy = JsonNamingPolicy.CamelCase
        });

    static string GetNativeLanguageDisplayName(string? code, string? currentName)
    {
        var normalizedCode = (code ?? string.Empty).Trim().ToLowerInvariant();
        return normalizedCode switch
        {
            "vi" => "Tiếng Việt",
            "en" => "English",
            "fr" => "Français",
            "zh" or "zh-cn" or "zh-tw" => "中文",
            "ja" => "日本語",
            "ko" => "한국어",
            "th" => "ไทย",
            "de" => "Deutsch",
            "es" => "Español",
            "it" => "Italiano",
            "pt" => "Português",
            "ru" => "Русский",
            _ => string.IsNullOrWhiteSpace(currentName) ? normalizedCode.ToUpperInvariant() : currentName.Trim()
        };
    }

    var selectedMapLanguageName = GetNativeLanguageDisplayName(
        Model.SelectedLanguageCode,
        Model.Languages
            .FirstOrDefault(language => string.Equals(language.Code, Model.SelectedLanguageCode, StringComparison.OrdinalIgnoreCase))
            ?.Name ?? Model.SelectedLanguageName ?? "Tiếng Việt");
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.4.1/dist/MarkerCluster.Default.css" />

    <style>
        /* =========================================================
           GLOBAL & LAYOUT TRANG
           ========================================================= */
        .dk-shell {
            width: min(1540px, calc(100% - 28px));
            margin: 0 auto;
        }

        .map-page {
            width: 100%;
            display: grid;
            grid-template-columns: minmax(0, 1fr) 440px;
            gap: 18px;
            align-items: stretch;
            height: calc(100vh - 120px);
            min-height: 680px;
            margin-bottom: 20px;
        }

        .map-main {
            position: relative;
            width: 100%;
            height: 100%;
            border-radius: 24px;
            overflow: hidden;
            background: #0b1b31;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        #touristMap {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            background: #dbeafe;
        }

        /* =========================================================
           UI PANEL BÊN PHẢI (GLASSMORPHISM & FLEXBOX FIX)
           ========================================================= */
        .map-side {
            display: flex;
            flex-direction: column;
            background: rgba(15, 23, 42, 0.75);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            box-shadow: -8px 0 30px rgba(0, 0, 0, 0.15);
            overflow: hidden;
            height: 100%;
        }

        .map-side-head {
            flex: 0 0 auto;
            padding: 20px 20px 10px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .map-side-title-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 12px;
        }

        .map-side-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.5px;
            color: #f8fafc;
        }

        .map-side-subtitle {
            font-size: 12.5px;
            color: #94a3b8;
            margin-top: 4px;
            line-height: 1.5;
        }

        .map-search {
            display: flex;
            align-items: center;
            gap: 10px;
            min-height: 44px;
            padding: 0 14px;
            border-radius: 14px;
            background: rgba(0, 0, 0, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.2s ease;
        }

        .map-search:focus-within {
            background: rgba(0, 0, 0, 0.4);
            border-color: rgba(56, 189, 248, 0.5);
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.15);
        }

        .map-search i {
            color: #64748b;
        }

        .map-search input {
            flex: 1;
            min-width: 0;
            border: 0;
            outline: 0;
            background: transparent;
            color: #f8fafc;
            font-weight: 600;
        }

        .map-search input::placeholder {
            color: #64748b;
        }

        /* Toolbar dạng Chip: cho phép xuống dòng để không che nút 4+ Sao */
        .map-toolbar-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            row-gap: 8px;
            margin-top: 14px;
            overflow: visible;
            padding-bottom: 4px;
        }

        .map-toolbar-chips::-webkit-scrollbar {
            height: 0px;
        }

        .chip-btn {
            flex: 0 0 auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 14px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            color: #cbd5e1;
            font-size: 12.5px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .chip-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
        }

        .chip-btn.primary {
            background: linear-gradient(135deg, #34d399, #38bdf8);
            color: #020617;
            border: none;
            font-weight: 700;
            box-shadow: 0 4px 15px rgba(52, 211, 153, 0.2);
        }

        .chip-btn.active {
            background: rgba(239, 68, 68, 0.15);
            border-color: rgba(239, 68, 68, 0.4);
            color: #f87171;
        }

        /* Danh sách POI */
        .poi-list {
            flex: 1 1 auto;
            height: auto;
            max-height: none;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 16px 32px 18px 20px; /* chừa chỗ cho thanh cuộn bên phải */
            display: flex;
            flex-direction: column;
            gap: 12px;
            scrollbar-gutter: stable both-edges;
        }

        .poi-list::-webkit-scrollbar,
        .detail-panel::-webkit-scrollbar {
            width: 6px;
        }

        .poi-list::-webkit-scrollbar-thumb,
        .detail-panel::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 10px;
        }

        .poi-list-item {
            position: relative;
            width: 100%;
            max-width: 100%;
            box-sizing: border-box;
            text-align: left;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 18px;
            padding: 16px;
            cursor: pointer;
            transition: transform 0.2s, background 0.2s, border-color 0.2s;
            overflow: visible;
        }

        .poi-list-item:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.15);
            transform: translateY(-2px);
        }

        .poi-list-item.active {
            background: rgba(56, 189, 248, 0.08);
            border-color: rgba(56, 189, 248, 0.4);
        }

        .poi-list-item.active::before {
            content: "";
            position: absolute;
            left: -1px;
            top: 16px;
            bottom: 16px;
            width: 4px;
            background: #38bdf8;
            border-radius: 0 4px 4px 0;
        }

        .poi-list-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px 10px;
            font-size: 15px;
            font-weight: 700;
            color: #f8fafc;
            min-width: 0;
            line-height: 1.35;
        }

        .poi-list-title-name {
            flex: 1 1 230px;
            min-width: 0;
            max-width: 100%;
            overflow: visible;
            text-overflow: unset;
            display: inline;
            -webkit-line-clamp: unset;
            -webkit-box-orient: unset;
            line-height: 1.35;
            overflow-wrap: anywhere;
        }

        .poi-list-desc {
            color: #94a3b8;
            font-size: 13px;
            margin-top: 6px;
            line-height: 1.5;
            display: block;
            overflow: visible;
            overflow-wrap: anywhere;
        }

        /* Badge trạng thái */
        .badge-soft {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            padding: 4px 8px;
            border-radius: 8px;
            background: rgba(34, 197, 94, 0.15);
            color: #34d399;
            font-size: 11px;
            font-weight: 800;
            white-space: nowrap;
            flex: 0 0 auto;
            max-width: none;
            position: relative;
            z-index: 2;
        }
        .badge-muted {
            background: rgba(255, 255, 255, 0.08);
            color: #94a3b8;
        }


        .featured-stat {
            border-color: rgba(250, 204, 21, .42) !important;
            background: linear-gradient(135deg, rgba(250,204,21,.16), rgba(251,146,60,.10)) !important;
        }

        .featured-filter {
            border-color: rgba(250,204,21,.45) !important;
            background: linear-gradient(135deg, rgba(250,204,21,.18), rgba(251,146,60,.12)) !important;
        }

        .badge-featured {
            background: linear-gradient(135deg, #facc15, #fb923c);
            color: #111827;
            box-shadow: 0 10px 24px rgba(250, 204, 21, 0.22);
        }

        .poi-list-item.featured {
            border-color: rgba(250, 204, 21, 0.55);
            background: linear-gradient(135deg, rgba(250, 204, 21, 0.12), rgba(251, 146, 60, 0.07)), rgba(255, 255, 255, 0.03);
        }

        .poi-list-item.featured::after {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: 18px;
            pointer-events: none;
            box-shadow: inset 0 0 0 1px rgba(250, 204, 21, 0.12), 0 18px 46px rgba(250, 204, 21, 0.10);
        }

        .featured-owner-line {
            display: flex;
            align-items: flex-start;
            gap: 6px;
            margin-top: 8px;
            color: #fde68a;
            font-size: 11.5px;
            font-weight: 900;
            line-height: 1.35;
            max-width: 100%;
            overflow-wrap: anywhere;
            white-space: normal;
        }

        .featured-owner-line i {
            flex: 0 0 auto;
            margin-top: 2px;
        }

        .poi-chip.featured {
            color: #111827;
            background: linear-gradient(135deg, #facc15, #fb923c);
            border-color: transparent;
            box-shadow: 0 10px 24px rgba(250, 204, 21, 0.20);
        }

        /* Panel Chi tiết */
        .detail-panel {
            flex: 0 0 auto;
            max-height: 42vh;
            overflow-y: auto;
            background: rgba(11, 17, 32, 0.95);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 0 0 24px 24px;
            box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.3);
            padding: 20px;
            z-index: 10;
        }

        .detail-panel.empty-detail {
            display: none !important;
        }

        .poi-detail-cover {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 14px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .poi-detail-cover img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            display: block;
        }

        .poi-detail-cover-badge {
            position: absolute;
            left: 10px;
            bottom: 10px;
            padding: 6px 10px;
            border-radius: 20px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #fff;
            font-size: 11px;
            font-weight: 800;
        }

        .detail-title {
            font-size: 22px;
            font-weight: 800;
            color: #f8fafc;
            margin-bottom: 8px;
            line-height: 1.2;
        }

        .detail-desc {
            color: #cbd5e1;
            font-size: 13.5px;
            line-height: 1.6;
            margin-bottom: 14px;
        }

        .poi-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.08);
            color: #cbd5e1;
            font-size: 11.5px;
            font-weight: 700;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .poi-chip.ok { color: #34d399; background: rgba(52, 211, 153, 0.1); border-color: rgba(52, 211, 153, 0.2); }
        .poi-chip.warn { color: #fbbf24; background: rgba(251, 191, 36, 0.1); border-color: rgba(251, 191, 36, 0.2); }

        .poi-rating-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin: 10px 0;
        }

        .rating-stars {
            color: #f59e0b;
            font-size: 14px;
            white-space: nowrap;
        }

        .poi-rating-text {
            color: #94a3b8;
            font-size: 12.5px;
            font-weight: 600;
        }

        .poi-list-rating-row {
            position: relative;
            z-index: 2;
        }

        .poi-audio-box {
            padding: 10px;
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
            margin-bottom: 14px;
        }
        .poi-audio-box audio { width: 100%; display: block; height: 36px; }

        .poi-qr-card {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 12px;
            align-items: center;
            padding: 12px;
            margin: 12px 0 14px;
            border-radius: 18px;
            background: rgba(56, 189, 248, .10);
            border: 1px solid rgba(56, 189, 248, .24);
        }

        .poi-qr-card img {
            width: 112px;
            height: 112px;
            border-radius: 14px;
            padding: 6px;
            background: #fff;
            box-shadow: 0 10px 24px rgba(0, 0, 0, .20);
        }

        .poi-qr-title {
            font-weight: 900;
            color: #e0f2fe;
            font-size: 13px;
            margin-bottom: 4px;
        }

        .poi-qr-note {
            color: #bae6fd;
            font-size: 12px;
            line-height: 1.45;
            margin-bottom: 8px;
        }


        .poi-qr-only-card {
            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
            padding: 18px;
            margin-top: 14px;
        }

        .poi-qr-only-card img {
            width: 190px;
            height: 190px;
        }

        .poi-qr-only-card .poi-qr-title {
            font-size: 16px;
            margin-top: 10px;
        }

        .poi-qr-only-card .poi-qr-note {
            max-width: 320px;
            margin: 8px auto 0;
        }

        @@media (max-width: 520px) {
            .poi-qr-card { grid-template-columns: 1fr; justify-items: center; text-align: center; }
        }

        .detail-actions {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }

        .map-btn {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            padding: 10px;
            border-radius: 12px;
            font-size: 12.5px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            background: rgba(255, 255, 255, 0.06);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #e2e8f0;
            transition: 0.2s;
        }
        .map-btn:hover { background: rgba(255, 255, 255, 0.1); color: #fff; }
        .map-btn.primary { background: linear-gradient(135deg, #34d399, #38bdf8); color: #020617; border: none; }
        .map-btn.bookmark { color: #f87171; }
        .map-btn.bookmark.active { background: #ef4444; color: #fff; border-color: transparent; }
        .map-btn.menu-order { background: linear-gradient(135deg, #fbbf24, #fb923c); color: #020617; border: none; }

        /* Review List */
        .poi-review-list {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            display: grid;
            gap: 10px;
        }
        .poi-review-item {
            padding: 12px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Nút ngôn ngữ thu gọn */
        .map-language-btn {
            min-height: 36px;
            padding: 0 12px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #fff;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12.5px;
            font-weight: 700;
            cursor: pointer;
        }

        .map-language-menu {
            min-width: 160px !important;
            background: rgba(15, 23, 42, 0.95) !important;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            border-radius: 16px !important;
            padding: 8px !important;
        }

        .map-language-option {
            width: 100%;
            padding: 8px 12px;
            border-radius: 10px;
            border: none;
            background: transparent;
            color: #e2e8f0;
            text-align: left;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }
        .map-language-option:hover { background: rgba(255, 255, 255, 0.1); }
        .map-language-option.active { background: rgba(56, 189, 248, 0.2); color: #38bdf8; }

        /* Header UI (Hero Banner) */
        .map-hero {
            position: relative;
            padding: 24px 30px;
            border-radius: 28px;
            background: linear-gradient(135deg, rgba(52, 211, 153, 0.15), rgba(56, 189, 248, 0.1)), rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .map-hero h1 { font-size: 36px; font-weight: 900; color: #fff; margin: 10px 0; letter-spacing: -0.5px; }
        .map-hero h1 span { background: linear-gradient(135deg, #34d399, #38bdf8); -webkit-background-clip: text; color: transparent; }
        .map-hero p { color: #94a3b8; font-size: 14.5px; max-width: 600px; margin: 0; line-height: 1.6; }

        .map-stat-grid { display: flex; gap: 14px; }
        .map-stat-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 18px;
            padding: 16px 20px;
            min-width: 140px;
        }
        .map-stat-card strong { font-size: 24px; color: #fff; font-weight: 900; display: block; }
        .map-stat-card span { font-size: 12px; color: #94a3b8; font-weight: 600; }

        /* Custom Marker CSS */
        .custom-map-icon { background: transparent; border: none; }
        .custom-marker {
            position: relative;
            display: flex; justify-content: center; align-items: center;
            width: 36px; height: 36px; border-radius: 50% 50% 50% 0;
            transform: rotate(-45deg); border: 2.5px solid #fff; color: #fff;
            font-size: 13px; box-shadow: 0 8px 16px rgba(0,0,0,0.3);
        }
        .custom-marker i { transform: rotate(45deg); }
        .custom-marker.discovered { background: #22c55e; }
        .custom-marker.undiscovered { background: #3b82f6; }
        .custom-marker.shop { background: linear-gradient(135deg, #06b6d4, #14b8a6); }
        .custom-marker.featured {
            width: 46px;
            height: 46px;
            background: linear-gradient(135deg, #facc15, #fb923c);
            color: #111827;
            border-color: #fff7ed;
            box-shadow: 0 0 0 7px rgba(250, 204, 21, 0.18), 0 18px 32px rgba(251, 146, 60, 0.38);
            animation: featuredPoiPulse 1.8s ease-in-out infinite;
        }
        .custom-marker.user { background: #f59e0b; }
        .custom-marker.route-selected {
            box-shadow: 0 0 0 5px rgba(14, 165, 233, .22), 0 14px 28px rgba(14, 165, 233, .36);
        }
        .route-marker-index {
            position: absolute;
            right: -10px;
            top: -10px;
            width: 22px;
            height: 22px;
            display: grid;
            place-items: center;
            border-radius: 999px;
            background: #0f172a;
            color: #fff;
            border: 2px solid #fff;
            font-size: 11px;
            font-weight: 950;
            transform: rotate(45deg);
        }

        @@keyframes featuredPoiPulse {
            0%, 100% { box-shadow: 0 0 0 6px rgba(250, 204, 21, 0.16), 0 18px 32px rgba(251, 146, 60, 0.34); }
            50% { box-shadow: 0 0 0 12px rgba(250, 204, 21, 0.06), 0 22px 42px rgba(251, 146, 60, 0.46); }
        }

        /* Alert Msg */
        .map-message { font-size: 12px; margin-top: 8px; min-height: 18px; }
        .map-message.ok { color: #34d399; }
        .map-message.err { color: #f87171; }

        .route-planner {
            display: grid;
            gap: 10px;
            margin-top: 12px;
            padding: 12px;
            border-radius: 18px;
            background: rgba(2, 6, 23, .42);
            border: 1px solid rgba(56, 189, 248, .22);
        }

        .route-planner[hidden] {
            display: none !important;
        }

        .route-planner-head {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: flex-start;
            color: #e0f2fe;
            font-weight: 950;
            font-size: 13px;
        }

        .route-planner-hint,
        .route-planner-summary {
            color: #94a3b8;
            font-size: 12px;
            line-height: 1.45;
        }

        .route-stop-list {
            display: grid;
            gap: 8px;
            max-height: 168px;
            overflow-y: auto;
            padding-right: 2px;
        }

        .route-stop {
            display: grid;
            grid-template-columns: 26px minmax(0, 1fr) 30px;
            gap: 8px;
            align-items: center;
            padding: 8px;
            border-radius: 12px;
            background: rgba(255, 255, 255, .05);
            border: 1px solid rgba(255, 255, 255, .08);
        }

        .route-stop-index {
            width: 26px;
            height: 26px;
            display: grid;
            place-items: center;
            border-radius: 999px;
            background: linear-gradient(135deg, #34d399, #38bdf8);
            color: #042f2e;
            font-size: 12px;
            font-weight: 950;
        }

        .route-stop-name {
            min-width: 0;
            color: #f8fafc;
            font-size: 12.5px;
            font-weight: 850;
            line-height: 1.35;
            overflow-wrap: anywhere;
        }

        .route-stop-remove {
            width: 30px;
            height: 30px;
            border: 0;
            border-radius: 10px;
            color: #fecaca;
            background: rgba(239, 68, 68, .15);
            cursor: pointer;
        }

        .route-planner-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .route-planner-actions .map-btn {
            min-height: 36px;
            padding: 8px 10px;
            border-radius: 12px;
            font-size: 12px;
        }

        .poi-list-item.route-selected {
            border-color: rgba(56, 189, 248, .55);
            background: rgba(56, 189, 248, .10);
        }

        .map-login-alert {
            background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 16px; padding: 14px 20px; color: #f8fafc; font-size: 14px; margin-bottom: 20px;
        }
        .map-login-alert a { color: #38bdf8; font-weight: 700; text-decoration: none; }

        @@media (max-width: 1100px) {
            .map-page { grid-template-columns: 1fr; height: auto; min-height: auto; }
            .map-main { height: 60vh; min-height: 500px; }
            .map-side { height: auto; }
            .poi-list { padding-right: 22px; }
            .badge-soft { max-width: none; padding-inline: 7px; }
            .detail-panel { max-height: none; }
            .map-hero { flex-direction: column; align-items: flex-start; gap: 20px; }
            .map-stat-grid { width: 100%; flex-wrap: wrap; }
        }

        /* ===== RESTORE REVIEW FORM / COMMENT INPUT ===== */
        .rating-form {
            margin-top: 16px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .rating-form textarea {
            width: 100%;
            min-height: 88px;
            margin-top: 10px;
            padding: 12px;
            border-radius: 14px;
            outline: none;
            resize: vertical;
            color: #f8fafc;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.10);
        }

        .rating-form textarea:focus {
            border-color: rgba(56, 189, 248, 0.55);
            box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.12);
        }

        .rating-form .star {
            cursor: pointer;
            transition: transform 0.14s ease;
        }

        .rating-form .star:hover {
            transform: translateY(-1px) scale(1.06);
        }

    </style>
}

<div class="map-hero">
    <div>
        <div class="poi-chip ok" style="margin-bottom: 8px;">
            <i class="fa-solid fa-map-location-dot"></i> Bản đồ POI
        </div>
        <h1>Tìm điểm tham quan <span>gần bạn.</span></h1>
        <p>Hiển thị các địa điểm đã được duyệt. Đăng nhập để check-in GPS, xem chi tiết, chọn ngôn ngữ và lưu tiến độ.</p>
    </div>

    <div class="map-stat-grid">
        <div class="map-stat-card">
            <strong>@Model.TotalPoiCount</strong>
            <span>POI trên bản đồ</span>
        </div>
        <div class="map-stat-card">
            <strong>@Model.FeaturedPoiCount</strong>
            <span>POI nổi bật</span>
        </div>
        <div class="map-stat-card">
            <strong>@Model.DiscoveredCount</strong>
            <span>Đã check-in</span>
        </div>
    </div>
</div>

@if (!Model.IsTouristSignedIn)
{
    <div class="map-login-alert">
        <i class="fa-solid fa-circle-info" style="color: #ef4444; margin-right: 6px;"></i>
        Bạn đang xem ở chế độ khách. Để check-in nhận điểm, vui lòng
        <a asp-area="DuKhach" asp-controller="Account" asp-action="Login" asp-route-returnUrl="/DuKhach/Map">đăng nhập du khách</a>.
    </div>
}
else if (!Model.HasPremiumActive)
{
    <div class="map-login-alert" id="audioQuotaBanner">
        <i class="fa-solid fa-headphones" style="color:#38bdf8;margin-right:6px;"></i>
        Gói miễn phí: còn <strong id="audioQuotaRemaining">@(Model.AudioPlaysRemainingToday ?? Model.AudioDailyLimit)</strong>/@Model.AudioDailyLimit lượt nghe hôm nay.
        <a asp-area="DuKhach" asp-controller="Payments" asp-action="Plans">Nâng cấp Premium</a> để nghe không giới hạn.
    </div>
}

<form id="antiForgeryForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="map-page">
    <div class="map-main">
        <div id="touristMap"></div>
    </div>

    <aside class="map-side">
        <div class="map-side-head">
            <div class="map-side-title-row">
                <div>
                    <div class="map-side-title">Khám phá bản đồ</div>
                    <div class="map-side-subtitle">Chọn địa điểm để xem chi tiết hoặc check-in</div>
                </div>

                <div class="dropdown map-language-dropdown compact" data-no-i18n="true">
                    <button class="map-language-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fa-solid fa-language"></i> <span data-map-language-current data-language-native="true">@selectedMapLanguageName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end map-language-menu">
                        @foreach (var language in Model.Languages)
                        {
                            var isCurrentLanguage = string.Equals(language.Code, Model.SelectedLanguageCode, StringComparison.OrdinalIgnoreCase);
                            var languageDisplayName = GetNativeLanguageDisplayName(language.Code, language.Name);
                            <li>
                                <button type="button" class="map-language-option @(isCurrentLanguage ? "active" : "")" data-lang="@language.Code" data-name="@languageDisplayName" data-language-native="true">
                                    <span data-language-native="true">@languageDisplayName</span>
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="map-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input id="poiSearch" type="search" placeholder="Tìm kiếm địa điểm..." />
            </div>

            <div class="map-toolbar-chips">
                <button class="chip-btn primary" type="button" id="btnLocate" title="Vị trí của tôi">
                    <i class="fa-solid fa-location-crosshairs"></i> Vị trí
                </button>
                <button class="chip-btn" type="button" id="btnNearby" title="Sắp xếp POI gần tôi">
                    <i class="fa-solid fa-arrow-down-short-wide"></i> Gần tôi
                </button>
                <button class="chip-btn" type="button" id="btnRoutePlanner" title="Chọn nhiều POI để tính lộ trình">
                    <i class="fa-solid fa-route"></i> Lộ trình POI
                </button>
                <button class="chip-btn" type="button" id="btnFit" title="Xem tất cả">
                    <i class="fa-solid fa-expand"></i> Tất cả
                </button>
                <button class="chip-btn" type="button" id="btnFilterBookmark" title="Chỉ hiện POI đã lưu">
                    <i class="fa-solid fa-heart"></i> Đã lưu
                </button>
                <button class="chip-btn" type="button" id="btnFilterShop" title="Chỉ hiện các gian hàng có menu">
                    <i class="fa-solid fa-store"></i> Gian hàng
                </button>
                <button class="chip-btn featured-filter" type="button" id="btnFilterFeatured" title="Chỉ hiện POI nổi bật">
                    <i class="fa-solid fa-crown" style="color: #f59e0b;"></i> Nổi bật
                </button>
                <button class="chip-btn" type="button" id="btnFilterRating" title="Chỉ hiện POI từ 4 sao">
                    <i class="fa-solid fa-star" style="color: #f59e0b;"></i> 4+ Sao
                </button>
                <button class="chip-btn" type="button" id="btnClearRoute" title="Tắt đường dẫn hiện tại" style="display:none;">
                    <i class="fa-solid fa-xmark"></i> Tắt dẫn đường
                </button>
                <button class="chip-btn" type="button" id="btnOpenGoogleMaps" title="Mở tuyến đường bằng Google Maps" style="display:none;">
                    <i class="fa-brands fa-google"></i> Google Maps
                </button>
            </div>

            <div id="mapMessage" class="map-message"></div>

            <div id="poiRoutePlanner" class="route-planner" hidden>
                <div class="route-planner-head">
                    <span><i class="fa-solid fa-route"></i> Lộ trình POI</span>
                    <span id="routeStopCount">0 điểm</span>
                </div>
                <div class="route-planner-hint">Bấm POI trên bản đồ hoặc danh sách để thêm/xóa điểm dừng theo thứ tự.</div>
                <div id="routeStopList" class="route-stop-list"></div>
                <div id="routeSummary" class="route-planner-summary">Chọn ít nhất 2 POI để tính khoảng cách.</div>
                <div class="route-planner-actions">
                    <button class="map-btn primary" type="button" id="btnDrawPoiRoute">
                        <i class="fa-solid fa-diamond-turn-right"></i> Vẽ tuyến
                    </button>
                    <button class="map-btn" type="button" id="btnClearPoiStops">
                        <i class="fa-solid fa-trash"></i> Xóa chọn
                    </button>
                </div>
            </div>
        </div>

        <div id="poiList" class="poi-list"></div>

        <div id="poiDetail" class="detail-panel empty-detail">
            <!-- Nội dung chi tiết sẽ được render qua JS -->
        </div>
    </aside>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>
    <script src="https://unpkg.com/leaflet.markercluster@1.4.1/dist/leaflet.markercluster.js"></script>

    <script>
        const pois = (@Html.Raw(poiJson)) || [];
        const isSignedIn = @Json.Serialize(Model.IsTouristSignedIn);
        const checkInUrl = '@Url.Action("CheckIn", "Map", new { area = "DuKhach" })';
        const toggleBookmarkUrl = '@Url.Action("ToggleBookmark", "Map", new { area = "DuKhach" })';
        const submitReviewUrl = '@Url.Action("SubmitReview", "Map", new { area = "DuKhach" })';
        const logAudioUrl = '@Url.Action("LogAudio", "Map", new { area = "DuKhach" })';
        const poiDetailUrlTemplate = '@Url.Action("Details", "Map", new { area = "DuKhach", id = "__POI_ID__" })';
        const poiQrImageUrlTemplate = '@Url.Action("PoiImage", "Qr", new { area = "DuKhach", id = "__POI_ID__" })';
        let selectedLanguageCode = @Html.Raw(JsonSerializer.Serialize(Model.SelectedLanguageCode));

        // Đặt tên cố định cho tab bản đồ. Các trang chi tiết POI sẽ mở/dẫn đường lại đúng tab này,
        // không tạo thêm tab map mới nếu tab bản đồ đang còn mở.
        try { window.name = 'versaDuKhachMapTab'; } catch (_) { }

        const mapMessage = document.getElementById('mapMessage');
        const poiList = document.getElementById('poiList');
        const poiSearch = document.getElementById('poiSearch');
        const poiDetail = document.getElementById('poiDetail');
        const btnClearRoute = document.getElementById('btnClearRoute');
        const btnOpenGoogleMaps = document.getElementById('btnOpenGoogleMaps');
        const btnRoutePlanner = document.getElementById('btnRoutePlanner');
        const poiRoutePlanner = document.getElementById('poiRoutePlanner');
        const routeStopList = document.getElementById('routeStopList');
        const routeStopCount = document.getElementById('routeStopCount');
        const routeSummary = document.getElementById('routeSummary');
        const btnDrawPoiRoute = document.getElementById('btnDrawPoiRoute');
        const btnClearPoiStops = document.getElementById('btnClearPoiStops');
        const mapLanguageOptions = document.querySelectorAll('.map-language-option');
        const mapLanguageCurrentLabels = document.querySelectorAll('[data-map-language-current]');
        const token = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]')?.value;

        let userLocation = null;
        let userMarker = null;
        let userCircle = null;
        let activePoiId = null;
        let routingControl = null;
        let simpleRouteLine = null;
        let markerClusterGroup = null;
        let userWatchId = null;
        let hasLiveLocation = false;
        let centerNextUserUpdate = false;
        let activeRoutePoi = null;
        let pendingRoutePoi = null;
        let lastRouteRefreshAt = 0;
        let activeRouteMode = null;
        let routePlannerMode = false;
        let routeStops = [];

        const markers = new Map();
        const circles = new Map();

        let showOnlyBookmarks = false;
        let showOnlyHighRating = false;
        let showOnlyFeatured = false;
        let showOnlyShops = false;
        let sortByDistance = false;

        const escapeHtml = value => String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');

        const buildPoiDetailUrl = poiId => {
            const raw = poiDetailUrlTemplate.replace('__POI_ID__', encodeURIComponent(poiId));
            const url = new URL(raw, window.location.origin);
            url.searchParams.set('lang', selectedLanguageCode);
            return url.toString();
        };

        const openPoiDetailPage = poi => {
            if (!poi) return;
            window.open(buildPoiDetailUrl(poi.id), 'versaPoiDetailTab');
        };

        const buildMapRouteUrl = poiId => {
            const url = new URL(window.location.pathname, window.location.origin);
            url.searchParams.set('lang', selectedLanguageCode);
            url.searchParams.set('routeTo', poiId);
            url.hash = `poi-${poiId}`;
            return url.toString();
        };

        const buildPoiQrImageUrl = poiId => {
            const raw = poiQrImageUrlTemplate.replace('__POI_ID__', encodeURIComponent(poiId));
            const url = new URL(raw, window.location.origin);
            url.searchParams.set('lang', 'auto');
            return url.toString();
        };

        const setMessage = (message, type = '') => {
            mapMessage.textContent = message || '';
            mapMessage.className = `map-message ${type}`;
        };

        const normalizeLanguageCode = value => String(value || 'vi').trim().toLowerCase();

        const getNarration = poi => {
            const languageCode = normalizeLanguageCode(selectedLanguageCode);
            const narrations = Array.isArray(poi.narrations) ? poi.narrations : [];

            return narrations.find(item => normalizeLanguageCode(item.languageCode) === languageCode)
                || narrations.find(item => normalizeLanguageCode(item.languageCode) === 'vi')
                || narrations.find(item => normalizeLanguageCode(item.languageCode) === 'en')
                || {
                    languageCode: poi.languageCode || languageCode,
                    languageName: poi.languageName || languageCode.toUpperCase(),
                    name: poi.name,
                    shortDescription: poi.shortDescription,
                    fullDescription: poi.fullDescription,
                    narrationText: poi.narrationText || poi.fullDescription || poi.shortDescription || poi.name,
                    audioUrl: poi.audioUrl,
                    videoUrl: poi.videoUrl
                };
        };

        const getPoiText = poi => {
            const narration = getNarration(poi);

            return {
                languageCode: normalizeLanguageCode(narration.languageCode || selectedLanguageCode),
                languageName: narration.languageName || selectedLanguageCode.toUpperCase(),
                name: narration.name || poi.name || `POI #${poi.id}`,
                shortDescription: narration.shortDescription || poi.shortDescription || '',
                fullDescription: narration.fullDescription || poi.fullDescription || '',
                narrationText: narration.narrationText || narration.fullDescription || narration.shortDescription || narration.name || '',
                audioUrl: narration.audioUrl || '',
                videoUrl: narration.videoUrl || ''
            };
        };

        const cultureMap = {
            vi: 'vi',
            en: 'en',
            fr: 'fr',
            zh: 'zh-CN',
            ja: 'ja',
            ko: 'ko',
            th: 'th-TH',
            de: 'de-DE',
            es: 'es-ES',
            it: 'it-IT',
            pt: 'pt-PT',
            ru: 'ru-RU'
        };

        const persistSelectedLanguage = () => {
            const expires = new Date();
            expires.setFullYear(expires.getFullYear() + 1);

            localStorage.setItem('versa-dukhach-lang', selectedLanguageCode);
            document.cookie = `versa.dukhach.lang=${encodeURIComponent(selectedLanguageCode)}; expires=${expires.toUTCString()}; path=/; samesite=lax`;

            const culture = cultureMap[selectedLanguageCode] || selectedLanguageCode;
            document.cookie = `.AspNetCore.Culture=c=${encodeURIComponent(culture)}|uic=${encodeURIComponent(culture)}; expires=${expires.toUTCString()}; path=/; samesite=lax`;
        };

        const syncTouristLinks = () => {
            document.querySelectorAll('a[href]').forEach(anchor => {
                const rawHref = anchor.getAttribute('href');
                if (!rawHref || rawHref.startsWith('#') || rawHref.startsWith('javascript:') || rawHref.startsWith('mailto:') || rawHref.startsWith('tel:')) return;

                try {
                    const url = new URL(rawHref, window.location.origin);
                    if (url.origin !== window.location.origin) return;

                    const isTouristLink = url.pathname === '/' || url.pathname.toLowerCase().startsWith('/dukhach');
                    if (!isTouristLink) return;

                    url.searchParams.set('lang', selectedLanguageCode);
                    anchor.setAttribute('href', `${url.pathname}${url.search}${url.hash}`);
                } catch (e) {
                    // Bỏ qua href không hợp lệ.
                }
            });
        };

        const updateUrlLanguage = () => {
            const url = new URL(window.location.href);
            url.searchParams.set('lang', selectedLanguageCode);
            history.replaceState(null, '', `${url.pathname}${url.search}${location.hash || ''}`);
            persistSelectedLanguage();
            syncTouristLinks();
        };

        const applyMapLanguage = (languageCode, languageName) => {
            const currentPageLanguage = normalizeLanguageCode(new URL(window.location.href).searchParams.get('lang') || window.VERSA_DUKHACH_LANG || selectedLanguageCode);
            selectedLanguageCode = normalizeLanguageCode(languageCode);
            const resolvedLanguageName = languageName || selectedLanguageCode.toUpperCase();
            const shouldReloadPage = currentPageLanguage !== selectedLanguageCode;

            mapLanguageCurrentLabels.forEach(label => {
                label.textContent = resolvedLanguageName;
            });

            mapLanguageOptions.forEach(option => {
                const isActive = normalizeLanguageCode(option.dataset.lang) === selectedLanguageCode;
                option.classList.toggle('active', isActive);
            });

            document.querySelectorAll('#dkLanguageCurrent').forEach(label => {
                label.textContent = resolvedLanguageName;
            });

            document.querySelectorAll('.dk-language-option').forEach(option => {
                const isActive = normalizeLanguageCode(option.dataset.lang) === selectedLanguageCode;
                option.classList.toggle('active', isActive);
            });

            window.VERSA_DUKHACH_LANG = selectedLanguageCode;
            window.VERSA_DUKHACH_LANG_NAME = resolvedLanguageName;

            updateUrlLanguage();

            window.dispatchEvent(new CustomEvent('versa-dukhach-language-changed', {
                detail: { lang: selectedLanguageCode, name: resolvedLanguageName, source: 'map' }
            }));

            setMessage(`Đã chuyển ngôn ngữ sang ${resolvedLanguageName}.`, 'ok');

            if (shouldReloadPage) {
                window.location.reload();
                return;
            }

            markers.forEach((marker, id) => {
                const poi = pois.find(item => Number(item.id) === Number(id));
                if (poi) marker.bindPopup(popupHtml(poi));
            });

            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);

            if (activePoiId) {
                const activePoi = pois.find(item => Number(item.id) === Number(activePoiId));
                if (activePoi) renderDetail(activePoi);
            }
        };

        const isValidLatLng = (lat, lng) => {
            const nLat = Number(lat);
            const nLng = Number(lng);
            return Number.isFinite(nLat) && Number.isFinite(nLng) && nLat >= -90 && nLat <= 90 && nLng >= -180 && nLng <= 180;
        };

        const distanceToPoi = poi => {
            if (!userLocation || !isValidLatLng(poi.latitude, poi.longitude)) return null;

            const toRadians = value => value * Math.PI / 180;
            const earthRadius = 6371000;
            const lat1 = toRadians(userLocation.latitude);
            const lat2 = toRadians(Number(poi.latitude));
            const deltaLat = toRadians(Number(poi.latitude) - userLocation.latitude);
            const deltaLng = toRadians(Number(poi.longitude) - userLocation.longitude);
            const a = Math.sin(deltaLat / 2) ** 2
                + Math.cos(lat1) * Math.cos(lat2) * Math.sin(deltaLng / 2) ** 2;

            return earthRadius * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        };

        const formatDistance = distance => {
            if (!Number.isFinite(distance)) return '';
            return distance >= 1000
                ? `${(distance / 1000).toFixed(distance >= 10000 ? 0 : 1)} km`
                : `${Math.round(distance)} m`;
        };

        const formatDuration = seconds => {
            if (!Number.isFinite(seconds)) return '';

            const totalMinutes = Math.max(1, Math.round(seconds / 60));
            const hours = Math.floor(totalMinutes / 60);
            const minutes = totalMinutes % 60;

            return hours > 0
                ? `${hours} giờ ${minutes} phút`
                : `${minutes} phút`;
        };

        const getRouteStopIndex = poiId =>
            routeStops.findIndex(item => Number(item.id) === Number(poiId));

        const isRouteStop = poiId => getRouteStopIndex(poiId) >= 0;

        const getPoiLatLng = poi => L.latLng(Number(poi.latitude), Number(poi.longitude));

        const getRouteWaypoints = () => routeStops
            .filter(poi => isValidLatLng(poi.latitude, poi.longitude))
            .map(getPoiLatLng);

        const getStraightRouteDistance = () => {
            const waypoints = getRouteWaypoints();
            let total = 0;

            for (let index = 1; index < waypoints.length; index++) {
                total += waypoints[index - 1].distanceTo(waypoints[index]);
            }

            return total;
        };

        const formatRouteSummary = (distance, seconds = null, isApproximate = false) => {
            const prefix = isApproximate ? 'Tạm tính đường thẳng' : 'Tuyến đường';
            const duration = Number.isFinite(seconds) ? `, khoảng ${formatDuration(seconds)}` : '';
            return `${prefix}: ${formatDistance(distance)}${duration}.`;
        };

        const removeRouteLayers = () => {
            if (routingControl) {
                map.removeControl(routingControl);
                routingControl = null;
            }

            if (simpleRouteLine) {
                map.removeLayer(simpleRouteLine);
                simpleRouteLine = null;
            }
        };

        const renderPoiRoutePlanner = (summaryOverride = null) => {
            if (!poiRoutePlanner) return;

            poiRoutePlanner.hidden = !routePlannerMode && routeStops.length === 0;
            btnRoutePlanner?.classList.toggle('primary', routePlannerMode);

            if (routeStopCount) {
                routeStopCount.textContent = `${routeStops.length} điểm`;
            }

            if (routeStopList) {
                routeStopList.innerHTML = routeStops.length
                    ? routeStops.map((poi, index) => {
                        const text = getPoiText(poi);
                        return `
                            <div class="route-stop">
                                <span class="route-stop-index">${index + 1}</span>
                                <span class="route-stop-name">${escapeHtml(text.name)}</span>
                                <button class="route-stop-remove" type="button" data-remove-route-stop="${poi.id}" title="Xóa khỏi lộ trình">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>`;
                    }).join('')
                    : '<div class="route-planner-summary">Chưa chọn POI nào.</div>';

                routeStopList.querySelectorAll('[data-remove-route-stop]').forEach(button => {
                    button.addEventListener('click', event => {
                        event.preventDefault();
                        event.stopPropagation();
                        removePoiRouteStopById(button.dataset.removeRouteStop);
                    });
                });
            }

            if (routeSummary) {
                if (summaryOverride) {
                    routeSummary.textContent = summaryOverride;
                } else if (routeStops.length >= 2) {
                    routeSummary.textContent = formatRouteSummary(getStraightRouteDistance(), null, true);
                } else {
                    routeSummary.textContent = 'Chọn ít nhất 2 POI để tính khoảng cách.';
                }
            }

            if (btnDrawPoiRoute) {
                btnDrawPoiRoute.disabled = routeStops.length < 2;
            }
        };

        const refreshRouteSelectionUi = (summaryOverride = null) => {
            renderPoiRoutePlanner(summaryOverride);

            markers.forEach((marker, id) => {
                const poi = pois.find(item => Number(item.id) === Number(id));
                if (!poi) return;
                marker.setIcon(createPoiIcon(poi));
                marker.bindPopup(popupHtml(poi));
            });

            renderList(filterPois());
        };

        const drawStraightPoiRoute = (message = null) => {
            const waypoints = getRouteWaypoints();
            if (waypoints.length < 2) return;

            removeRouteLayers();
            activeRoutePoi = null;
            pendingRoutePoi = null;
            activeRouteMode = 'poi';

            simpleRouteLine = L.polyline(waypoints, {
                color: '#f59e0b',
                weight: 5,
                opacity: .9,
                dashArray: '9, 8'
            }).addTo(map);

            map.fitBounds(L.latLngBounds(waypoints).pad(.22), { maxZoom: 16 });

            const summaryText = formatRouteSummary(getStraightRouteDistance(), null, true);
            renderPoiRoutePlanner(summaryText);
            updateRouteButtons();
            setMessage(message || `${summaryText} Không lấy được tuyến đường phố nên đang vẽ đường thẳng giữa các POI.`, 'ok');
        };

        const drawPoiRoute = () => {
            const waypoints = getRouteWaypoints();

            if (waypoints.length < 2) {
                clearRoute(true);
                renderPoiRoutePlanner();
                setMessage('Chọn ít nhất 2 POI để tính lộ trình.', 'err');
                return;
            }

            activeRoutePoi = null;
            pendingRoutePoi = null;
            activeRouteMode = 'poi';
            updateRouteButtons();
            removeRouteLayers();

            if (!L.Routing || typeof L.Routing.control !== 'function') {
                drawStraightPoiRoute();
                return;
            }

            setMessage(`Đang tính lộ trình qua ${waypoints.length} POI...`, 'ok');

            routingControl = L.Routing.control({
                waypoints,
                routeWhileDragging: false,
                addWaypoints: false,
                show: false,
                lineOptions: { styles: [{ color: '#f59e0b', opacity: .9, weight: 5 }] },
                createMarker: () => null
            }).addTo(map);

            routingControl.on('routesfound', event => {
                const summary = event.routes?.[0]?.summary;
                if (!summary) return drawStraightPoiRoute();

                const summaryText = formatRouteSummary(summary.totalDistance, summary.totalTime, false);
                renderPoiRoutePlanner(summaryText);
                map.fitBounds(L.latLngBounds(waypoints).pad(.22), { maxZoom: 16 });
                setMessage(`${summaryText} Thứ tự đi theo các POI bạn đã chọn.`, 'ok');
            });

            routingControl.on('routingerror', () => {
                drawStraightPoiRoute('Không thể lấy tuyến đường phố, đã tạm tính đường thẳng giữa các POI.');
            });
        };

        const addPoiRouteStop = poi => {
            if (!poi || !isValidLatLng(poi.latitude, poi.longitude) || isRouteStop(poi.id)) return false;

            routeStops.push(poi);
            return true;
        };

        const removePoiRouteStopById = poiId => {
            const index = getRouteStopIndex(poiId);
            if (index < 0) return;

            routeStops.splice(index, 1);

            if (activeRouteMode === 'poi') {
                if (routeStops.length >= 2) drawPoiRoute();
                else clearRoute(true);
            }

            refreshRouteSelectionUi();
        };

        const togglePoiRouteStop = poi => {
            routePlannerMode = true;

            if (isRouteStop(poi.id)) {
                removePoiRouteStopById(poi.id);
                setMessage(`Đã bỏ ${getPoiText(poi).name} khỏi lộ trình.`, 'ok');
                return;
            }

            addPoiRouteStop(poi);
            refreshRouteSelectionUi();

            if (routeStops.length >= 2) {
                drawPoiRoute();
            } else {
                clearRoute(true);
                setMessage('Đã chọn điểm đầu. Chọn thêm POI thứ 2 để tính khoảng cách.', 'ok');
            }
        };

        window.addPoiRouteStopById = poiId => {
            const poi = pois.find(item => Number(item.id) === Number(poiId));
            if (poi) togglePoiRouteStop(poi);
        };

        const clearPoiRouteStops = () => {
            routeStops = [];
            activeRouteMode = null;
            activeRoutePoi = null;
            pendingRoutePoi = null;
            removeRouteLayers();
            updateRouteButtons();
            refreshRouteSelectionUi();
            setMessage('Đã xóa lộ trình POI.', 'ok');
        };

        const osm = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { maxZoom: 19 });
        const satellite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { maxZoom: 19 });
        const topo = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', { maxZoom: 17 });

        const firstValidPoi = pois.find(poi => isValidLatLng(poi.latitude, poi.longitude));
        const mapCenter = firstValidPoi ? [Number(firstValidPoi.latitude), Number(firstValidPoi.longitude)] : [10.7769, 106.7009];

        const map = L.map('touristMap', { zoomControl: true, layers: [osm] }).setView(mapCenter, firstValidPoi ? 14 : 12);
        window.touristLeafletMap = map;

        const forceTouristMapResize = () => {
            requestAnimationFrame(() => map.invalidateSize(true));
            setTimeout(() => map.invalidateSize(true), 150);
            setTimeout(() => map.invalidateSize(true), 450);
        };

        map.whenReady(forceTouristMapResize);
        window.addEventListener('load', forceTouristMapResize);
        window.addEventListener('resize', forceTouristMapResize);

        L.control.layers({'Bản đồ tiêu chuẩn': osm, 'Vệ tinh': satellite, 'Địa hình': topo}).addTo(map);

        const createPoiIcon = poi => {
            const isShopPoi = poi.isShop || Number(poi.menuItemCount) > 0;
            const statusClass = poi.isFeatured ? 'featured' : (isShopPoi ? 'shop' : (poi.isDiscovered ? 'discovered' : 'undiscovered'));
            const iconClass = poi.isFeatured ? 'fa-crown' : (isShopPoi ? 'fa-store' : 'fa-map-pin');
            const iconSize = poi.isFeatured ? [46, 46] : [36, 36];
            const iconAnchor = poi.isFeatured ? [23, 46] : [18, 36];
            const routeIndex = getRouteStopIndex(poi.id);
            const routeClass = routeIndex >= 0 ? 'route-selected' : '';
            const routeBadge = routeIndex >= 0 ? `<span class="route-marker-index">${routeIndex + 1}</span>` : '';
            return L.divIcon({
                className: 'custom-map-icon',
                html: `<div class="custom-marker ${statusClass} ${routeClass}"><i class="fa-solid ${iconClass}"></i>${routeBadge}</div>`,
                iconSize,
                iconAnchor,
                popupAnchor: [0, -36]
            });
        };

        const popupHtml = poi => {
            const text = getPoiText(poi);
            const distance = distanceToPoi(poi);
            const distanceLine = Number.isFinite(distance)
                ? `<div style="font-size:12px;color:#0284c7;font-weight:800;margin-bottom:8px;"><i class="fa-solid fa-person-walking"></i> Cách bạn ${formatDistance(distance)}</div>`
                : '';
            const featuredLine = poi.isFeatured
                ? `<div style="display:inline-flex;align-items:center;gap:6px;margin-bottom:8px;padding:5px 8px;border-radius:999px;background:linear-gradient(135deg,#facc15,#fb923c);color:#111827;font-size:11px;font-weight:900;"><i class="fa-solid fa-crown"></i> POI nổi bật</div>`
                : '';
            const shopLine = (poi.isShop || Number(poi.menuItemCount) > 0)
                ? `<div style="display:inline-flex;align-items:center;gap:6px;margin-bottom:8px;margin-left:${poi.isFeatured ? '6px' : '0'};padding:5px 8px;border-radius:999px;background:#ecfeff;color:#0e7490;border:1px solid #a5f3fc;font-size:11px;font-weight:900;"><i class="fa-solid fa-store"></i> Gian hàng · ${Number(poi.menuItemCount) || 0} món</div>`
                : '';
            const routeStopIndex = getRouteStopIndex(poi.id);
            const routeStopText = routeStopIndex >= 0 ? `Bỏ khỏi lộ trình #${routeStopIndex + 1}` : 'Thêm vào lộ trình POI';
            const detailUrl = buildPoiDetailUrl(poi.id);
            const qrUrl = buildPoiQrImageUrl(poi.id);
            return `
                <div style="min-width:230px;max-width:260px;">
                     ${featuredLine}${shopLine}
                     <div style="font-weight:900;font-size:15px;margin-bottom:6px;color:#0f172a;">${escapeHtml(text.name)}</div>
                     <div style="font-size:12.5px;color:#475569;margin-bottom:10px;">${escapeHtml(text.shortDescription || 'Điểm tham quan')}</div>
                     ${distanceLine}
                    <button type="button" data-route-poi="${poi.id}" style="width:100%;border:0;border-radius:10px;padding:8px;font-weight:800;cursor:pointer;background:#38bdf8;color:#fff;margin-bottom:8px;">
                        <i class="fa-solid fa-route"></i> Dẫn đường trên bản đồ
                    </button>
                    <button type="button" data-route-stop-poi="${poi.id}" style="width:100%;border:0;border-radius:10px;padding:8px;font-weight:800;cursor:pointer;background:#f59e0b;color:#111827;margin-bottom:8px;">
                        <i class="fa-solid fa-map-pin"></i> ${escapeHtml(routeStopText)}
                    </button>
                    <a href="${escapeHtml(detailUrl)}" target="versaPoiDetailTab" style="display:flex;align-items:center;justify-content:center;gap:6px;width:100%;border-radius:10px;padding:8px;font-weight:800;text-decoration:none;background:#0f172a;color:#fff;margin-bottom:10px;box-sizing:border-box;">
                        <i class="fa-solid fa-up-right-from-square"></i> Mở trang chi tiết riêng
                    </a>
                    <div style="display:grid;grid-template-columns:78px 1fr;gap:8px;align-items:center;padding:8px;border-radius:12px;background:#f8fafc;border:1px solid #e2e8f0;">
                        <img src="${escapeHtml(qrUrl)}" alt="QR mở chi tiết POI" style="width:78px;height:78px;border-radius:8px;background:#fff;" />
                        <div style="font-size:11.5px;line-height:1.35;color:#475569;font-weight:700;">Quét để mở trang chi tiết web trên điện thoại. QR không cộng điểm.</div>
                    </div>
                </div>`;
        };

        const renderDetail = poi => {
            activePoiId = poi.id;
            const text = getPoiText(poi);
            const qrUrl = buildPoiQrImageUrl(poi.id);
            const routeStopIndex = getRouteStopIndex(poi.id);
            const routeStopText = routeStopIndex >= 0 ? `Bỏ khỏi lộ trình #${routeStopIndex + 1}` : 'Thêm vào lộ trình POI';

            poiDetail.classList.remove('empty-detail');

            poiDetail.innerHTML = `
                <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                    <div class="detail-title">${escapeHtml(text.name)}</div>
                    <button type="button" onclick="closeDetail()" style="background:transparent;border:none;color:#94a3b8;cursor:pointer;font-size:18px;">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="poi-qr-card poi-qr-only-card">
                    <img src="${escapeHtml(qrUrl)}" alt="QR mở chi tiết POI" />
                    <div>
                        <div class="poi-qr-title"><i class="fa-solid fa-qrcode"></i> Quét QR để xem chi tiết</div>
                        <div class="poi-qr-note">Dùng camera điện thoại quét mã này để mở trang chi tiết POI trên web. QR chỉ để xem chi tiết, không cộng điểm.</div>
                    </div>
                </div>

                <button class="map-btn primary" type="button" style="width:100%;" onclick="addPoiRouteStopById(${poi.id})">
                    <i class="fa-solid fa-route"></i> ${escapeHtml(routeStopText)}
                </button>`;
        };

        const renderReviewForm = (container, poiId) => {
            container.innerHTML = `
                <strong style="font-size:15px;display:block;margin-bottom:8px;">
                    <i class="fa-solid fa-pen-to-square"></i> Để lại đánh giá của bạn
                </strong>

                <div class="rating-stars" id="submit-rating-${poiId}" style="font-size:24px;margin-top:8px;">
                    ${[...Array(5)].map((_, i) => `<i class="star fa-regular fa-star" data-value="${i + 1}"></i>`).join('')}
                </div>

                <textarea id="comment-${poiId}" placeholder="Chia sẻ cảm nhận của bạn..."></textarea>

                <button class="map-btn primary" style="width:100%;margin-top:10px;" onclick="submitReview(${poiId})">
                    <i class="fa-solid fa-paper-plane"></i>
                    Gửi đánh giá
                </button>
            `;

            const stars = container.querySelectorAll('.star');

            const paintStars = rating => {
                stars.forEach(star => {
                    const value = Number(star.dataset.value);
                    star.classList.toggle('fa-solid', value <= rating);
                    star.classList.toggle('fa-regular', value > rating);
                });
            };

            stars.forEach(star => {
                star.addEventListener('mouseover', function () {
                    paintStars(Number(this.dataset.value));
                });

                star.addEventListener('click', function () {
                    container.dataset.rating = this.dataset.value;
                    paintStars(Number(this.dataset.value));
                });
            });

            container.addEventListener('mouseleave', function () {
                paintStars(Number(container.dataset.rating || 0));
            });
        };

        window.submitReview = async (poiId) => {
            const container = document.getElementById(`review-form-${poiId}`);
            const rating = Number(container?.dataset.rating || 0);
            const comment = document.getElementById(`comment-${poiId}`)?.value || '';

            if (!rating) {
                alert('Vui lòng chọn số sao để đánh giá.');
                return;
            }

            try {
                const res = await fetch(submitReviewUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        poiId,
                        rating,
                        comment
                    })
                });

                const data = await res.json();

                setMessage(data.message || (data.success ? 'Đã gửi đánh giá.' : 'Không thể gửi đánh giá.'), data.success ? 'ok' : 'err');

                if (data.success) {
                    const poi = pois.find(item => Number(item.id) === Number(poiId));

                    if (poi) {
                        poi.averageRating = data.averageRating ?? poi.averageRating;
                        poi.ratingCount = data.ratingCount ?? poi.ratingCount;

                        poi.reviews = poi.reviews || [];
                        poi.reviews.unshift({
                            touristName: 'Bạn',
                            rating,
                            comment,
                            createdAt: new Date().toISOString()
                        });

                        renderList(filterPois());
                        renderDetail(poi);
                    }
                }
            } catch (e) {
                setMessage('Lỗi khi gửi đánh giá.', 'err');
            }
        };

        window.closeDetail = () => {
            activePoiId = null;
            poiDetail.classList.add('empty-detail');
            document.querySelectorAll('.poi-list-item').forEach(item => item.classList.remove('active'));
            history.replaceState(null, '', `${location.pathname}${location.search}`);
        };

        const requestAudioAccess = async (poiId, isTts = false) => {
            if (!isSignedIn) {
                window.location.href = `/Areas/DuKhach/Account/Login?returnUrl=${encodeURIComponent('/Areas/DuKhach/Map#poi-' + poiId)}`;
                return false;
            }

            try {
                const res = await fetch(logAudioUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ poiId, languageCode: selectedLanguageCode, isTts })
                });

                const data = await res.json();
                setMessage(data.message || (res.ok ? 'Được phép nghe.' : 'Không thể phát thuyết minh.'), res.ok ? 'ok' : 'err');

                if (Number.isFinite(Number(data.remainingToday))) {
                    const remainingLabel = document.getElementById('audioQuotaRemaining');
                    if (remainingLabel) remainingLabel.textContent = String(data.remainingToday);
                }

                return res.ok && data.success;
            } catch (e) {
                setMessage('Không kiểm tra được lượt nghe. Vui lòng thử lại.', 'err');
                return false;
            }
        };

        window.authorizeAudioPlay = async (event, poiId) => {
            const audio = event.currentTarget;
            if (!audio || audio.dataset.quotaGranted === 'true' || audio.dataset.quotaPending === 'true') return;

            audio.dataset.quotaPending = 'true';
            audio.pause();
            const allowed = await requestAudioAccess(poiId, false);
            delete audio.dataset.quotaPending;

            if (!allowed) {
                audio.currentTime = 0;
                return;
            }

            audio.dataset.quotaGranted = 'true';
            await audio.play();
        };

        window.resetAudioAuthorization = event => {
            const audio = event.currentTarget;
            if (audio) delete audio.dataset.quotaGranted;
        };

        window.speakPoi = async (poiId) => {
            const poi = pois.find(item => Number(item.id) === Number(poiId));
            if (!poi) return;
            const text = getPoiText(poi);
            if (!text.narrationText) return setMessage('Chưa có mô tả.', 'err');
            if (!await requestAudioAccess(poiId, true)) return;
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text.narrationText);
            utterance.lang = text.languageCode === 'en' ? 'en-US' : 'vi-VN';
            utterance.rate = 0.95;
            window.speechSynthesis.speak(utterance);
            setMessage(`Đang đọc thuyết minh...`, 'ok');
        };

        const focusPoi = (poi, options = {}) => {
            if (!poi) return;
            activePoiId = poi.id;

            if (routePlannerMode && options.routePlannerToggle !== false) {
                togglePoiRouteStop(poi);
            }

            const marker = markers.get(poi.id);
            if (markerClusterGroup && marker) {
                markerClusterGroup.zoomToShowLayer(marker, () => {
                    marker.openPopup();
                    map.setView(marker.getLatLng(), Math.max(map.getZoom(), 16));
                });
            }

            document.querySelectorAll('.poi-list-item').forEach(item => {
                const isActive = Number(item.dataset.poiId) === Number(poi.id);
                item.classList.toggle('active', isActive);
            });

            history.replaceState(null, '', `${location.pathname}${location.search}#poi-${poi.id}`);
            setTimeout(() => map.invalidateSize(true), 120);
        };

        window.handleBookmark = async (id, btn) => {
            if (!isSignedIn) {
                window.location.href = `/DuKhach/Account/Login?returnUrl=${encodeURIComponent('/DuKhach/Map#poi-' + id)}`;
                return;
            }
            try {
                const res = await fetch(toggleBookmarkUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify(id)
                });
                const data = await res.json();
                if (data.success) {
                    const poi = pois.find(p => Number(p.id) === Number(id));
                    if (poi) poi.isBookmarked = data.isBookmarked;
                    btn.classList.toggle('active', data.isBookmarked);
                    btn.querySelector('.bm-text').textContent = data.isBookmarked ? 'Đã lưu' : 'Lưu lại';
                    if (showOnlyBookmarks) {
                        const filtered = filterPois();
                        renderList(filtered);
                        updateMapMarkers(filtered);
                    }
                }
            } catch (error) { alert('Lỗi khi lưu địa điểm.'); }
        };

        const filterPois = () => {
            const keyword = (poiSearch.value || '').trim().toLowerCase();
            let filtered = pois;
            if (keyword) {
                filtered = filtered.filter(poi => {
                    const text = getPoiText(poi);
                    return `${text.name} ${text.shortDescription}`.toLowerCase().includes(keyword);
                });
            }
            if (showOnlyBookmarks) filtered = filtered.filter(poi => poi.isBookmarked);
            if (showOnlyShops) filtered = filtered.filter(poi => poi.isShop || Number(poi.menuItemCount) > 0);
            if (showOnlyHighRating) filtered = filtered.filter(poi => poi.averageRating >= 4);
            if (showOnlyFeatured) filtered = filtered.filter(poi => poi.isFeatured);
            if (sortByDistance && userLocation) {
                filtered = [...filtered].sort((left, right) =>
                    (distanceToPoi(left) ?? Number.MAX_VALUE) - (distanceToPoi(right) ?? Number.MAX_VALUE));
            }
            return filtered;
        };

        const updateMapMarkers = (filteredItems) => {
            if (!markerClusterGroup) return;
            markerClusterGroup.clearLayers();
            filteredItems.forEach(poi => {
                const marker = markers.get(poi.id);
                if (marker) markerClusterGroup.addLayer(marker);
            });
            circles.forEach((circle, id) => {
                if (filteredItems.find(p => Number(p.id) === Number(id))) {
                    if (!map.hasLayer(circle)) map.addLayer(circle);
                } else {
                    if (map.hasLayer(circle)) map.removeLayer(circle);
                }
            });
        };

        const renderList = items => {
            poiList.innerHTML = '';
            if (!items.length) {
                poiList.innerHTML = `<div style="text-align:center;color:#64748b;padding:20px;">Không tìm thấy kết quả.</div>`;
                return;
            }

            for (const poi of items) {
                const text = getPoiText(poi);
                const distance = distanceToPoi(poi);
                const distanceLine = Number.isFinite(distance)
                    ? `<span class="badge-soft"><i class="fa-solid fa-person-walking"></i> ${formatDistance(distance)}</span>`
                    : '';
                const routeStopIndex = getRouteStopIndex(poi.id);
                const routeSelected = routeStopIndex >= 0;
                const routeStopText = routeSelected ? `Bỏ khỏi lộ trình #${routeStopIndex + 1}` : 'Thêm lộ trình';
                const routeBadge = routeSelected
                    ? `<span class="badge-soft" style="border-color:rgba(56,189,248,.45);color:#7dd3fc;"><i class="fa-solid fa-route"></i> #${routeStopIndex + 1}</span>`
                    : '';
                const item = document.createElement('div');
                item.className = `poi-list-item ${poi.isFeatured ? 'featured' : ''} ${activePoiId === poi.id ? 'active' : ''} ${routeSelected ? 'route-selected' : ''}`;
                item.dataset.poiId = poi.id;

                const statusBadge = poi.isFeatured
                    ? '<span class="badge-soft badge-featured"><i class="fa-solid fa-crown"></i> Nổi bật</span>'
                    : poi.isDiscovered
                        ? '<span class="badge-soft"><i class="fa-solid fa-check"></i> Done</span>'
                        : `<span class="badge-soft badge-muted">${escapeHtml(poi.radius)}m</span>`;
                const shopBadge = (poi.isShop || Number(poi.menuItemCount) > 0)
                    ? `<span class="badge-soft" style="border-color:rgba(45,212,191,.45);color:#67e8f9;"><i class="fa-solid fa-store"></i> Gian hàng · ${Number(poi.menuItemCount) || 0} món</span>`
                    : '';

                item.innerHTML = `
                    <div class="poi-list-title"><span class="poi-list-title-name">${escapeHtml(text.name)}</span> ${statusBadge}${routeBadge}</div>
                    <div class="poi-list-desc">${escapeHtml(text.shortDescription || 'Bấm để xem chi tiết')}</div>
                    ${distanceLine || shopBadge ? `<div style="margin-top:7px;display:flex;gap:6px;flex-wrap:wrap;">${distanceLine}${shopBadge}</div>` : ''}
                    ${poi.isFeatured ? `<div class="featured-owner-line"><i class="fa-solid fa-bolt"></i> Được ưu tiên hiển thị${poi.ownerBusinessName ? ' · ' + escapeHtml(poi.ownerBusinessName) : ''}</div>` : ''}
                    <div class="poi-list-rating-row" style="display:flex; align-items:center; gap: 6px; margin-top: 8px; flex-wrap: wrap;">
                        <div class="rating-stars" style="font-size: 12px;">
                            ${[...Array(5)].map((_, i) => `<i class="fa-${i < Math.round(poi.averageRating) ? 'solid' : 'regular'} fa-star"></i>`).join('')}
                        </div>
                        <span style="font-size: 11.5px; color: #94a3b8; font-weight: 700;">
                            ${poi.averageRating > 0 ? poi.averageRating.toFixed(1) : 'Mới'}
                        </span>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;">
                        <button type="button" data-list-route-poi="${poi.id}" style="border:0;border-radius:10px;padding:8px;font-weight:900;cursor:pointer;background:linear-gradient(135deg,#34d399,#38bdf8);color:#052e24;">
                            <i class="fa-solid fa-route"></i> Chỉ đường
                        </button>
                        <a href="${escapeHtml(buildPoiDetailUrl(poi.id))}" target="versaPoiDetailTab" data-list-detail-poi="${poi.id}" style="display:flex;align-items:center;justify-content:center;gap:6px;border-radius:10px;padding:8px;font-weight:900;text-decoration:none;background:rgba(15,23,42,.95);color:#fff;border:1px solid rgba(255,255,255,.12);">
                            <i class="fa-solid fa-up-right-from-square"></i> Chi tiết
                        </a>
                        <button type="button" data-list-route-stop-poi="${poi.id}" style="grid-column:1 / -1;border:0;border-radius:10px;padding:8px;font-weight:900;cursor:pointer;background:#f59e0b;color:#111827;">
                            <i class="fa-solid fa-map-pin"></i> ${escapeHtml(routeStopText)}
                        </button>
                    </div>`;

                item.addEventListener('click', () => focusPoi(poi));

                item.querySelector('[data-list-route-poi]')?.addEventListener('click', event => {
                    event.preventDefault();
                    event.stopPropagation();
                    focusPoi(poi, { routePlannerToggle: false });
                    window.showRouteToPoi(poi.latitude, poi.longitude, poi.id);
                });

                item.querySelector('[data-list-detail-poi]')?.addEventListener('click', event => {
                    event.stopPropagation();
                });

                item.querySelector('[data-list-route-stop-poi]')?.addEventListener('click', event => {
                    event.preventDefault();
                    event.stopPropagation();
                    togglePoiRouteStop(poi);
                });

                poiList.appendChild(item);
            }
        };

        markerClusterGroup = L.markerClusterGroup({ showCoverageOnHover: false, maxClusterRadius: 42, spiderfyOnMaxZoom: true });

        document.getElementById('btnFilterBookmark')?.addEventListener('click', function () {
            showOnlyBookmarks = !showOnlyBookmarks;
            this.classList.toggle('active', showOnlyBookmarks);
            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);
        });

        document.getElementById('btnFilterRating')?.addEventListener('click', function () {
            showOnlyHighRating = !showOnlyHighRating;
            this.classList.toggle('primary', showOnlyHighRating);
            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);
        });

        document.getElementById('btnFilterFeatured')?.addEventListener('click', function () {
            showOnlyFeatured = !showOnlyFeatured;
            this.classList.toggle('primary', showOnlyFeatured);
            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);
        });

        document.getElementById('btnFilterShop')?.addEventListener('click', function () {
            showOnlyShops = !showOnlyShops;
            this.classList.toggle('primary', showOnlyShops);
            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);
            if (showOnlyShops) setMessage(`Đang hiển thị ${filtered.length} gian hàng có menu.`, 'ok');
            else setMessage('');
        });

        document.getElementById('btnNearby')?.addEventListener('click', function () {
            sortByDistance = !sortByDistance;
            this.classList.toggle('primary', sortByDistance);

            if (sortByDistance && !userLocation) {
                setMessage('Đang lấy vị trí để tìm POI gần bạn...');
                document.getElementById('btnLocate')?.click();
                return;
            }

            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);
        });

        btnRoutePlanner?.addEventListener('click', () => {
            routePlannerMode = !routePlannerMode;
            renderPoiRoutePlanner();
            btnRoutePlanner.classList.toggle('primary', routePlannerMode);
            setMessage(
                routePlannerMode
                    ? 'Đã bật chọn lộ trình POI. Bấm các POI theo thứ tự muốn đi.'
                    : 'Đã tắt chế độ chọn lộ trình POI.',
                'ok');
        });

        btnDrawPoiRoute?.addEventListener('click', () => {
            drawPoiRoute();
        });

        btnClearPoiStops?.addEventListener('click', () => {
            clearPoiRouteStops();
        });

        mapLanguageOptions.forEach(option => {
            option.addEventListener('click', function () {
                applyMapLanguage(this.dataset.lang || 'vi', this.dataset.name || this.textContent.trim());
            });
        });

        for (const poi of pois) {
            if (!isValidLatLng(poi.latitude, poi.longitude)) continue;
            const marker = L.marker([Number(poi.latitude), Number(poi.longitude)], { icon: createPoiIcon(poi) }).bindPopup(popupHtml(poi));
            const circle = L.circle([Number(poi.latitude), Number(poi.longitude)], { radius: Number(poi.radius) || 50, color: poi.isFeatured ? '#f59e0b' : (poi.isDiscovered ? '#22c55e' : '#3b82f6'), weight: 1, fillOpacity: 0.08 }).addTo(map);
            markers.set(poi.id, marker);
            circles.set(poi.id, circle);
            markerClusterGroup.addLayer(marker);
            marker.on('click', () => focusPoi(poi));
        }

        map.addLayer(markerClusterGroup);

        document.addEventListener('click', event => {
            const routeStopButton = event.target.closest('[data-route-stop-poi]');
            if (routeStopButton) {
                event.preventDefault();
                event.stopPropagation();
                const poi = pois.find(item => Number(item.id) === Number(routeStopButton.dataset.routeStopPoi));
                if (poi) togglePoiRouteStop(poi);
                return;
            }

            const routeButton = event.target.closest('[data-route-poi]');
            if (!routeButton) return;
            event.preventDefault();
            event.stopPropagation();
            const poi = pois.find(item => Number(item.id) === Number(routeButton.dataset.routePoi));
            if (poi) window.showRouteToPoi(poi.latitude, poi.longitude, poi.id);
        });

        const fitAllPois = () => {
            if (!markerClusterGroup || markers.size === 0) return map.setView([10.7769, 106.7009], 12);
            const bounds = markerClusterGroup.getBounds();
            if (bounds && bounds.isValid()) map.fitBounds(bounds.pad(0.18), { maxZoom: 16 });
        };

        renderList(pois);
        forceTouristMapResize();
        if (markers.size > 0) setTimeout(fitAllPois, 200);

        document.getElementById('btnFit')?.addEventListener('click', () => { fitAllPois(); setTimeout(() => map.invalidateSize(), 100); });
        poiSearch.addEventListener('input', () => { const filtered = filterPois(); renderList(filtered); updateMapMarkers(filtered); });

        const updateUserLocationOnMap = (position, options = {}) => {
            const shouldCenter = Boolean(options.center);
            userLocation = {
                latitude: position.coords.latitude,
                longitude: position.coords.longitude,
                accuracyMeters: position.coords.accuracy
            };

            const latLng = [userLocation.latitude, userLocation.longitude];
            const radius = Math.min(userLocation.accuracyMeters || 30, 120);

            if (userMarker) {
                userMarker.setLatLng(latLng);
                if (userCircle) {
                    userCircle.setLatLng(latLng);
                    userCircle.setRadius(radius);
                }
            } else {
                userMarker = L.marker(latLng, {
                    icon: L.divIcon({
                        className: 'custom-map-icon',
                        html: `<div class="custom-marker user"><i class="fa-solid fa-user"></i></div>`,
                        iconSize: [36, 36],
                        iconAnchor: [18, 36]
                    })
                }).addTo(map).bindPopup('Vị trí trực tiếp của bạn');

                userCircle = L.circle(latLng, {
                    radius: radius,
                    color: '#f59e0b',
                    weight: 1,
                    fillOpacity: 0.1
                }).addTo(map);
            }

            if (shouldCenter) map.setView(latLng, 16);

            markers.forEach((marker, id) => {
                const poi = pois.find(item => Number(item.id) === Number(id));
                if (poi) marker.bindPopup(popupHtml(poi));
            });

            const filtered = filterPois();
            renderList(filtered);
            updateMapMarkers(filtered);

            if (activeRoutePoi) refreshRouteToPoi(activeRoutePoi, false);
        };

        const startLiveLocation = (centerOnFirstUpdate = true) => {
            if (!navigator.geolocation) {
                setMessage('Trình duyệt không hỗ trợ vị trí.', 'err');
                return false;
            }

            centerNextUserUpdate = centerOnFirstUpdate;
            document.getElementById('btnLocate')?.classList.add('primary');

            if (userWatchId !== null) {
                if (centerOnFirstUpdate && userLocation) {
                    map.setView([userLocation.latitude, userLocation.longitude], 16);
                }
                setMessage('Đang theo dõi vị trí trực tiếp của bạn trên bản đồ.', 'ok');
                return true;
            }

            setMessage('Đang bật vị trí trực tiếp...');

            userWatchId = navigator.geolocation.watchPosition(
                position => {
                    const shouldCenter = centerNextUserUpdate || !hasLiveLocation;
                    centerNextUserUpdate = false;
                    updateUserLocationOnMap(position, { center: shouldCenter });

                    if (!hasLiveLocation) {
                        hasLiveLocation = true;
                        const radius = Math.min(position.coords.accuracy || 30, 120);
                        setMessage(`Đã bật vị trí trực tiếp. Độ chính xác khoảng ${Math.round(radius)}m.`, 'ok');
                    }

                    if (pendingRoutePoi) {
                        const poi = pendingRoutePoi;
                        pendingRoutePoi = null;
                        refreshRouteToPoi(poi, true);
                    }
                },
                () => {
                    setMessage('Vui lòng bật GPS và cấp quyền vị trí cho trình duyệt.', 'err');
                    document.getElementById('btnLocate')?.classList.remove('primary');
                },
                { enableHighAccuracy: true, timeout: 15000, maximumAge: 2000 }
            );

            return true;
        };

        const updateRouteButtons = () => {
            const show = Boolean(activeRoutePoi) || activeRouteMode === 'poi';
            if (btnClearRoute) btnClearRoute.style.display = show ? '' : 'none';
            if (btnOpenGoogleMaps) btnOpenGoogleMaps.style.display = show ? '' : 'none';
        };

        const buildGoogleMapsRouteUrl = (poi = null) => {
            const url = new URL('https://www.google.com/maps/dir/');
            const toCoord = item => `${Number(item.latitude)},${Number(item.longitude)}`;
            url.searchParams.set('api', '1');

            if (activeRouteMode === 'poi' && routeStops.length >= 2) {
                const middleStops = routeStops.slice(1, -1);
                url.searchParams.set('origin', toCoord(routeStops[0]));
                url.searchParams.set('destination', toCoord(routeStops[routeStops.length - 1]));

                if (middleStops.length > 0) {
                    url.searchParams.set('waypoints', middleStops.map(toCoord).join('|'));
                }

                return url.toString();
            }

            if (!poi) return '#';

            const dest = `${Number(poi.latitude)},${Number(poi.longitude)}`;
            if (userLocation) {
                url.searchParams.set('origin', `${userLocation.latitude},${userLocation.longitude}`);
                url.searchParams.set('destination', dest);
            } else {
                url.searchParams.set('destination', dest);
            }
            return url.toString();
        };

        const clearRoute = (silent = false) => {
            const clearedMode = activeRouteMode;
            removeRouteLayers();
            activeRoutePoi = null;
            pendingRoutePoi = null;
            activeRouteMode = null;
            updateRouteButtons();
            if (clearedMode === 'poi') renderPoiRoutePlanner();
            if (!silent) setMessage('Đã tắt dẫn đường trên bản đồ.', 'ok');
        };

        const refreshRouteToPoi = (poi, force = true) => {
            if (!poi || !isValidLatLng(poi.latitude, poi.longitude)) return;
            activeRoutePoi = poi;
            activeRouteMode = 'single';
            updateRouteButtons();

            if (!userLocation) {
                pendingRoutePoi = poi;
                setMessage('Đang lấy vị trí của bạn để vẽ đường đi...', 'ok');
                startLiveLocation(true);
                return;
            }

            const now = Date.now();
            if (!force && now - lastRouteRefreshAt < 8000) return;
            lastRouteRefreshAt = now;

            const start = L.latLng(userLocation.latitude, userLocation.longitude);
            const end = L.latLng(Number(poi.latitude), Number(poi.longitude));

            if (routingControl && typeof routingControl.setWaypoints === 'function' && !force) {
                routingControl.setWaypoints([start, end]);
                return;
            }

            removeRouteLayers();

            if (!L.Routing || typeof L.Routing.control !== 'function') {
                simpleRouteLine = L.polyline([start, end], {
                    color: '#3b82f6',
                    weight: 5,
                    opacity: 0.9,
                    dashArray: '10, 8'
                }).addTo(map);
                map.fitBounds(L.latLngBounds([start, end]).pad(0.25), { maxZoom: 16 });
                const straightDistance = start.distanceTo(end);
                setMessage(`Đã vẽ đường thẳng tới ${getPoiText(poi).name}: khoảng ${formatDistance(straightDistance)}. Nếu cần tuyến đường theo đường phố, bấm Google Maps.`, 'ok');
                return;
            }

            setMessage('Đang vẽ đường đi trên bản đồ...', 'ok');
            routingControl = L.Routing.control({
                waypoints: [start, end],
                routeWhileDragging: false,
                addWaypoints: false,
                show: false,
                lineOptions: { styles: [{ color: '#3b82f6', opacity: 0.9, weight: 5, dashArray: '10, 8' }] },
                createMarker: () => null
            }).addTo(map);

            routingControl.on('routesfound', e => {
                const sum = e.routes[0].summary;
                const dist = sum.totalDistance > 1000 ? (sum.totalDistance / 1000).toFixed(2) + ' km' : Math.round(sum.totalDistance) + ' m';
                const min = Math.round(sum.totalTime / 60);
                setMessage(`Đường đi tới ${getPoiText(poi).name}: ${dist}, khoảng ${min > 60 ? Math.floor(min / 60) + ' giờ ' + (min % 60) : min} phút.`, 'ok');
            });

            routingControl.on('routingerror', () => {
                setMessage('Không thể tìm tuyến đường. Bạn có thể mở bằng Google Maps từ trang chi tiết.', 'err');
            });
        };

        window.showRouteToPoi = (destLat, destLng, poiId = null) => {
            const poi = poiId
                ? pois.find(item => Number(item.id) === Number(poiId))
                : { id: 0, latitude: Number(destLat), longitude: Number(destLng), name: 'địa điểm đã chọn' };

            if (!poi) return setMessage('Không tìm thấy địa điểm để dẫn đường.', 'err');
            focusPoi(poi, { routePlannerToggle: false });
            refreshRouteToPoi(poi, true);
        };

        const routeToPoiByIdFromAnotherTab = poiId => {
            const id = Number(poiId);
            if (!Number.isFinite(id) || id <= 0) return false;

            const poi = pois.find(item => Number(item.id) === id);
            if (!poi) {
                setMessage('Không tìm thấy POI để dẫn đường.', 'err');
                return false;
            }

            try {
                history.replaceState(null, '', buildMapRouteUrl(poi.id));
            } catch (_) { }

            focusPoi(poi, { routePlannerToggle: false });
            window.showRouteToPoi(poi.latitude, poi.longitude, poi.id);
            setMessage(`Đã nhận yêu cầu dẫn đường tới ${getPoiText(poi).name}.`, 'ok');
            return true;
        };

        const handleExternalRouteRequest = payload => {
            try {
                const data = typeof payload === 'string' ? JSON.parse(payload) : payload;
                if (!data || data.type !== 'VERSA_ROUTE_TO_POI') return;
                routeToPoiByIdFromAnotherTab(data.poiId);
            } catch (_) { }
        };

        window.addEventListener('message', event => {
            if (event.origin !== window.location.origin) return;
            handleExternalRouteRequest(event.data);
        });

        window.addEventListener('storage', event => {
            if (event.key !== 'versaDuKhachRouteRequest' || !event.newValue) return;
            handleExternalRouteRequest(event.newValue);
        });

        try {
            if ('BroadcastChannel' in window) {
                const routeChannel = new BroadcastChannel('versa-dukhach-map');
                routeChannel.onmessage = event => handleExternalRouteRequest(event.data);
            }
        } catch (_) { }

        document.getElementById('btnLocate')?.addEventListener('click', () => {
            startLiveLocation(true);
        });

        btnClearRoute?.addEventListener('click', () => {
            clearRoute(false);
        });

        btnOpenGoogleMaps?.addEventListener('click', () => {
            if (activeRouteMode === 'poi' && routeStops.length >= 2) {
                window.open(buildGoogleMapsRouteUrl(), '_blank', 'noopener');
                return;
            }

            if (!activeRoutePoi) return;
            window.open(buildGoogleMapsRouteUrl(activeRoutePoi), '_blank', 'noopener');
        });

        window.checkInPoi = async poiId => {
            if (!isSignedIn) return window.location.href = `/DuKhach/Account/Login?returnUrl=${encodeURIComponent('/DuKhach/Map#poi-' + poiId)}`;
            if (!navigator.geolocation) return setMessage('Không hỗ trợ GPS.', 'err');
            setMessage('Đang xác thực tọa độ...');
            navigator.geolocation.getCurrentPosition(
                async position => {
                    try {
                        const response = await fetch(checkInUrl, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                            body: JSON.stringify({
                                poiId: poiId, languageCode: selectedLanguageCode,
                                latitude: position.coords.latitude, longitude: position.coords.longitude, accuracyMeters: position.coords.accuracy
                            })
                        });
                        const data = await response.json();
                        if (!response.ok || !data.success) throw new Error(data.message || 'Check-in thất bại.');
                        setMessage(data.message, 'ok');
                        if (data.isNewDiscovery) {
                            const poi = pois.find(p => Number(p.id) === Number(poiId));
                            if (poi) { poi.isDiscovered = true; markers.get(poiId)?.setIcon(createPoiIcon(poi)); circles.get(poiId)?.setStyle({ color: '#22c55e' }); }
                            renderList(filterPois());
                        }
                    } catch (error) { setMessage(error.message, 'err'); }
                },
                error => setMessage('Vui lòng bật GPS.', 'err'),
                { enableHighAccuracy: true, timeout: 10000, maximumAge: 5000 }
            );
        };

        setTimeout(() => {
            const params = new URLSearchParams(location.search);
            const routeToId = Number(params.get('routeTo'));
            const hashMatch = location.hash.match(/^#poi-(\d+)$/);
            const hashPoiId = hashMatch ? Number(hashMatch[1]) : 0;
            const initialPoiId = Number.isFinite(routeToId) && routeToId > 0 ? routeToId : hashPoiId;

            if (initialPoiId) {
                const poi = pois.find(item => Number(item.id) === Number(initialPoiId));
                if (poi) {
                    focusPoi(poi, { routePlannerToggle: false });
                    if (Number.isFinite(routeToId) && routeToId > 0) {
                        window.showRouteToPoi(poi.latitude, poi.longitude, poi.id);
                    }
                }
            }
        }, 300);
    </script>
}
