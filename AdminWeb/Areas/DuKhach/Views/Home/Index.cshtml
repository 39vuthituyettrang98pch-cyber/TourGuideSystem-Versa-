@using Microsoft.AspNetCore.Authentication
@using System.Security.Claims
@model AdminWeb.Areas.DuKhach.Models.DuKhachDashboardViewModel

@{
    ViewData["Title"] = "Trang chủ du khách";

    var featuredPois = Model.FeaturedPois?.ToList() ?? new();
    var recentDiscoveries = Model.RecentDiscoveries?.ToList() ?? new();

    var touristAuth = await Context.AuthenticateAsync("TouristScheme");
    var touristPrincipal = touristAuth.Succeeded ? touristAuth.Principal : null;
    var isTourist = touristPrincipal?.Identity?.IsAuthenticated == true
        && touristPrincipal.IsInRole("Tourist")
        && string.Equals(touristPrincipal.FindFirstValue("AccountType"), "Tourist", StringComparison.OrdinalIgnoreCase);
    var hasPois = featuredPois.Count > 0;
    var hasRecentDiscoveries = recentDiscoveries.Count > 0;

    var selectedLanguageCode = (ViewBag.SelectedLanguageCode as string
        ?? Context.Request.Query["lang"].FirstOrDefault()
        ?? Context.Request.Cookies["versa.dukhach.lang"]
        ?? "vi").ToLowerInvariant();
}

<style>
    .tourist-hero {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 34px;
        min-height: 520px;
        padding: 54px;
        background:
            linear-gradient(115deg, rgba(52, 211, 153, 0.18), rgba(56, 189, 248, 0.12)),
            linear-gradient(135deg, rgba(15, 29, 52, 0.96), rgba(7, 18, 34, 0.82)),
            url("https://images.unsplash.com/photo-1528127269322-539801943592?auto=format&fit=crop&w=1600&q=80");
        background-size: cover;
        background-position: center;
        box-shadow: var(--shadow);
    }

    html[data-theme="light"] .tourist-hero {
        background:
            linear-gradient(115deg, rgba(255, 255, 255, 0.92), rgba(232, 248, 255, 0.74)),
            url("https://images.unsplash.com/photo-1528127269322-539801943592?auto=format&fit=crop&w=1600&q=80");
        background-size: cover;
        background-position: center;
    }

    .tourist-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at 82% 24%, rgba(56, 189, 248, 0.34), transparent 28%),
            radial-gradient(circle at 14% 86%, rgba(52, 211, 153, 0.30), transparent 28%);
        pointer-events: none;
    }

    .tourist-hero::after {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
        background-size: 36px 36px;
        opacity: .55;
    }

    .tourist-hero-grid {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
        gap: 36px;
        align-items: center;
    }

    .tourist-eyebrow {
        width: fit-content;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 22px;
        padding: 9px 15px;
        border: 1px solid rgba(52, 211, 153, 0.32);
        border-radius: 999px;
        color: var(--accent);
        background: rgba(52, 211, 153, 0.12);
        font-weight: 900;
        font-size: 13px;
        box-shadow: 0 12px 34px rgba(52, 211, 153, 0.12);
    }

    .tourist-hero h1 {
        max-width: 920px;
        margin: 0;
        font-size: clamp(40px, 5.2vw, 74px);
        line-height: 1.08;
        letter-spacing: -0.035em;
        font-weight: 950;
        word-spacing: 0.02em;
        text-wrap: balance;
        overflow: visible;
        text-shadow: 0 10px 34px rgba(0, 0, 0, 0.26);
    }

    .tourist-hero h1 .gradient-text {
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .tourist-hero p {
        max-width: 720px;
        margin: 24px 0 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.85;
    }

    .tourist-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
    }

    .tourist-actions .dk-btn {
        min-height: 44px;
    }

    .tourist-preview {
        border: 1px solid var(--border);
        border-radius: 32px;
        padding: 22px;
        background: rgba(6, 17, 31, 0.62);
        backdrop-filter: blur(20px);
        box-shadow: 0 26px 80px rgba(0, 0, 0, 0.28);
    }

    html[data-theme="light"] .tourist-preview {
        background: rgba(255,255,255,0.76);
    }

    .tourist-phone {
        border-radius: 28px;
        border: 1px solid var(--border);
        overflow: hidden;
        background: linear-gradient(180deg, var(--surface), rgba(15, 29, 52, 0.54));
    }

    .tourist-phone-map {
        height: 250px;
        position: relative;
        background:
            linear-gradient(90deg, rgba(255,255,255,0.07) 1px, transparent 1px),
            linear-gradient(rgba(255,255,255,0.07) 1px, transparent 1px),
            radial-gradient(circle at 30% 38%, rgba(52, 211, 153, 0.28), transparent 18%),
            radial-gradient(circle at 72% 64%, rgba(56, 189, 248, 0.30), transparent 20%),
            linear-gradient(135deg, #0b1f36, #11284a);
        background-size: 44px 44px, 44px 44px, auto, auto, auto;
    }

    html[data-theme="light"] .tourist-phone-map {
        background:
            linear-gradient(90deg, rgba(15,23,42,0.07) 1px, transparent 1px),
            linear-gradient(rgba(15,23,42,0.07) 1px, transparent 1px),
            radial-gradient(circle at 30% 38%, rgba(52, 211, 153, 0.22), transparent 18%),
            radial-gradient(circle at 72% 64%, rgba(56, 189, 248, 0.24), transparent 20%),
            linear-gradient(135deg, #eaf7ff, #d9f3ee);
        background-size: 44px 44px, 44px 44px, auto, auto, auto;
    }

    .demo-pin {
        position: absolute;
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 16px 16px 16px 4px;
        transform: rotate(-45deg);
        color: #03131d;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow: 0 14px 34px rgba(52, 211, 153, 0.38);
    }

    .demo-pin i {
        transform: rotate(45deg);
    }

    .pin-a {
        left: 18%;
        top: 26%;
    }

    .pin-b {
        right: 22%;
        top: 54%;
    }

    .pin-c {
        left: 48%;
        bottom: 18%;
    }

    .tourist-phone-body {
        padding: 20px;
    }

    .tourist-phone-body h3 {
        margin: 0 0 8px;
        font-weight: 950;
        line-height: 1.18;
        letter-spacing: -0.02em;
    }

    .tourist-phone-body p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
        font-size: 14px;
    }

    .tourist-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-top: 22px;
    }

    .tourist-stat {
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 24px;
        background: var(--card);
        box-shadow: 0 18px 50px rgba(0,0,0,0.12);
        min-width: 0;
    }

    .tourist-stat strong {
        display: block;
        font-size: 38px;
        line-height: 1.08;
        letter-spacing: -0.025em;
        margin-bottom: 10px;
        word-break: break-word;
    }

    .tourist-stat span {
        display: block;
        color: var(--muted);
        font-weight: 800;
        font-size: 13px;
        line-height: 1.45;
    }

    .tourist-section {
        margin-top: 48px;
    }

    .tourist-section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 18px;
        margin-bottom: 18px;
    }

    .tourist-kicker {
        color: var(--accent);
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.12em;
    }

    .tourist-title {
        margin: 6px 0 0;
        font-size: clamp(28px, 3.6vw, 44px);
        line-height: 1.12;
        letter-spacing: -0.025em;
        font-weight: 950;
        text-wrap: balance;
    }

    .tourist-desc {
        max-width: 540px;
        color: var(--muted);
        line-height: 1.7;
        margin: 0;
    }

    .feature-grid,
    .poi-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .feature-card {
        border: 1px solid var(--border);
        border-radius: 28px;
        padding: 28px;
        background: var(--card);
        min-height: 230px;
        position: relative;
        overflow: hidden;
        transition: 0.2s ease;
    }

    .feature-card:hover,
    .poi-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
    }

    .feature-card::after {
        content: "";
        position: absolute;
        right: -30px;
        top: -30px;
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: rgba(56, 189, 248, 0.12);
    }

    .feature-icon {
        width: 56px;
        height: 56px;
        border-radius: 20px;
        display: grid;
        place-items: center;
        color: #03131d;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        margin-bottom: 22px;
        font-size: 22px;
        position: relative;
        z-index: 1;
    }

    .feature-card h3 {
        margin: 0 0 12px;
        font-size: 20px;
        line-height: 1.18;
        letter-spacing: -0.015em;
        font-weight: 950;
        position: relative;
        z-index: 1;
    }

    .feature-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
        position: relative;
        z-index: 1;
    }

    .poi-card {
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 28px;
        background: var(--card);
        transition: 0.2s ease;
        position: relative;
    }

    .poi-card.featured {
        border-color: rgba(250, 204, 21, 0.55);
        box-shadow: 0 0 0 1px rgba(250, 204, 21, 0.10), 0 18px 48px rgba(250, 204, 21, 0.12);
    }

    .poi-featured-badge {
        position: absolute;
        top: 14px;
        right: 14px;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 11px;
        border-radius: 999px;
        background: linear-gradient(135deg, #facc15, #fb923c);
        color: #111827;
        font-size: 12px;
        font-weight: 950;
        box-shadow: 0 14px 34px rgba(251, 146, 60, 0.28);
    }

    .poi-owner-featured {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: #f59e0b;
        font-size: 12px;
        font-weight: 900;
        margin-bottom: 10px;
    }

    .poi-cover {
        height: 190px;
        background:
            linear-gradient(135deg, rgba(52, 211, 153, 0.28), rgba(56, 189, 248, 0.22)),
            url("https://images.unsplash.com/photo-1583417319070-4a69db38a482?auto=format&fit=crop&w=900&q=80");
        background-size: cover;
        background-position: center;
    }

    .poi-body {
        padding: 20px;
    }

    .poi-body h3 {
        margin: 0 0 8px;
        font-size: 19px;
        line-height: 1.2;
        letter-spacing: -0.015em;
        font-weight: 950;
    }

    .poi-body p {
        margin: 0 0 16px;
        color: var(--muted);
        line-height: 1.6;
        min-height: 52px;
    }

    .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 11px;
        border-radius: 999px;
        border: 1px solid var(--border);
        color: var(--muted);
        background: rgba(148, 163, 184, 0.08);
        font-size: 12px;
        font-weight: 900;
        transition: 0.18s ease;
    }

    .pill:hover {
        color: var(--text);
        background: rgba(148, 163, 184, 0.14);
        transform: translateY(-1px);
    }

    .empty-showcase {
        border: 1px solid var(--border);
        border-radius: 34px;
        padding: 30px;
        background:
            linear-gradient(135deg, rgba(52,211,153,0.12), rgba(56,189,248,0.08)),
            var(--card);
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, 1fr);
        gap: 24px;
        align-items: center;
    }

    .empty-content h3 {
        margin: 0 0 14px;
        font-size: 34px;
        line-height: 1.14;
        letter-spacing: -0.02em;
        font-weight: 950;
        text-wrap: balance;
    }

    .empty-content p {
        color: var(--muted);
        line-height: 1.8;
        margin: 0 0 20px;
    }

    .empty-visual {
        min-height: 300px;
        border-radius: 28px;
        border: 1px solid var(--border);
        background:
            radial-gradient(circle at 28% 28%, rgba(52, 211, 153, 0.34), transparent 18%),
            radial-gradient(circle at 74% 62%, rgba(56, 189, 248, 0.34), transparent 20%),
            linear-gradient(135deg, rgba(15, 29, 52, 0.92), rgba(6, 17, 31, 0.76));
        display: grid;
        place-items: center;
        position: relative;
        overflow: hidden;
    }

    html[data-theme="light"] .empty-visual {
        background:
            radial-gradient(circle at 28% 28%, rgba(52, 211, 153, 0.26), transparent 18%),
            radial-gradient(circle at 74% 62%, rgba(56, 189, 248, 0.25), transparent 20%),
            linear-gradient(135deg, #effaff, #e8fff5);
    }

    .empty-visual i {
        font-size: 94px;
        color: var(--accent);
        filter: drop-shadow(0 20px 35px rgba(52, 211, 153, 0.32));
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .step {
        border: 1px solid var(--border);
        border-radius: 26px;
        background: var(--card);
        padding: 22px;
    }

    .step-number {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 15px;
        color: #03131d;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        font-weight: 950;
        margin-bottom: 16px;
    }

    .step h3 {
        margin: 0 0 8px;
        font-size: 18px;
        line-height: 1.2;
        letter-spacing: -0.015em;
        font-weight: 950;
    }

    .step p {
        margin: 0;
        color: var(--muted);
        line-height: 1.6;
        font-size: 14px;
    }

    .recent-card {
        border: 1px solid var(--border);
        border-radius: 28px;
        background: var(--card);
        overflow: hidden;
    }

    .recent-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 130px 90px 150px;
        gap: 12px;
        padding: 16px 18px;
        border-bottom: 1px solid var(--border);
        align-items: center;
    }

    .recent-row:last-child {
        border-bottom: 0;
    }

    .recent-row small {
        color: var(--muted);
        font-weight: 800;
    }

    .cta-box {
        border: 1px solid var(--border);
        border-radius: 34px;
        padding: 38px;
        background:
            radial-gradient(circle at 80% 20%, rgba(52, 211, 153, 0.22), transparent 28%),
            linear-gradient(135deg, rgba(56, 189, 248, 0.13), rgba(167, 139, 250, 0.10)),
            var(--card);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 26px;
    }

    .cta-box h2 {
        margin: 0 0 10px;
        font-size: clamp(28px, 3.6vw, 42px);
        line-height: 1.12;
        letter-spacing: -0.025em;
        font-weight: 950;
        text-wrap: balance;
    }

    .cta-box p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
    }

    .cta-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    @@media (max-width: 1050px) {
        .tourist-hero {
            padding: 34px;
        }

        .tourist-hero-grid,
        .empty-showcase {
            grid-template-columns: 1fr;
        }

        .tourist-stats,
        .steps {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .feature-grid,
        .poi-grid {
            grid-template-columns: 1fr;
        }

        .cta-box {
            flex-direction: column;
            align-items: flex-start;
        }

        .recent-row {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .tourist-hero {
            padding: 26px;
            min-height: auto;
        }

        .tourist-hero h1 {
            font-size: clamp(38px, 13vw, 56px);
            line-height: 1.1;
            letter-spacing: -0.025em;
        }

        .tourist-hero p {
            font-size: 16px;
            line-height: 1.7;
        }

        .tourist-stats,
        .steps {
            grid-template-columns: 1fr;
        }

        .tourist-section-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .empty-content h3 {
            font-size: 28px;
        }

        .cta-box {
            padding: 28px;
        }
    }
</style>

<section class="tourist-hero">
    <div class="tourist-hero-grid">
        <div>
            <div class="tourist-eyebrow">
                <i class="fa-solid fa-sparkles"></i>
                <span data-i18n="homeEyebrow">Web cho du khách</span>
            </div>

            <h1>
                <span data-i18n="homeHeroTitlePrefix">Khám phá thành phố bằng</span>
                <span class="gradient-text" data-i18n="homeHeroTitleHighlight">bản đồ thông minh.</span>
            </h1>

            <p data-i18n="homeHeroDesc">
                Du khách có thể đăng ký, đăng nhập, xem bản đồ POI, check-in bằng vị trí
                và dùng cùng một tài khoản trên app mobile.
            </p>

            <div class="tourist-actions">
                <a class="dk-btn dk-btn-primary"
                   asp-area="DuKhach"
                   asp-controller="Map"
                   asp-action="Index"
                   asp-route-lang="@selectedLanguageCode">
                    <i class="fa-solid fa-map-location-dot"></i>
                    <span data-i18n="homeOpenMap">Mở bản đồ</span>
                </a>

                <a class="dk-btn dk-btn-ghost"
                   style="background: rgba(148, 163, 184, 0.12); border-color: transparent;"
                   asp-area="DuKhach"
                   asp-controller="Tour"
                   asp-action="Index"
                   asp-route-lang="@selectedLanguageCode">
                    <i class="fa-solid fa-route"></i>
                    <span data-i18n="homeTourList">Danh sách Tour</span>
                </a>

                <a class="dk-btn dk-btn-ghost"
                   style="background: rgba(245, 158, 11, 0.12); color: #d97706; border-color: transparent;"
                   asp-area="DuKhach"
                   asp-controller="Leaderboard"
                   asp-action="Index"
                   asp-route-lang="@selectedLanguageCode">
                    <i class="fa-solid fa-trophy"></i>
                    <span data-i18n="homeRanking">Bảng xếp hạng</span>
                </a>

                @if (!isTourist)
                {
                    <a class="dk-btn dk-btn-ghost"
                       asp-area="DuKhach"
                       asp-controller="Account"
                       asp-action="Register"
                       asp-route-lang="@selectedLanguageCode">
                        <i class="fa-solid fa-user-plus"></i>
                        <span data-i18n="homeCreateAccount">Tạo tài khoản du khách</span>
                    </a>

                    <a class="dk-btn dk-btn-ghost"
                       asp-area="DuKhach"
                       asp-controller="Account"
                       asp-action="Login"
                       asp-route-lang="@selectedLanguageCode">
                        <i class="fa-solid fa-right-to-bracket"></i>
                        <span data-i18n="navLogin">Đăng nhập</span>
                    </a>
                }
                else
                {
                    <a class="dk-btn dk-btn-ghost"
                       asp-area="DuKhach"
                       asp-controller="Account"
                       asp-action="Profile"
                       asp-route-lang="@selectedLanguageCode">
                        <i class="fa-solid fa-id-card"></i>
                        <span data-i18n="homeMyProfile">Hồ sơ của tôi</span>
                    </a>
                }
            </div>
        </div>

        <div class="tourist-preview">
            <div class="tourist-phone">
                <div class="tourist-phone-map">
                    <span class="demo-pin pin-a">
                        <i class="fa-solid fa-landmark"></i>
                    </span>

                    <span class="demo-pin pin-b">
                        <i class="fa-solid fa-camera"></i>
                    </span>

                    <span class="demo-pin pin-c">
                        <i class="fa-solid fa-utensils"></i>
                    </span>
                </div>

                <div class="tourist-phone-body">
                    <h3 data-i18n="homePhoneTitle">Bản đồ POI gần bạn</h3>
                    <p data-i18n="homePhoneDesc">
                        Xem vị trí, bán kính geofence, mở chỉ đường và check-in khi ở gần điểm tham quan.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="tourist-stats">
    <div class="tourist-stat">
        <strong>@Model.ApprovedPoiCount</strong>
        <span data-i18n="homeApprovedPoi">POI đã duyệt</span>
    </div>

    <div class="tourist-stat">
        <strong>@Model.TourCount</strong>
        <span data-i18n="homeOpenTours">Tour đang mở</span>
    </div>

    <div class="tourist-stat">
        <strong>@Model.DiscoveredPoiCount</strong>
        <span data-i18n="homeDiscoveredPoi">POI bạn đã khám phá</span>
    </div>

    <div class="tourist-stat">
        <strong>@Model.TotalPoints</strong>
        <span>
            <span data-i18n="homePoints">Điểm</span> · @Model.RankName
        </span>
    </div>
</div>

<section class="tourist-section">
    <div class="tourist-section-head">
        <div>
            <div class="tourist-kicker" data-i18n="homeFeatureKicker">Tính năng nổi bật</div>
            <h2 class="tourist-title" data-i18n="homeFeatureTitle">Một tài khoản, nhiều trải nghiệm.</h2>
        </div>

        <p class="tourist-desc" data-i18n="homeFeatureDesc">
            Giao diện du khách được tách riêng khỏi admin, nhưng vẫn dùng chung dữ liệu tài khoản
            với app mobile.
        </p>
    </div>

    <div class="feature-grid">
        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-solid fa-map"></i>
            </div>

            <h3 data-i18n="homeFeatureMapTitle">Bản đồ tham quan</h3>
            <p data-i18n="homeFeatureMapDesc">Xem các điểm tham quan đã duyệt, vị trí, bán kính kích hoạt và mở chỉ đường nhanh.</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-solid fa-location-crosshairs"></i>
            </div>

            <h3 data-i18n="homeFeatureCheckinTitle">Check-in vị trí</h3>
            <p data-i18n="homeFeatureCheckinDesc">Du khách có thể dùng GPS để khám phá POI nằm trong vùng geofence.</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-solid fa-mobile-screen-button"></i>
            </div>

            <h3 data-i18n="homeFeatureMobileTitle">Dùng chung với app</h3>
            <p data-i18n="homeFeatureMobileDesc">Tài khoản đăng ký trên web được lưu vào bảng du khách, app có thể đăng nhập cùng tài khoản.</p>
        </div>
    </div>
</section>

<section class="tourist-section">
    <div class="tourist-section-head">
        <div>
            <div class="tourist-kicker" data-i18n="homePlaceKicker">Địa điểm</div>
            <h2 class="tourist-title" data-i18n="homePlaceTitle">Điểm tham quan nổi bật.</h2>
        </div>

        <a asp-area="DuKhach"
           asp-controller="Map"
           asp-action="Index"
           asp-route-lang="@selectedLanguageCode"
           class="dk-btn dk-btn-ghost">
            <i class="fa-solid fa-map-location-dot"></i>
            <span data-i18n="homeViewOnMap">Xem trên bản đồ</span>
        </a>
    </div>

    @if (hasPois)
    {
        <div class="poi-grid">
            @foreach (var poi in featuredPois)
            {
                <article class="poi-card @(poi.IsFeatured ? "featured" : "")">
                    @if (poi.IsFeatured)
                    {
                        <div class="poi-featured-badge"><i class="fa-solid fa-crown"></i> Nổi bật</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(poi.CoverImageUrl))
                    {
                        <div class="poi-cover"
                             style="background-image:linear-gradient(135deg, rgba(52, 211, 153, 0.18), rgba(56, 189, 248, 0.16)), url('@poi.CoverImageUrl');">
                        </div>
                    }
                    else
                    {
                        <div class="poi-cover"></div>
                    }

                    <div class="poi-body">
                        @if (poi.IsFeatured)
                        {
                            <div class="poi-owner-featured"><i class="fa-solid fa-bolt"></i> Ưu tiên hiển thị@(string.IsNullOrWhiteSpace(poi.OwnerBusinessName) ? "" : " · " + poi.OwnerBusinessName)</div>
                        }
                        <h3>@poi.Name</h3>
                        <p>@poi.ShortDescription</p>

                        <div style="display:flex;gap:8px;flex-wrap:wrap;">
                            <a class="pill"
                               asp-area="DuKhach"
                               asp-controller="Map"
                               asp-action="Index"
                               asp-route-lang="@selectedLanguageCode"
                               asp-fragment="poi-@poi.Id">
                                <i class="fa-solid fa-location-crosshairs"></i>
                                <span data-i18n="homeViewOnMap">Xem trên bản đồ</span>
                            </a>

                            <a class="pill"
                               href="https://www.google.com/maps/dir/?api=1&destination=@poi.Latitude,@poi.Longitude"
                               target="_blank"
                               rel="noopener">
                                <i class="fa-solid fa-route"></i>
                                <span data-i18n="homeDirection">Chỉ đường</span>
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty-showcase">
            <div class="empty-content">
                <div class="tourist-kicker" data-i18n="homeNoDataKicker">Chưa có dữ liệu hiển thị</div>

                <h3 data-i18n="homeNoPoiTitle">Hãy duyệt POI để trang du khách sống động hơn.</h3>

                <p>
                    <span data-i18n="homeNoPoiDescPrefix">Hiện chưa có POI trạng thái</span>
                    <strong>Approved</strong>,
                    <span data-i18n="homeNoPoiDescSuffix">nên trang chủ chưa có địa điểm thật để hiển thị. Giao diện vẫn có đầy đủ khối giới thiệu, tính năng, hướng dẫn và nút mở bản đồ.</span>
                </p>

                <div class="tourist-actions">
                    @if (User.IsInRole("Admin") || User.IsInRole("Editor"))
                    {
                        <a asp-area=""
                           asp-controller="Poi"
                           asp-action="Index"
                           class="dk-btn dk-btn-primary">
                            <i class="fa-solid fa-screwdriver-wrench"></i>
                            <span data-i18n="homeManagePoi">Vào quản lý POI</span>
                        </a>
                    }

                    <a asp-area="DuKhach"
                       asp-controller="Map"
                       asp-action="Index"
                       asp-route-lang="@selectedLanguageCode"
                       class="dk-btn dk-btn-ghost">
                        <i class="fa-solid fa-map"></i>
                        <span data-i18n="homeViewMap">Xem bản đồ</span>
                    </a>
                </div>
            </div>

            <div class="empty-visual">
                <i class="fa-solid fa-map-location-dot"></i>
            </div>
        </div>
    }
</section>

@if (isTourist)
{
    <section class="tourist-section">
        <div class="tourist-section-head">
            <div>
                <div class="tourist-kicker" data-i18n="homeHistoryKicker">Lịch sử</div>
                <h2 class="tourist-title" data-i18n="homeHistoryTitle">Khám phá gần đây.</h2>
            </div>
        </div>

        @if (!hasRecentDiscoveries)
        {
            <div class="empty-showcase">
                <div class="empty-content">
                    <h3 data-i18n="homeNoCheckinTitle">Bạn chưa check-in POI nào.</h3>

                    <p data-i18n="homeNoCheckinDesc">
                        Mở bản đồ và thử check-in khi bạn ở gần điểm tham quan để nhận điểm.
                    </p>

                    <a asp-area="DuKhach"
                       asp-controller="Map"
                       asp-action="Index"
                       asp-route-lang="@selectedLanguageCode"
                       class="dk-btn dk-btn-primary">
                        <i class="fa-solid fa-map-location-dot"></i>
                        <span data-i18n="homeOpenMap">Mở bản đồ</span>
                    </a>
                </div>

                <div class="empty-visual">
                    <i class="fa-solid fa-location-crosshairs"></i>
                </div>
            </div>
        }
        else
        {
            <div class="recent-card">
                @foreach (var item in recentDiscoveries)
                {
                    <div class="recent-row">
                        <div>
                            <strong>@item.PoiName</strong>
                            <br />
                            <small>POI #@item.PoiId</small>
                        </div>

                        <div>@item.Method</div>

                        <div>
                            +@item.Points <span data-i18n="homePointsLower">điểm</span>
                        </div>

                        <div>@item.DiscoveredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                }
            </div>
        }
    </section>
}

<section class="tourist-section">
    <div class="tourist-section-head">
        <div>
            <div class="tourist-kicker" data-i18n="homeProcessKicker">Quy trình</div>
            <h2 class="tourist-title" data-i18n="homeProcessTitle">Du khách sử dụng như thế nào?</h2>
        </div>
    </div>

    <div class="steps">
        <div class="step">
            <div class="step-number">1</div>
            <h3 data-i18n="homeStep1Title">Tạo tài khoản</h3>
            <p data-i18n="homeStep1Desc">Đăng ký tài khoản du khách trên web bằng email và mật khẩu.</p>
        </div>

        <div class="step">
            <div class="step-number">2</div>
            <h3 data-i18n="homeStep2Title">Mở bản đồ</h3>
            <p data-i18n="homeStep2Desc">Xem các POI đã duyệt, tìm địa điểm và chọn điểm muốn khám phá.</p>
        </div>

        <div class="step">
            <div class="step-number">3</div>
            <h3 data-i18n="homeStep3Title">Đến địa điểm</h3>
            <p data-i18n="homeStep3Desc">Dùng chỉ đường để di chuyển tới vị trí POI ngoài thực tế.</p>
        </div>

        <div class="step">
            <div class="step-number">4</div>
            <h3 data-i18n="homeStep4Title">Dùng trên app</h3>
            <p data-i18n="homeStep4Desc">Tài khoản web có thể đăng nhập trên app để tiếp tục trải nghiệm.</p>
        </div>
    </div>
</section>

<section class="tourist-section">
    <div class="cta-box">
        <div>
            <h2 data-i18n="homeCtaTitle">Sẵn sàng khám phá chưa?</h2>

            <p data-i18n="homeCtaDesc">
                Mở bản đồ du khách để xem các điểm tham quan, hoặc tạo tài khoản để dùng chung với app mobile.
            </p>
        </div>

        <div class="cta-actions">
            <a asp-area="DuKhach"
               asp-controller="Map"
               asp-action="Index"
               asp-route-lang="@selectedLanguageCode"
               class="dk-btn dk-btn-primary">
                <i class="fa-solid fa-map-location-dot"></i>
                <span data-i18n="homeOpenMap">Mở bản đồ</span>
            </a>

            @if (!isTourist)
            {
                <a asp-area="DuKhach"
                   asp-controller="Account"
                   asp-action="Register"
                   asp-route-lang="@selectedLanguageCode"
                   class="dk-btn dk-btn-ghost">
                    <i class="fa-solid fa-user-plus"></i>
                    <span data-i18n="navRegister">Đăng ký</span>
                </a>
            }
            else
            {
                <a asp-area="DuKhach"
                   asp-controller="Account"
                   asp-action="Profile"
                   asp-route-lang="@selectedLanguageCode"
                   class="dk-btn dk-btn-ghost">
                    <i class="fa-solid fa-user"></i>
                    <span data-i18n="homeMyProfile">Hồ sơ của tôi</span>
                </a>
            }
        </div>
    </div>
</section>