@{
    ViewData["Title"] = "Quên mật khẩu";
}

@section Styles {
    <style>
        .forgot-page {
            min-height: calc(100vh - 230px);
            display: grid;
            grid-template-columns: minmax(0, 1fr) 460px;
            gap: 28px;
            align-items: center;
        }

        .forgot-hero {
            position: relative;
            overflow: hidden;
            min-height: 590px;
            border: 1px solid var(--border);
            border-radius: 36px;
            padding: 42px;
            background:
                radial-gradient(circle at 18% 20%, rgba(52, 211, 153, 0.22), transparent 28%),
                radial-gradient(circle at 82% 34%, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, rgba(15, 29, 52, 0.94), rgba(7, 18, 34, 0.80)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");
            background-size: cover;
            background-position: center;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        html[data-theme="light"] .forgot-hero {
            background:
                radial-gradient(circle at 18% 20%, rgba(52, 211, 153, 0.18), transparent 28%),
                radial-gradient(circle at 82% 34%, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(238, 248, 255, 0.78)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");
            background-size: cover;
            background-position: center;
        }

        .forgot-eyebrow {
            width: fit-content;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 13px;
            border: 1px solid rgba(52, 211, 153, 0.30);
            border-radius: 999px;
            color: var(--accent);
            background: rgba(52, 211, 153, 0.12);
            font-size: 13px;
            font-weight: 900;
        }

        .forgot-hero h1 {
            max-width: 760px;
            margin: 20px 0 16px;
            font-size: clamp(42px, 5vw, 74px);
            line-height: 0.94;
            letter-spacing: -0.075em;
            font-weight: 950;
        }

        .forgot-hero h1 span {
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .forgot-hero p {
            max-width: 650px;
            margin: 0;
            color: var(--muted);
            font-size: 17px;
            line-height: 1.8;
        }

        .forgot-feature-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
            margin-top: 30px;
        }

        .forgot-feature {
            min-width: 0;
            padding: 18px;
            border: 1px solid var(--border);
            border-radius: 24px;
            background: rgba(6, 17, 31, 0.54);
            backdrop-filter: blur(18px);
        }

        html[data-theme="light"] .forgot-feature {
            background: rgba(255, 255, 255, 0.66);
        }

        .forgot-feature i {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 16px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            margin-bottom: 12px;
        }

        .forgot-feature strong {
            display: block;
            font-weight: 950;
            margin-bottom: 6px;
        }

        .forgot-feature span {
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
        }

        .forgot-note {
            display: flex;
            gap: 12px;
            padding: 16px;
            border: 1px solid rgba(56, 189, 248, 0.24);
            border-radius: 22px;
            color: var(--muted);
            background: rgba(56, 189, 248, 0.08);
            line-height: 1.6;
            font-size: 14px;
        }

        .forgot-note i {
            color: var(--accent-2);
            margin-top: 4px;
        }

        .forgot-card {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border);
            border-radius: 34px;
            background: var(--card);
            box-shadow: var(--shadow);
        }

        .forgot-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 0%, rgba(52, 211, 153, 0.16), transparent 28%),
                radial-gradient(circle at 100% 20%, rgba(56, 189, 248, 0.14), transparent 30%);
            pointer-events: none;
        }

        .forgot-card-inner {
            position: relative;
            z-index: 2;
            padding: 34px;
        }

        .forgot-card-top {
            text-align: center;
            margin-bottom: 28px;
        }

        .forgot-icon {
            width: 70px;
            height: 70px;
            margin: 0 auto 16px;
            display: grid;
            place-items: center;
            border-radius: 24px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            box-shadow: 0 18px 45px rgba(52, 211, 153, 0.24);
            font-size: 27px;
        }

        .forgot-card h2 {
            margin: 0;
            font-size: 34px;
            font-weight: 950;
            letter-spacing: -0.055em;
        }

        .forgot-card-subtitle {
            margin: 10px auto 0;
            max-width: 350px;
            color: var(--muted);
            line-height: 1.65;
            font-size: 14px;
        }

        .forgot-alert {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            padding: 14px;
            border-radius: 18px;
            margin-bottom: 16px;
            line-height: 1.55;
            font-weight: 750;
        }

        .forgot-alert-success {
            border: 1px solid rgba(52, 211, 153, 0.30);
            background: rgba(52, 211, 153, 0.10);
            color: var(--accent);
        }

        .forgot-alert-danger,
        .validation-summary-errors {
            border: 1px solid rgba(251, 113, 133, 0.28);
            background: rgba(251, 113, 133, 0.10);
            color: var(--danger);
        }

        .validation-summary-errors {
            padding: 13px 14px;
            border-radius: 18px;
            font-weight: 800;
            margin-bottom: 16px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        .forgot-field {
            margin-bottom: 16px;
        }

        .forgot-label {
            display: block;
            margin-bottom: 8px;
            color: var(--text);
            font-weight: 900;
            font-size: 13px;
        }

        .forgot-input-wrap {
            position: relative;
        }

        .forgot-input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        .forgot-input {
            width: 100%;
            min-height: 52px;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 0 16px 0 44px;
            color: var(--text);
            background: var(--surface);
            outline: none;
            font-weight: 700;
            transition: 0.2s ease;
        }

        .forgot-input::placeholder {
            color: var(--soft);
            font-weight: 600;
        }

        .forgot-input:focus {
            border-color: var(--accent-2);
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
        }

        .forgot-submit {
            width: 100%;
            min-height: 54px;
            border: 0;
            border-radius: 18px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            font-weight: 950;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 18px 46px rgba(52, 211, 153, 0.22);
            transition: 0.2s ease;
        }

        .forgot-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 56px rgba(52, 211, 153, 0.28);
        }

        .forgot-bottom {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            text-align: center;
            color: var(--muted);
            line-height: 1.6;
        }

        .forgot-bottom a {
            color: var(--accent-2);
            font-weight: 950;
            text-decoration: none;
        }

        .forgot-bottom a:hover {
            text-decoration: underline;
        }

        .forgot-mini-note {
            margin-top: 18px;
            padding: 14px;
            border-radius: 20px;
            border: 1px solid rgba(251, 191, 36, 0.26);
            background: rgba(251, 191, 36, 0.10);
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
            display: flex;
            gap: 10px;
        }

        .forgot-mini-note i {
            color: var(--warning);
            margin-top: 3px;
        }

        @@media (max-width: 1050px) {
            .forgot-page {
                grid-template-columns: 1fr;
            }

            .forgot-hero {
                min-height: auto;
            }
        }

        @@media (max-width: 720px) {
            .forgot-hero,
            .forgot-card-inner {
                padding: 24px;
            }

            .forgot-feature-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="forgot-page">
    <section class="forgot-hero">
        <div>
            <div class="forgot-eyebrow">
                <i class="fa-solid fa-key"></i>
                Khôi phục tài khoản
            </div>

            <h1>
                Lấy lại quyền truy cập <span>tài khoản du khách.</span>
            </h1>

            <p>
                Nhập email đã đăng ký để nhận hướng dẫn đặt lại mật khẩu.
                Sau khi đổi mật khẩu, web du khách và app mobile sẽ dùng mật khẩu mới.
            </p>

            <div class="forgot-feature-row">
                <div class="forgot-feature">
                    <i class="fa-solid fa-envelope-circle-check"></i>
                    <strong>Gửi qua email</strong>
                    <span>Hệ thống gửi hướng dẫn khôi phục tới email đã đăng ký.</span>
                </div>

                <div class="forgot-feature">
                    <i class="fa-solid fa-shield-halved"></i>
                    <strong>Bảo mật</strong>
                    <span>Chỉ email hợp lệ mới có thể thực hiện yêu cầu đặt lại mật khẩu.</span>
                </div>

                <div class="forgot-feature">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                    <strong>Dùng chung app</strong>
                    <span>Mật khẩu mới sẽ dùng được cho cả web và app mobile.</span>
                </div>
            </div>
        </div>

        <div class="forgot-note">
            <i class="fa-solid fa-circle-info"></i>
            <span>
                Nếu không thấy email trong hộp thư đến, hãy kiểm tra mục Spam/Quảng cáo.
                Link đặt lại mật khẩu thường chỉ có hiệu lực trong một khoảng thời gian nhất định.
            </span>
        </div>
    </section>

    <section class="forgot-card">
        <div class="forgot-card-inner">
            <div class="forgot-card-top">
                <div class="forgot-icon">
                    <i class="fa-solid fa-unlock-keyhole"></i>
                </div>

                <h2>Quên mật khẩu</h2>

                <p class="forgot-card-subtitle">
                    Nhập email bạn đã dùng để đăng ký tài khoản du khách.
                </p>
            </div>

            @if (TempData["DuKhachSuccessMessage"] != null)
            {
                <div class="forgot-alert forgot-alert-danger">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span>@TempData["DuKhachSuccessMessage"]</span>
                </div>
            }

            @if (TempData["DuKhachSuccessMessage"] != null)
            {
                <div class="forgot-alert forgot-alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["DuKhachSuccessMessage"]</span>
                </div>
            }

            @if (TempData["DuKhachDebugResetLink"] != null)
            {
                <div class="forgot-mini-note" style="margin-bottom:16px;">
                    <i class="fa-solid fa-code"></i>
                    <span>
                        Link test local:
                        <a href="@TempData["DuKhachDebugResetLink"]" style="color:var(--accent-2);font-weight:900;word-break:break-all;">
                            @TempData["DuKhachDebugResetLink"]
                        </a>
                    </span>
                </div>
            }

            <form asp-area="DuKhach"
                  asp-controller="Account"
                  asp-action="ForgotPassword"
                  method="post"
                  novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="forgot-alert forgot-alert-danger"></div>

                <div class="forgot-field">
                    <label for="email" class="forgot-label">
                        Địa chỉ email
                    </label>

                    <div class="forgot-input-wrap">
                        <i class="fa-solid fa-envelope forgot-input-icon"></i>

                        <input type="email"
                               id="email"
                               name="email"
                               class="forgot-input"
                               autocomplete="email"
                               placeholder="your.email@example.com"
                               required />
                    </div>
                </div>

                <button type="submit" class="forgot-submit">
                    <i class="fa-solid fa-paper-plane"></i>
                    Gửi yêu cầu khôi phục
                </button>
            </form>

            <div class="forgot-bottom">
                Nhớ mật khẩu rồi?
                <a asp-area="DuKhach"
                   asp-controller="Account"
                   asp-action="Login">
                    Quay lại đăng nhập
                </a>
            </div>

            <div class="forgot-mini-note">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>
                    Vì lý do bảo mật, hệ thống có thể không thông báo email có tồn tại hay không.
                    Hãy nhập đúng email đã đăng ký tài khoản du khách.
                </span>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}