@model DuKhachChangePasswordViewModel

@{
    ArgumentNullException.ThrowIfNull(Model);
    ViewData["Title"] = "Đổi mật khẩu du khách";
}

@section Styles {
    <style>
        .change-password-page {
            min-height: calc(100vh - 230px);
            display: grid;
            grid-template-columns: minmax(0, 1fr) 480px;
            gap: 28px;
            align-items: center;
        }

        .security-hero {
            position: relative;
            overflow: hidden;
            min-height: 620px;
            border: 1px solid var(--border);
            border-radius: 36px;
            padding: 42px;
            background:
                radial-gradient(circle at 18% 20%, rgba(52, 211, 153, 0.22), transparent 28%),
                radial-gradient(circle at 82% 34%, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, rgba(15, 29, 52, 0.94), rgba(7, 18, 34, 0.80)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");
            background-size: cover;
            background-position: center;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        html[data-theme="light"] .security-hero {
            background:
                radial-gradient(circle at 18% 20%, rgba(52, 211, 153, 0.18), transparent 28%),
                radial-gradient(circle at 82% 34%, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(238, 248, 255, 0.78)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");
            background-size: cover;
            background-position: center;
        }

        .security-eyebrow {
            width: fit-content;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 13px;
            border: 1px solid rgba(52, 211, 153, 0.30);
            border-radius: 999px;
            color: var(--accent);
            background: rgba(52, 211, 153, 0.12);
            font-size: 13px;
            font-weight: 900;
        }

        .security-hero h1 {
            max-width: 760px;
            margin: 20px 0 16px;
            font-size: clamp(42px, 5vw, 74px);
            line-height: 0.94;
            letter-spacing: -0.075em;
            font-weight: 950;
        }

        .security-hero h1 span {
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .security-hero p {
            max-width: 660px;
            margin: 0;
            color: var(--muted);
            font-size: 17px;
            line-height: 1.8;
        }

        .security-feature-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
            margin-top: 30px;
        }

        .security-feature {
            min-width: 0;
            padding: 18px;
            border: 1px solid var(--border);
            border-radius: 24px;
            background: rgba(6, 17, 31, 0.54);
            backdrop-filter: blur(18px);
        }

        html[data-theme="light"] .security-feature {
            background: rgba(255, 255, 255, 0.66);
        }

        .security-feature i {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 16px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            margin-bottom: 12px;
        }

        .security-feature strong {
            display: block;
            font-weight: 950;
            margin-bottom: 6px;
        }

        .security-feature span {
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
        }

        .security-note {
            display: flex;
            gap: 12px;
            padding: 16px;
            border: 1px solid rgba(251, 191, 36, 0.26);
            border-radius: 22px;
            color: var(--muted);
            background: rgba(251, 191, 36, 0.10);
            line-height: 1.6;
            font-size: 14px;
        }

        .security-note i {
            color: var(--warning);
            margin-top: 4px;
        }

        .password-card {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border);
            border-radius: 34px;
            background: var(--card);
            box-shadow: var(--shadow);
        }

        .password-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 0%, rgba(52, 211, 153, 0.16), transparent 28%),
                radial-gradient(circle at 100% 20%, rgba(56, 189, 248, 0.14), transparent 30%);
            pointer-events: none;
        }

        .password-card-inner {
            position: relative;
            z-index: 2;
            padding: 34px;
        }

        .password-card-top {
            text-align: center;
            margin-bottom: 26px;
        }

        .password-icon {
            width: 70px;
            height: 70px;
            margin: 0 auto 16px;
            display: grid;
            place-items: center;
            border-radius: 24px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            box-shadow: 0 18px 45px rgba(52, 211, 153, 0.24);
            font-size: 27px;
        }

        .password-card h2 {
            margin: 0;
            font-size: 34px;
            font-weight: 950;
            letter-spacing: -0.055em;
        }

        .password-card-subtitle {
            margin: 10px auto 0;
            max-width: 350px;
            color: var(--muted);
            line-height: 1.65;
            font-size: 14px;
        }

        .password-form-grid {
            display: grid;
            gap: 15px;
        }

        .password-field {
            min-width: 0;
        }

        .password-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
            color: var(--text);
            font-weight: 900;
            font-size: 13px;
        }

        .password-input-wrap {
            position: relative;
        }

        .password-input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        .password-input {
            width: 100%;
            min-height: 52px;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 0 48px 0 44px;
            color: var(--text);
            background: var(--surface);
            outline: none;
            font-weight: 700;
            transition: 0.2s ease;
        }

        .password-input::placeholder {
            color: var(--soft);
            font-weight: 600;
        }

        .password-input:focus {
            border-color: var(--accent-2);
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
        }

        .password-toggle {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            width: 38px;
            height: 38px;
            border: 0;
            border-radius: 14px;
            color: var(--muted);
            background: transparent;
            cursor: pointer;
            transition: 0.2s ease;
        }

        .password-toggle:hover {
            color: var(--text);
            background: rgba(148, 163, 184, 0.12);
        }

        .password-hint {
            margin-top: 9px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }

        .password-bar {
            height: 5px;
            border-radius: 999px;
            background: rgba(148, 163, 184, 0.20);
            overflow: hidden;
        }

        .password-bar span {
            display: block;
            width: 0;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            transition: 0.2s ease;
        }

        .password-small {
            margin-top: 8px;
            color: var(--muted);
            font-size: 12px;
            line-height: 1.5;
        }

        .password-actions {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 10px;
            align-items: center;
            margin-top: 4px;
        }

        .password-submit {
            min-height: 54px;
            border: 0;
            border-radius: 18px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            font-weight: 950;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 18px 46px rgba(52, 211, 153, 0.22);
            transition: 0.2s ease;
        }

        .password-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 56px rgba(52, 211, 153, 0.28);
        }

        .password-back {
            min-height: 54px;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 0 18px;
            color: var(--text);
            background: rgba(148, 163, 184, 0.10);
            font-weight: 950;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            text-decoration: none;
            transition: 0.2s ease;
            white-space: nowrap;
        }

        .password-back:hover {
            color: var(--text);
            transform: translateY(-2px);
            background: rgba(148, 163, 184, 0.16);
        }

        .security-mini-note {
            margin-top: 18px;
            padding: 14px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.22);
            background: rgba(56, 189, 248, 0.08);
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
            display: flex;
            gap: 10px;
        }

        .security-mini-note i {
            color: var(--accent-2);
            margin-top: 3px;
        }

        .text-danger {
            display: block;
            margin-top: 6px;
            font-size: 13px;
            font-weight: 700;
        }

        .validation-summary-errors {
            padding: 13px 14px;
            border-radius: 18px;
            border: 1px solid rgba(251, 113, 133, 0.28);
            background: rgba(251, 113, 133, 0.10);
            color: var(--danger);
            font-weight: 800;
            margin-bottom: 16px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        @@media (max-width: 1050px) {
            .change-password-page {
                grid-template-columns: 1fr;
            }

            .security-hero {
                min-height: auto;
            }
        }

        @@media (max-width: 720px) {
            .security-hero,
            .password-card-inner {
                padding: 24px;
            }

            .security-feature-row {
                grid-template-columns: 1fr;
            }

            .password-actions {
                grid-template-columns: 1fr;
            }

            .password-back {
                width: 100%;
            }
        }
    </style>
}

<div class="change-password-page">
    <section class="security-hero">
        <div>
            <div class="security-eyebrow">
                <i class="fa-solid fa-shield-halved"></i>
                Bảo mật tài khoản
            </div>

            <h1>
                Cập nhật mật khẩu <span>an toàn hơn.</span>
            </h1>

            <p>
                Sau khi đổi mật khẩu, web du khách và app mobile đều sẽ dùng mật khẩu mới.
                Hãy chọn mật khẩu đủ mạnh để bảo vệ lịch sử check-in và điểm khám phá của bạn.
            </p>

            <div class="security-feature-row">
                <div class="security-feature">
                    <i class="fa-solid fa-key"></i>
                    <strong>Đổi mật khẩu</strong>
                    <span>Cập nhật thông tin đăng nhập cho tài khoản du khách.</span>
                </div>

                <div class="security-feature">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                    <strong>Đồng bộ app</strong>
                    <span>App mobile sẽ cần dùng mật khẩu mới sau khi thay đổi.</span>
                </div>

                <div class="security-feature">
                    <i class="fa-solid fa-location-crosshairs"></i>
                    <strong>Bảo vệ dữ liệu</strong>
                    <span>Giữ an toàn lịch sử check-in, điểm và hành trình khám phá.</span>
                </div>
            </div>
        </div>

        <div class="security-note">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>
                Không chia sẻ mật khẩu với người khác. Nên dùng mật khẩu khác với email,
                mạng xã hội hoặc các tài khoản quan trọng khác.
            </span>
        </div>
    </section>

    <section class="password-card">
        <div class="password-card-inner">
            <div class="password-card-top">
                <div class="password-icon">
                    <i class="fa-solid fa-lock"></i>
                </div>

                <h2>Đổi mật khẩu</h2>

                <p class="password-card-subtitle">
                    Nhập mật khẩu hiện tại và mật khẩu mới để cập nhật tài khoản.
                </p>
            </div>

            <form asp-area="DuKhach"
                  asp-controller="Account"
                  asp-action="ChangePassword"
                  method="post"
                  novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="password-form-grid">
                    <div class="password-field">
                        <label asp-for="CurrentPassword" class="password-label">
                            Mật khẩu hiện tại
                        </label>

                        <div class="password-input-wrap">
                            <i class="fa-solid fa-lock-open password-input-icon"></i>

                            <input asp-for="CurrentPassword"
                                   id="currentPassword"
                                   class="password-input"
                                   type="password"
                                   autocomplete="current-password"
                                   placeholder="Nhập mật khẩu hiện tại" />

                            <button type="button"
                                    class="password-toggle"
                                    data-target="currentPassword"
                                    title="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="password-field">
                        <label asp-for="NewPassword" class="password-label">
                            Mật khẩu mới
                        </label>

                        <div class="password-input-wrap">
                            <i class="fa-solid fa-key password-input-icon"></i>

                            <input asp-for="NewPassword"
                                   id="newPassword"
                                   class="password-input"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="Ít nhất 8 ký tự" />

                            <button type="button"
                                    class="password-toggle"
                                    data-target="newPassword"
                                    title="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <div class="password-hint" aria-hidden="true">
                            <div class="password-bar"><span></span></div>
                            <div class="password-bar"><span></span></div>
                            <div class="password-bar"><span></span></div>
                            <div class="password-bar"><span></span></div>
                        </div>

                        <div class="password-small" id="passwordHelp">
                            Nên dùng ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số hoặc ký tự đặc biệt.
                        </div>

                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="password-field">
                        <label asp-for="ConfirmPassword" class="password-label">
                            Nhập lại mật khẩu mới
                        </label>

                        <div class="password-input-wrap">
                            <i class="fa-solid fa-shield-halved password-input-icon"></i>

                            <input asp-for="ConfirmPassword"
                                   id="confirmPassword"
                                   class="password-input"
                                   type="password"
                                   autocomplete="new-password"
                                   placeholder="Nhập lại mật khẩu mới" />

                            <button type="button"
                                    class="password-toggle"
                                    data-target="confirmPassword"
                                    title="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <div class="password-small" id="confirmHelp">
                            Nhập lại mật khẩu mới để xác nhận.
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="password-actions">
                        <button class="password-submit" type="submit">
                            <i class="fa-solid fa-key"></i>
                            Đổi mật khẩu
                        </button>

                        <a class="password-back"
                           asp-area="DuKhach"
                           asp-controller="Account"
                           asp-action="Profile">
                            <i class="fa-solid fa-arrow-left"></i>
                            Quay lại
                        </a>
                    </div>
                </div>
            </form>

            <div class="security-mini-note">
                <i class="fa-solid fa-circle-info"></i>
                <span>
                    Sau khi đổi mật khẩu thành công, hãy dùng mật khẩu mới để đăng nhập lại trên app mobile.
                </span>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const newPasswordInput = document.getElementById('newPassword');
            const confirmInput = document.getElementById('confirmPassword');
            const passwordHelp = document.getElementById('passwordHelp');
            const confirmHelp = document.getElementById('confirmHelp');
            const bars = document.querySelectorAll('.password-bar span');

            function getStrength(value) {
                let score = 0;

                if (value.length >= 8) score++;
                if (/[A-Z]/.test(value) && /[a-z]/.test(value)) score++;
                if (/\d/.test(value)) score++;
                if (/[^A-Za-z0-9]/.test(value)) score++;

                return score;
            }

            function updateStrength() {
                const value = newPasswordInput.value || '';
                const score = getStrength(value);

                bars.forEach((bar, index) => {
                    bar.style.width = index < score ? '100%' : '0';
                });

                if (!value) {
                    passwordHelp.textContent = 'Nên dùng ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số hoặc ký tự đặc biệt.';
                    passwordHelp.style.color = 'var(--muted)';
                } else if (score <= 1) {
                    passwordHelp.textContent = 'Mật khẩu còn yếu. Hãy thêm chữ hoa, số hoặc ký tự đặc biệt.';
                    passwordHelp.style.color = 'var(--danger)';
                } else if (score <= 3) {
                    passwordHelp.textContent = 'Mật khẩu khá ổn. Có thể thêm ký tự đặc biệt để mạnh hơn.';
                    passwordHelp.style.color = 'var(--warning)';
                } else {
                    passwordHelp.textContent = 'Mật khẩu mạnh.';
                    passwordHelp.style.color = 'var(--accent)';
                }

                updateConfirm();
            }

            function updateConfirm() {
                const password = newPasswordInput.value || '';
                const confirm = confirmInput.value || '';

                if (!confirm) {
                    confirmHelp.textContent = 'Nhập lại mật khẩu mới để xác nhận.';
                    confirmHelp.style.color = 'var(--muted)';
                    return;
                }

                if (password === confirm) {
                    confirmHelp.textContent = 'Mật khẩu xác nhận khớp.';
                    confirmHelp.style.color = 'var(--accent)';
                } else {
                    confirmHelp.textContent = 'Mật khẩu xác nhận chưa khớp.';
                    confirmHelp.style.color = 'var(--danger)';
                }
            }

            document.querySelectorAll('.password-toggle').forEach(button => {
                button.addEventListener('click', function () {
                    const targetId = button.getAttribute('data-target');
                    const input = document.getElementById(targetId);

                    if (!input) return;

                    const isPassword = input.type === 'password';

                    input.type = isPassword ? 'text' : 'password';

                    button.innerHTML = isPassword
                        ? '<i class="fa-solid fa-eye-slash"></i>'
                        : '<i class="fa-solid fa-eye"></i>';
                });
            });

            newPasswordInput?.addEventListener('input', updateStrength);
            confirmInput?.addEventListener('input', updateConfirm);

            updateStrength();
        })();
    </script>
}