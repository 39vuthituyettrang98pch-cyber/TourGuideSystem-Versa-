@model DuKhachResetPasswordViewModel

@{
    ArgumentNullException.ThrowIfNull(Model);
    ViewData["Title"] = "Đặt lại mật khẩu";

    var email = Model.Email;
    var displayEmail = string.IsNullOrWhiteSpace(email) ? "tài khoản du khách" : email;
}

@section Styles {
    <style>
        .reset-page {
            min-height: calc(100vh - 230px);
            display: grid;
            grid-template-columns: minmax(0, 1fr) 480px;
            gap: 28px;
            align-items: center;
        }

        .reset-hero {
            position: relative;
            overflow: hidden;
            min-height: 620px;
            border: 1px solid var(--border);
            border-radius: 36px;
            padding: 42px;
            background:
                radial-gradient(circle at 18% 20%, rgba(52, 211, 153, 0.22), transparent 28%),
                radial-gradient(circle at 82% 34%, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, rgba(15, 29, 52, 0.94), rgba(7, 18, 34, 0.80)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");
            background-size: cover;
            background-position: center;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        html[data-theme="light"] .reset-hero {
            background:
                radial-gradient(circle at 18% 20%, rgba(52, 211, 153, 0.18), transparent 28%),
                radial-gradient(circle at 82% 34%, rgba(56, 189, 248, 0.18), transparent 30%),
                linear-gradient(135deg, rgba(255, 255, 255, 0.94), rgba(238, 248, 255, 0.78)),
                url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80");
            background-size: cover;
            background-position: center;
        }

        .reset-eyebrow {
            width: fit-content;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 13px;
            border: 1px solid rgba(52, 211, 153, 0.30);
            border-radius: 999px;
            color: var(--accent);
            background: rgba(52, 211, 153, 0.12);
            font-size: 13px;
            font-weight: 900;
        }

        .reset-hero h1 {
            max-width: 760px;
            margin: 20px 0 16px;
            font-size: clamp(42px, 5vw, 74px);
            line-height: 0.94;
            letter-spacing: -0.075em;
            font-weight: 950;
        }

        .reset-hero h1 span {
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .reset-hero p {
            max-width: 650px;
            margin: 0;
            color: var(--muted);
            font-size: 17px;
            line-height: 1.8;
        }

        .reset-feature-row {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
            margin-top: 30px;
        }

        .reset-feature {
            min-width: 0;
            padding: 18px;
            border: 1px solid var(--border);
            border-radius: 24px;
            background: rgba(6, 17, 31, 0.54);
            backdrop-filter: blur(18px);
        }

        html[data-theme="light"] .reset-feature {
            background: rgba(255, 255, 255, 0.66);
        }

        .reset-feature i {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 16px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            margin-bottom: 12px;
        }

        .reset-feature strong {
            display: block;
            font-weight: 950;
            margin-bottom: 6px;
        }

        .reset-feature span {
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
        }

        .reset-note {
            display: flex;
            gap: 12px;
            padding: 16px;
            border: 1px solid rgba(251, 191, 36, 0.26);
            border-radius: 22px;
            color: var(--muted);
            background: rgba(251, 191, 36, 0.10);
            line-height: 1.6;
            font-size: 14px;
        }

        .reset-note i {
            color: var(--warning);
            margin-top: 4px;
        }

        .reset-card {
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border);
            border-radius: 34px;
            background: var(--card);
            box-shadow: var(--shadow);
        }

        .reset-card::before {
            content: "";
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 0%, rgba(52, 211, 153, 0.16), transparent 28%),
                radial-gradient(circle at 100% 20%, rgba(56, 189, 248, 0.14), transparent 30%);
            pointer-events: none;
        }

        .reset-card-inner {
            position: relative;
            z-index: 2;
            padding: 34px;
        }

        .reset-card-top {
            text-align: center;
            margin-bottom: 26px;
        }

        .reset-icon {
            width: 70px;
            height: 70px;
            margin: 0 auto 16px;
            display: grid;
            place-items: center;
            border-radius: 24px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            box-shadow: 0 18px 45px rgba(52, 211, 153, 0.24);
            font-size: 27px;
        }

        .reset-card h2 {
            margin: 0;
            font-size: 34px;
            font-weight: 950;
            letter-spacing: -0.055em;
        }

        .reset-card-subtitle {
            margin: 10px auto 0;
            max-width: 360px;
            color: var(--muted);
            line-height: 1.65;
            font-size: 14px;
        }

        .reset-email-pill {
            margin-top: 16px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            max-width: 100%;
            padding: 9px 12px;
            border-radius: 999px;
            border: 1px solid rgba(56, 189, 248, 0.24);
            color: var(--accent-2);
            background: rgba(56, 189, 248, 0.08);
            font-size: 13px;
            font-weight: 900;
            word-break: break-all;
        }

        .reset-form-grid {
            display: grid;
            gap: 15px;
        }

        .reset-field {
            min-width: 0;
        }

        .reset-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 8px;
            color: var(--text);
            font-weight: 900;
            font-size: 13px;
        }

        .reset-input-wrap {
            position: relative;
        }

        .reset-input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        .reset-input {
            width: 100%;
            min-height: 52px;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 0 48px 0 44px;
            color: var(--text);
            background: var(--surface);
            outline: none;
            font-weight: 700;
            transition: 0.2s ease;
        }

        .reset-input::placeholder {
            color: var(--soft);
            font-weight: 600;
        }

        .reset-input:focus {
            border-color: var(--accent-2);
            box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
        }

        .password-toggle {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            width: 38px;
            height: 38px;
            border: 0;
            border-radius: 14px;
            color: var(--muted);
            background: transparent;
            cursor: pointer;
            transition: 0.2s ease;
        }

        .password-toggle:hover {
            color: var(--text);
            background: rgba(148, 163, 184, 0.12);
        }

        .password-hint {
            margin-top: 9px;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 6px;
        }

        .password-bar {
            height: 5px;
            border-radius: 999px;
            background: rgba(148, 163, 184, 0.20);
            overflow: hidden;
        }

        .password-bar span {
            display: block;
            width: 0;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            transition: 0.2s ease;
        }

        .password-small {
            margin-top: 8px;
            color: var(--muted);
            font-size: 12px;
            line-height: 1.5;
        }

        .reset-submit {
            width: 100%;
            min-height: 54px;
            margin-top: 4px;
            border: 0;
            border-radius: 18px;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            font-weight: 950;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 18px 46px rgba(52, 211, 153, 0.22);
            transition: 0.2s ease;
        }

        .reset-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 22px 56px rgba(52, 211, 153, 0.28);
        }

        .reset-bottom {
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            text-align: center;
            color: var(--muted);
            line-height: 1.6;
        }

        .reset-bottom a {
            color: var(--accent-2);
            font-weight: 950;
            text-decoration: none;
        }

        .reset-bottom a:hover {
            text-decoration: underline;
        }

        .reset-mini-note {
            margin-top: 18px;
            padding: 14px;
            border-radius: 20px;
            border: 1px solid rgba(56, 189, 248, 0.22);
            background: rgba(56, 189, 248, 0.08);
            color: var(--muted);
            font-size: 13px;
            line-height: 1.55;
            display: flex;
            gap: 10px;
        }

        .reset-mini-note i {
            color: var(--accent-2);
            margin-top: 3px;
        }

        .validation-summary-errors {
            padding: 13px 14px;
            border-radius: 18px;
            border: 1px solid rgba(251, 113, 133, 0.28);
            background: rgba(251, 113, 133, 0.10);
            color: var(--danger);
            font-weight: 800;
            margin-bottom: 16px;
        }

        .validation-summary-errors ul {
            margin: 0;
            padding-left: 18px;
        }

        @@media (max-width: 1050px) {
            .reset-page {
                grid-template-columns: 1fr;
            }

            .reset-hero {
                min-height: auto;
            }
        }

        @@media (max-width: 720px) {
            .reset-hero,
            .reset-card-inner {
                padding: 24px;
            }

            .reset-feature-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="reset-page">
    <section class="reset-hero">
        <div>
            <div class="reset-eyebrow">
                <i class="fa-solid fa-unlock-keyhole"></i>
                Đặt lại mật khẩu
            </div>

            <h1>
                Tạo mật khẩu mới <span>an toàn hơn.</span>
            </h1>

            <p>
                Đặt lại mật khẩu cho tài khoản du khách của bạn.
                Sau khi lưu, web du khách và app mobile đều sẽ dùng mật khẩu mới này.
            </p>

            <div class="reset-feature-row">
                <div class="reset-feature">
                    <i class="fa-solid fa-key"></i>
                    <strong>Mật khẩu mới</strong>
                    <span>Tạo mật khẩu đủ mạnh để bảo vệ tài khoản.</span>
                </div>

                <div class="reset-feature">
                    <i class="fa-solid fa-shield-halved"></i>
                    <strong>Bảo mật</strong>
                    <span>Không chia sẻ mật khẩu mới cho người khác.</span>
                </div>

                <div class="reset-feature">
                    <i class="fa-solid fa-mobile-screen-button"></i>
                    <strong>Dùng chung app</strong>
                    <span>Mật khẩu mới đăng nhập được cả web và app mobile.</span>
                </div>
            </div>
        </div>

        <div class="reset-note">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>
                Nên dùng mật khẩu khác với email, mạng xã hội hoặc các tài khoản quan trọng khác.
                Mật khẩu tốt nên có chữ hoa, chữ thường, số và ký tự đặc biệt.
            </span>
        </div>
    </section>

    <section class="reset-card">
        <div class="reset-card-inner">
            <div class="reset-card-top">
                <div class="reset-icon">
                    <i class="fa-solid fa-lock"></i>
                </div>

                <h2>Tạo mật khẩu mới</h2>

                <p class="reset-card-subtitle">
                    Nhập OTP trong Gmail rồi tạo mật khẩu mới.
                </p>

                <div class="reset-email-pill">
                    <i class="fa-solid fa-envelope"></i>
                    @displayEmail
                </div>
            </div>

            @if (TempData["DuKhachSuccessMessage"] != null)
            {
                <div class="reset-mini-note" style="margin:0 0 16px;border-color:rgba(52,211,153,.3);background:rgba(52,211,153,.1)">
                    <i class="fa-solid fa-circle-check" style="color:var(--accent)"></i>
                    <span>@TempData["DuKhachSuccessMessage"]</span>
                </div>
            }

            @if (TempData["DuKhachDebugOtp"] != null)
            {
                <div class="reset-mini-note" style="margin:0 0 16px">
                    <i class="fa-solid fa-code"></i>
                    <span>OTP test local: <strong style="color:var(--accent-2);letter-spacing:.2em">@TempData["DuKhachDebugOtp"]</strong></span>
                </div>
            }

            <form asp-area="DuKhach"
                  asp-controller="Account"
                  asp-action="ResetPassword"
                  method="post"
                  novalidate>
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Email" />

                <div asp-validation-summary="ModelOnly"></div>

                <div class="reset-form-grid">
                    <div class="reset-field">
                        <label asp-for="Otp" class="reset-label">Mã OTP trong Gmail</label>

                        <div class="reset-input-wrap">
                            <i class="fa-solid fa-key reset-input-icon"></i>
                            <input asp-for="Otp"
                                   class="reset-input"
                                   inputmode="numeric"
                                   autocomplete="one-time-code"
                                   maxlength="6"
                                   pattern="[0-9]{6}"
                                   placeholder="000000"
                                   style="letter-spacing:.3em;font-size:20px" />
                        </div>

                        <span asp-validation-for="Otp" class="text-danger"></span>
                    </div>

                    <div class="reset-field">
                        <label asp-for="NewPassword" class="reset-label">
                            Mật khẩu mới
                        </label>

                        <div class="reset-input-wrap">
                            <i class="fa-solid fa-key reset-input-icon"></i>

                            <input asp-for="NewPassword"
                                   type="password"
                                   id="newPassword"
                                   class="reset-input"
                                   autocomplete="new-password"
                                   placeholder="Ít nhất 8 ký tự"
                                   required />

                            <button type="button"
                                    class="password-toggle"
                                    data-target="newPassword"
                                    title="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <div class="password-hint" aria-hidden="true">
                            <div class="password-bar"><span></span></div>
                            <div class="password-bar"><span></span></div>
                            <div class="password-bar"><span></span></div>
                            <div class="password-bar"><span></span></div>
                        </div>

                        <div class="password-small" id="passwordHelp">
                            Nên dùng ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số hoặc ký tự đặc biệt.
                        </div>

                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="reset-field">
                        <label asp-for="ConfirmPassword" class="reset-label">
                            Xác nhận mật khẩu mới
                        </label>

                        <div class="reset-input-wrap">
                            <i class="fa-solid fa-shield-halved reset-input-icon"></i>

                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   id="confirmPassword"
                                   class="reset-input"
                                   autocomplete="new-password"
                                   placeholder="Nhập lại mật khẩu mới"
                                   required />

                            <button type="button"
                                    class="password-toggle"
                                    data-target="confirmPassword"
                                    title="Hiện/ẩn mật khẩu">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>

                        <div class="password-small" id="confirmHelp">
                            Nhập lại mật khẩu mới để xác nhận.
                        </div>

                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="reset-submit">
                        <i class="fa-solid fa-floppy-disk"></i>
                        Lưu mật khẩu mới
                    </button>
                </div>
            </form>

            <div class="reset-bottom">
                Nhớ mật khẩu rồi?
                <a asp-area="DuKhach"
                   asp-controller="Account"
                   asp-action="Login">
                    Quay lại đăng nhập
                </a>
            </div>

            <div class="reset-mini-note">
                <i class="fa-solid fa-circle-info"></i>
                <span>
                    Sau khi đặt lại thành công, hãy dùng mật khẩu mới để đăng nhập trên web và app mobile.
                    Chưa nhận được mã?
                    <a asp-action="ForgotPassword" asp-route-email="@email" style="color:var(--accent-2);font-weight:900">Gửi lại OTP</a>.
                </span>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const newPasswordInput = document.getElementById('newPassword');
            const confirmInput = document.getElementById('confirmPassword');
            const passwordHelp = document.getElementById('passwordHelp');
            const confirmHelp = document.getElementById('confirmHelp');
            const bars = document.querySelectorAll('.password-bar span');

            function getStrength(value) {
                let score = 0;

                if (value.length >= 8) score++;
                if (/[A-Z]/.test(value) && /[a-z]/.test(value)) score++;
                if (/\d/.test(value)) score++;
                if (/[^A-Za-z0-9]/.test(value)) score++;

                return score;
            }

            function updateStrength() {
                const value = newPasswordInput.value || '';
                const score = getStrength(value);

                bars.forEach((bar, index) => {
                    bar.style.width = index < score ? '100%' : '0';
                });

                if (!value) {
                    passwordHelp.textContent = 'Nên dùng ít nhất 8 ký tự, gồm chữ hoa, chữ thường, số hoặc ký tự đặc biệt.';
                    passwordHelp.style.color = 'var(--muted)';
                } else if (score <= 1) {
                    passwordHelp.textContent = 'Mật khẩu còn yếu. Hãy thêm chữ hoa, số hoặc ký tự đặc biệt.';
                    passwordHelp.style.color = 'var(--danger)';
                } else if (score <= 3) {
                    passwordHelp.textContent = 'Mật khẩu khá ổn. Có thể thêm ký tự đặc biệt để mạnh hơn.';
                    passwordHelp.style.color = 'var(--warning)';
                } else {
                    passwordHelp.textContent = 'Mật khẩu mạnh.';
                    passwordHelp.style.color = 'var(--accent)';
                }

                updateConfirm();
            }

            function updateConfirm() {
                const password = newPasswordInput.value || '';
                const confirm = confirmInput.value || '';

                if (!confirm) {
                    confirmHelp.textContent = 'Nhập lại mật khẩu mới để xác nhận.';
                    confirmHelp.style.color = 'var(--muted)';
                    return;
                }

                if (password === confirm) {
                    confirmHelp.textContent = 'Mật khẩu xác nhận khớp.';
                    confirmHelp.style.color = 'var(--accent)';
                } else {
                    confirmHelp.textContent = 'Mật khẩu xác nhận chưa khớp.';
                    confirmHelp.style.color = 'var(--danger)';
                }
            }

            document.querySelectorAll('.password-toggle').forEach(button => {
                button.addEventListener('click', function () {
                    const targetId = button.getAttribute('data-target');
                    const input = document.getElementById(targetId);

                    if (!input) return;

                    const isPassword = input.type === 'password';

                    input.type = isPassword ? 'text' : 'password';

                    button.innerHTML = isPassword
                        ? '<i class="fa-solid fa-eye-slash"></i>'
                        : '<i class="fa-solid fa-eye"></i>';
                });
            });

            newPasswordInput?.addEventListener('input', updateStrength);
            confirmInput?.addEventListener('input', updateConfirm);

            updateStrength();
           })();
    </script>
}
