@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authentication
@using System.Security.Claims
@using System.Text.Json
@inject AdminWeb.Data.AppDbContext LayoutDbContext

@{
    var title = ViewData["Title"] as string ?? "Du khách";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    // Đọc trực tiếp TouristScheme để thanh điều hướng vẫn nhận ra du khách
    // khi trang chủ công khai đang ở URL `/` thay vì `/DuKhach/...`.
    var touristAuth = await Context.AuthenticateAsync("TouristScheme");
    var touristPrincipal = touristAuth.Succeeded ? touristAuth.Principal : null;
    var isTourist = touristPrincipal?.Identity?.IsAuthenticated == true
        && touristPrincipal.IsInRole("Tourist")
        && string.Equals(touristPrincipal.FindFirstValue("AccountType"), "Tourist", StringComparison.OrdinalIgnoreCase);
    var touristDisplayName = touristPrincipal?.FindFirstValue(ClaimTypes.Name) ?? "Tài khoản";
    var touristEmail = touristPrincipal?.FindFirstValue(ClaimTypes.Email) ?? string.Empty;
    var touristIdText = touristPrincipal?.FindFirstValue(ClaimTypes.NameIdentifier);
    var touristIdForLayout = int.TryParse(touristIdText, out var parsedTouristId) ? parsedTouristId : (int?)null;
    var hasDuKhachPremium = touristIdForLayout.HasValue && await LayoutDbContext.TouristSubscriptions
        .AsNoTracking()
        .Include(item => item.PaymentPlan)
        .AnyAsync(item =>
            item.TouristId == touristIdForLayout.Value &&
            item.Status == "Active" &&
            item.ExpiresAt > DateTime.UtcNow &&
            item.PaymentPlan != null &&
            (item.PaymentPlan.PlanCode == "USER_PREMIUM" || item.PaymentPlan.Audience == "Tourist" || item.PaymentPlan.Audience == "Both"));

    var isHome = currentController == "Home";
    var isMap = currentController == "Map";
    var isQr = currentController == "Qr";
    var isTour = currentController == "Tour";
    var isLeaderboard = currentController == "Leaderboard";
    var isPayments = currentController == "Payments";
    var isOrders = currentController == "MenuOrders";
    var isAccount = currentController == "Account";

    var selectedLanguageCode = (ViewBag.SelectedLanguageCode as string
        ?? Context.Request.Query["lang"].FirstOrDefault()
        ?? Context.Request.Cookies["versa.dukhach.lang"]
        ?? "vi").ToLowerInvariant();

    static string GetNativeLanguageDisplayName(string? code, string? currentName)
    {
        var normalizedCode = (code ?? string.Empty).Trim().ToLowerInvariant();
        return normalizedCode switch
        {
            "vi" => "Tiếng Việt",
            "en" => "English",
            "fr" => "Français",
            "zh" or "zh-cn" or "zh-tw" => "中文",
            "ja" => "日本語",
            "ko" => "한국어",
            "th" => "ไทย",
            "de" => "Deutsch",
            "es" => "Español",
            "it" => "Italiano",
            "pt" => "Português",
            "ru" => "Русский",
            _ => string.IsNullOrWhiteSpace(currentName) ? normalizedCode.ToUpperInvariant() : currentName.Trim()
        };
    }

    var languageRows = await LayoutDbContext.SupportedLanguages
        .AsNoTracking()
        .Where(language => language.IsActive)
        .OrderBy(language => language.LanguageCode == "vi" ? 0 : language.LanguageCode == "en" ? 1 : 2)
        .ThenBy(language => language.LanguageName)
        .Select(language => new
        {
            Code = language.LanguageCode.Trim().ToLower(),
            Name = language.LanguageName
        })
        .ToListAsync();

    var languageOptions = languageRows
        .Select(language => new
        {
            language.Code,
            Name = GetNativeLanguageDisplayName(language.Code, language.Name)
        })
        .ToList();

    if (languageOptions.Count == 0)
    {
        languageOptions = new[]
        {
            new { Code = "vi", Name = "Tiếng Việt" },
            new { Code = "en", Name = "English" },
            new { Code = "fr", Name = "Français" },
            new { Code = "zh", Name = "中文" },
            new { Code = "ja", Name = "日本語" },
            new { Code = "ko", Name = "한국어" }
        }.ToList();
    }

    var selectedLanguageName = languageOptions
        .FirstOrDefault(language => string.Equals(language.Code, selectedLanguageCode, StringComparison.OrdinalIgnoreCase))
        ?.Name ?? selectedLanguageCode.ToUpperInvariant();
}

<!DOCTYPE html>
<html lang="@selectedLanguageCode" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@title - VERSA Travel</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/dukhach-ai-chat.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        :root {
            --bg: #06111f;
            --bg-2: #091a2e;
            --surface: rgba(15, 29, 52, 0.82);
            --surface-2: rgba(20, 40, 70, 0.72);
            --card: rgba(12, 24, 44, 0.88);
            --text: #f4f8ff;
            --muted: #a9bad7;
            --soft: #6f82a7;
            --border: rgba(148, 163, 184, 0.22);
            --accent: #34d399;
            --accent-2: #38bdf8;
            --accent-3: #a78bfa;
            --danger: #fb7185;
            --warning: #fbbf24;
            --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
            --radius: 28px;
        }

        html[data-theme="light"] {
            --bg: #f4f8ff;
            --bg-2: #e9f3ff;
            --surface: rgba(255, 255, 255, 0.86);
            --surface-2: rgba(255, 255, 255, 0.74);
            --card: rgba(255, 255, 255, 0.96);
            --text: #102033;
            --muted: #50627e;
            --soft: #71809a;
            --border: rgba(15, 23, 42, 0.12);
            --shadow: 0 24px 70px rgba(15, 23, 42, 0.12);
        }

        * {
            box-sizing: border-box;
        }

        html,
        body {
            min-height: 100%;
            height: auto;
            overflow-x: hidden;
            overflow-y: auto;
        }

        body {
            margin: 0;
            color: var(--text);
            background:
                radial-gradient(circle at 8% 12%, rgba(52, 211, 153, 0.18), transparent 32%),
                radial-gradient(circle at 88% 18%, rgba(56, 189, 248, 0.18), transparent 34%),
                radial-gradient(circle at 50% 92%, rgba(167, 139, 250, 0.15), transparent 34%),
                linear-gradient(180deg, var(--bg), var(--bg-2));
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);
            background-size: 46px 46px;
            mask-image: linear-gradient(to bottom, rgba(0,0,0,0.85), transparent);
            z-index: -1;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .dk-shell {
            width: min(1660px, calc(100% - 28px));
            margin: 0 auto;
        }

        .dk-navbar-wrap {
            position: sticky;
            top: 0;
            z-index: 5000;
            border-bottom: 1px solid var(--border);
            background: rgba(6, 17, 31, 0.86);
            backdrop-filter: blur(22px);
        }

        html[data-theme="light"] .dk-navbar-wrap {
            background: rgba(244, 248, 255, 0.92);
        }

        .dk-navbar {
            min-height: 76px;
            display: grid;
            grid-template-columns: 218px minmax(0, 1fr) auto;
            align-items: center;
            gap: 10px;
        }

        .dk-brand {
            min-width: 0;
            display: inline-flex;
            align-items: center;
            gap: 12px;
            font-weight: 950;
            letter-spacing: -0.02em;
        }

        .dk-brand-icon {
            width: 48px;
            height: 48px;
            min-width: 48px;
            border-radius: 19px;
            display: grid;
            place-items: center;
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            box-shadow: 0 16px 34px rgba(52, 211, 153, 0.28);
        }

        .dk-brand-text {
            display: grid;
            line-height: 1.05;
            font-size: 18px;
        }

        .dk-brand small {
            display: block;
            margin-top: 4px;
            color: var(--muted);
            font-size: 10px;
            font-weight: 850;
        }

        .dk-nav-center {
            min-width: 0;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 6px;
            overflow-x: auto;
            overflow-y: hidden;
            scrollbar-width: none;
            padding: 10px 0;
            mask-image: none;
        }

        .dk-nav-center::-webkit-scrollbar {
            display: none;
        }

        .dk-nav-actions {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 7px;
            flex-wrap: nowrap;
            min-width: 0;
        }

        .dk-nav-link,
        .dk-icon-btn,
        .dk-btn,
        .dk-language-btn {
            border: 1px solid transparent;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            font-weight: 900;
            transition: 0.18s ease;
            white-space: nowrap;
            line-height: 1;
        }

        .dk-nav-link {
            flex: 0 0 auto;
            min-height: 40px;
            padding: 0 11px;
            color: var(--muted);
            font-size: 13px;
        }

        .dk-nav-link i {
            font-size: 13px;
        }

        .dk-nav-link:hover,
        .dk-nav-link.active {
            color: var(--text);
            background: rgba(148, 163, 184, 0.12);
            border-color: var(--border);
        }

        .dk-nav-link.active {
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            border-color: transparent;
            box-shadow: 0 14px 34px rgba(52, 211, 153, 0.18);
        }


        .dk-premium-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            border-radius: 999px;
            padding: 0 10px;
            min-height: 34px;
            border: 1px solid rgba(251, 191, 36, .28);
            background: rgba(251, 191, 36, .10);
            color: #fde68a;
            font-size: 12px;
            font-weight: 950;
        }

        .dk-language {
            position: relative;
            flex: 0 0 auto;
        }

        .dk-language-btn {
            min-height: 42px;
            min-width: 132px;
            max-width: 142px;
            padding: 0 12px;
            border-color: var(--border);
            color: var(--text);
            background: rgba(148, 163, 184, 0.10);
            font-size: 13px;
            cursor: pointer;
        }

        .dk-language-btn i {
            color: var(--accent-2);
        }

        .dk-language-btn span {
            min-width: 0;
            max-width: 68px;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .dk-language-btn:hover,
        .dk-language-btn.show {
            color: var(--text);
            border-color: rgba(56, 189, 248, 0.44);
            background: rgba(148, 163, 184, 0.16);
            transform: translateY(-1px);
        }

        .dk-language-menu {
            min-width: 220px;
            padding: 9px;
            margin-top: 12px !important;
            border-radius: 20px;
            border: 1px solid var(--border);
            background: rgba(7, 18, 34, 0.98);
            box-shadow: 0 22px 70px rgba(0, 0, 0, 0.35);
            backdrop-filter: blur(22px);
        }

        html[data-theme="light"] .dk-language-menu {
            background: rgba(255, 255, 255, 0.98);
            box-shadow: 0 22px 70px rgba(15, 23, 42, 0.16);
        }

        .dk-language-option {
            width: 100%;
            min-height: 42px;
            border: 0;
            border-radius: 14px;
            padding: 0 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text);
            background: transparent;
            font-size: 13px;
            font-weight: 850;
            text-align: left;
            cursor: pointer;
        }

        .dk-language-option:hover {
            background: rgba(148, 163, 184, 0.14);
        }

        .dk-language-option.active {
            color: #03131d;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
        }

        .dk-language-option .check {
            width: 18px;
            opacity: 0;
        }

        .dk-language-option.active .check {
            opacity: 1;
        }

        .dk-icon-btn {
            flex: 0 0 auto;
            width: 42px;
            height: 42px;
            color: var(--muted);
            background: rgba(148, 163, 184, 0.10);
            border-color: var(--border);
        }

        .dk-icon-btn:hover {
            color: var(--text);
            transform: translateY(-1px);
            background: rgba(148, 163, 184, 0.16);
        }

        .dk-btn {
            flex: 0 0 auto;
            min-height: 42px;
            padding: 0 16px;
            font-size: 13px;
            border-color: var(--border);
            color: var(--text);
            background: rgba(148, 163, 184, 0.10);
        }

        .dk-btn:hover {
            transform: translateY(-1px);
            color: var(--text);
            box-shadow: 0 14px 36px rgba(0, 0, 0, 0.18);
        }

        .dk-btn-primary {
            color: #03131d;
            border: none;
            background: linear-gradient(135deg, var(--accent), var(--accent-2));
            box-shadow: 0 18px 46px rgba(52, 211, 153, 0.22);
        }

        .dk-btn-primary:hover {
            color: #03131d;
        }

        .dk-btn-ghost {
            background: rgba(255,255,255,0.06);
            border-color: var(--border);
        }

        .dk-main {
            min-height: calc(100vh - 132px);
            padding: 34px 0 58px;
        }

        .dk-alert-stack {
            display: grid;
            gap: 12px;
            margin-bottom: 18px;
        }

        .dk-alert {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 18px;
            border-radius: 20px;
            border: 1px solid var(--border);
            color: var(--text);
            background: var(--surface);
            box-shadow: 0 14px 40px rgba(0, 0, 0, 0.14);
        }

        .dk-alert i {
            width: 22px;
            text-align: center;
        }

        .dk-alert.success {
            border-color: rgba(52, 211, 153, 0.28);
            background: rgba(52, 211, 153, 0.12);
        }

        .dk-alert.success i {
            color: var(--accent);
        }

        .dk-alert.error {
            border-color: rgba(251, 113, 133, 0.28);
            background: rgba(251, 113, 133, 0.12);
        }

        .dk-alert.error i {
            color: var(--danger);
        }

        .dk-alert.debug {
            border-color: rgba(251, 191, 36, 0.32);
            background: rgba(251, 191, 36, 0.12);
        }

        .dk-alert.debug i {
            color: var(--warning);
        }

        .dk-alert a {
            color: var(--accent-2);
            font-weight: 900;
            word-break: break-all;
        }

        .dk-alert .btn-close {
            margin-left: auto;
            filter: invert(1);
            opacity: .72;
        }

        html[data-theme="light"] .dk-alert .btn-close {
            filter: none;
        }

        .dk-footer {
            border-top: 1px solid var(--border);
            padding: 28px 0;
            color: var(--muted);
            text-align: center;
            background: rgba(6, 17, 31, 0.38);
        }

        html[data-theme="light"] .dk-footer {
            background: rgba(255, 255, 255, 0.45);
        }

        .dk-footer strong {
            color: var(--text);
        }


        @@media (max-width: 1680px) {
            .dk-navbar {
                grid-template-columns: 208px minmax(0, 1fr) auto;
                gap: 8px;
            }

            .dk-nav-center {
                gap: 5px;
            }

            .dk-nav-link {
                padding: 0 9px;
                font-size: 12px;
            }

            .dk-language-btn {
                min-width: 122px;
                max-width: 122px;
                padding: 0 10px;
                font-size: 12px;
            }

            .dk-language-btn span {
                max-width: 60px;
            }

            .dk-premium-pill {
                padding: 0 8px;
                font-size: 11px;
            }

            .dk-nav-actions form .dk-btn {
                width: 42px;
                padding: 0;
            }

            .dk-nav-actions form .dk-btn span {
                display: none;
            }
        }

        @@media (max-width: 1380px) {
            .dk-navbar {
                grid-template-columns: 205px minmax(0, 1fr) auto;
            }

            .dk-brand-text {
                font-size: 16px;
            }

            .dk-nav-link {
                min-height: 38px;
                padding: 0 10px;
                font-size: 12px;
            }

            .dk-nav-link i {
                font-size: 12px;
            }

            .dk-language-btn {
                min-width: 132px;
                max-width: 142px;
                font-size: 12px;
            }

            .dk-btn {
                padding: 0 13px;
                font-size: 12px;
            }
        }

        @@media (max-width: 1120px) {
            .dk-navbar {
                min-height: auto;
                padding: 12px 0;
                grid-template-columns: 1fr auto;
                grid-template-areas:
                    "brand actions"
                    "menu menu";
                gap: 8px 12px;
            }

            .dk-brand {
                grid-area: brand;
            }

            .dk-nav-center {
                grid-area: menu;
                justify-content: flex-start;
                width: 100%;
                padding-bottom: 2px;
            }

            .dk-nav-actions {
                grid-area: actions;
            }
        }

        @@media (max-width: 760px) {
            .dk-shell {
                width: min(100% - 20px, 1660px);
            }

            .dk-brand-text {
                display: none;
            }

            .dk-brand-icon {
                width: 44px;
                height: 44px;
                min-width: 44px;
            }

            .dk-navbar {
                grid-template-columns: auto minmax(0, 1fr);
            }

            .dk-nav-actions {
                overflow-x: auto;
                scrollbar-width: none;
                justify-content: flex-end;
            }

            .dk-nav-actions::-webkit-scrollbar {
                display: none;
            }

            .dk-nav-link span,
            .dk-btn span {
                display: none;
            }

            .dk-nav-link {
                width: 40px;
                padding: 0;
            }

            .dk-language-btn {
                min-width: 112px;
                width: 112px;
                padding: 0 10px;
            }

            .dk-language-btn span {
                max-width: 64px;
            }

            .dk-language-menu {
                min-width: 190px;
            }

            .dk-btn {
                width: 42px;
                padding: 0;
            }
        }
    </style>
</head>

<body>
    <header class="dk-navbar-wrap">
        <div class="dk-shell dk-navbar">
            <a asp-area="DuKhach" asp-controller="Home" asp-action="Index" asp-route-lang="@selectedLanguageCode" class="dk-brand">
                <span class="dk-brand-icon">
                    <i class="fa-solid fa-location-dot"></i>
                </span>

                <span class="dk-brand-text">
                    VERSA Travel
                    <small>Smart Tour Guide</small>
                </span>
            </a>

            <nav class="dk-nav-center" aria-label="Điều hướng du khách">
                <a asp-area="DuKhach" asp-controller="Home" asp-action="Index" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isHome ? "active" : "")">
                    <i class="fa-solid fa-house"></i>
                    <span data-i18n="navHome">Trang chủ</span>
                </a>

                <a asp-area="DuKhach" asp-controller="Map" asp-action="Index" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isMap ? "active" : "")">
                    <i class="fa-solid fa-map-location-dot"></i>
                    <span data-i18n="navMap">Bản đồ</span>
                </a>

                <a asp-area="DuKhach" asp-controller="Qr" asp-action="Scan" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isQr ? "active" : "")">
                    <i class="fa-solid fa-qrcode"></i>
                    <span data-i18n="navScanQr">Quét QR</span>
                </a>

                <a asp-area="DuKhach" asp-controller="Tour" asp-action="Index" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isTour ? "active" : "")">
                    <i class="fa-solid fa-route"></i>
                    <span data-i18n="navTour">Tour</span>
                </a>

                <a asp-area="DuKhach" asp-controller="Leaderboard" asp-action="Index" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isLeaderboard ? "active" : "")">
                    <i class="fa-solid fa-ranking-star"></i>
                    <span data-i18n="navRanking">Xếp hạng</span>
                </a>

                <a asp-area="DuKhach" asp-controller="Payments" asp-action="Plans" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isPayments ? "active" : "")">
                    <i class="fa-solid fa-crown"></i>
                    <span data-i18n="navPlans">Gói dịch vụ</span>
                </a>

                <a asp-area="DuKhach" asp-controller="MenuOrders" asp-action="My" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isOrders ? "active" : "")">
                    <i class="fa-solid fa-receipt"></i>
                    <span data-i18n="navOrders">Đơn hàng</span>
                </a>
            </nav>

            <div class="dk-nav-actions">
                <div class="dropdown dk-language" data-no-i18n="true">
                    <button class="dk-language-btn dropdown-toggle"
                            type="button"
                            id="dkLanguageDropdown"
                            data-bs-toggle="dropdown"
                            aria-expanded="false"
                            title="Chọn ngôn ngữ thuyết minh">
                        <i class="fa-solid fa-language"></i>
                        <span id="dkLanguageCurrent" data-language-native="true">@selectedLanguageName</span>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end dk-language-menu" aria-labelledby="dkLanguageDropdown">
                        @foreach (var language in languageOptions)
                        {
                            var isSelected = string.Equals(language.Code, selectedLanguageCode, StringComparison.OrdinalIgnoreCase);

                            <li>
                                <button type="button"
                                        class="dk-language-option @(isSelected ? "active" : "")"
                                        data-lang="@language.Code"
                                        data-name="@language.Name"
                                        data-language-native="true">
                                    <i class="fa-solid fa-check check"></i>
                                    <span data-language-native="true">@language.Name</span>
                                </button>
                            </li>
                        }
                    </ul>
                </div>

                <button type="button" class="dk-icon-btn" id="dkThemeToggle" title="Đổi giao diện">
                    <i class="fa-solid fa-moon"></i>
                </button>

                @if (isTourist)
                {
                    <a asp-area="DuKhach" asp-controller="Account" asp-action="Profile" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isAccount ? "active" : "")" title="@touristEmail">
                        <i class="fa-solid fa-user"></i>
                        <span>@touristDisplayName</span>
                    </a>

                    @if (hasDuKhachPremium)
                    {
                        <span class="dk-premium-pill" title="Du khách Premium đang hoạt động">
                            <i class="fa-solid fa-crown"></i> Premium
                        </span>
                    }

                    <form asp-area="DuKhach" asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="dk-btn dk-btn-ghost" title="Đăng xuất">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span data-i18n="navLogout">Đăng xuất</span>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-area="DuKhach" asp-controller="Account" asp-action="Login" asp-route-lang="@selectedLanguageCode" class="dk-nav-link @(isAccount && currentAction == "Login" ? "active" : "")">
                        <i class="fa-solid fa-right-to-bracket"></i>
                        <span data-i18n="navLogin">Đăng nhập</span>
                    </a>

                    <a asp-area="DuKhach" asp-controller="Account" asp-action="Register" asp-route-lang="@selectedLanguageCode" class="dk-btn dk-btn-primary">
                        <i class="fa-solid fa-user-plus"></i>
                        <span data-i18n="navRegister">Đăng ký</span>
                    </a>
                }
            </div>
        </div>
    </header>

    <main class="dk-main">
        <div class="dk-shell">
            <div class="dk-alert-stack">
                @if (TempData["DuKhachSuccessMessage"] is string successMessage)
                {
                    <div class="dk-alert success" role="alert">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>@successMessage</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                    </div>
                }

                @if (TempData["DuKhachErrorMessage"] is string errorMessage)
                {
                    <div class="dk-alert error" role="alert">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span>@errorMessage</span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                    </div>
                }

                @if (TempData["DuKhachDebugResetLink"] is string debugResetLink)
                {
                    <div class="dk-alert debug" role="alert">
                        <i class="fa-solid fa-triangle-exclamation"></i>
                        <span>
                            Link reset local:
                            <a href="@debugResetLink">@debugResetLink</a>
                        </span>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                    </div>
                }
            </div>

            @RenderBody()
        </div>
    </main>

    <footer class="dk-footer">
        <div class="dk-shell">
            <strong>VERSA Travel</strong> · <span data-i18n="footerText">Bản đồ tham quan, tài khoản du khách và trải nghiệm dùng chung với app mobile.</span>
        </div>
    </footer>

    @await Html.PartialAsync("_AiChatBox")

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            const html = document.documentElement;
            const button = document.getElementById('dkThemeToggle');

            const saved = localStorage.getItem('versa-dukhach-theme') || 'dark';
            html.setAttribute('data-theme', saved);

            function updateIcon() {
                if (!button) return;

                const theme = html.getAttribute('data-theme');

                button.innerHTML = theme === 'dark'
                    ? '<i class="fa-solid fa-moon"></i>'
                    : '<i class="fa-solid fa-sun"></i>';
            }

            updateIcon();

            button?.addEventListener('click', function () {
                const current = html.getAttribute('data-theme') || 'dark';
                const next = current === 'dark' ? 'light' : 'dark';

                html.setAttribute('data-theme', next);
                localStorage.setItem('versa-dukhach-theme', next);
                updateIcon();
            });
        })();

        (function () {
            const languageButtons = document.querySelectorAll('.dk-language-option');
            const currentLabel = document.getElementById('dkLanguageCurrent');

            const cultureMap = {
                vi: 'vi',
                en: 'en',
                fr: 'fr',
                zh: 'zh-CN',
                ja: 'ja',
                ko: 'ko',
                th: 'th-TH',
                de: 'de-DE',
                es: 'es-ES',
                it: 'it-IT',
                pt: 'pt-PT',
                ru: 'ru-RU'
            };

            function normalizeLang(value) {
                return String(value || 'vi').trim().toLowerCase();
            }

            function persistLanguage(lang) {
                const normalizedLang = normalizeLang(lang);
                const expires = new Date();
                expires.setFullYear(expires.getFullYear() + 1);

                localStorage.setItem('versa-dukhach-lang', normalizedLang);
                document.cookie = `versa.dukhach.lang=${encodeURIComponent(normalizedLang)}; expires=${expires.toUTCString()}; path=/; samesite=lax`;

                const culture = cultureMap[normalizedLang] || normalizedLang;
                document.cookie = `.AspNetCore.Culture=c=${encodeURIComponent(culture)}|uic=${encodeURIComponent(culture)}; expires=${expires.toUTCString()}; path=/; samesite=lax`;
            }

            function setLanguageUi(lang, name) {
                const normalizedLang = normalizeLang(lang);
                const resolvedName = name || document.querySelector(`.dk-language-option[data-lang="${CSS.escape(normalizedLang)}"]`)?.dataset.name || normalizedLang.toUpperCase();

                if (currentLabel) currentLabel.textContent = resolvedName;

                languageButtons.forEach(button => {
                    const isActive = normalizeLang(button.dataset.lang) === normalizedLang;
                    button.classList.toggle('active', isActive);
                });

                document.querySelectorAll('[data-map-language-current]').forEach(label => {
                    label.textContent = resolvedName;
                });

                document.querySelectorAll('.map-language-option').forEach(button => {
                    const isActive = normalizeLang(button.dataset.lang) === normalizedLang;
                    button.classList.toggle('active', isActive);
                });

                window.VERSA_DUKHACH_LANG = normalizedLang;
                window.VERSA_DUKHACH_LANG_NAME = resolvedName;
            }

            function syncTouristLinks(lang) {
                const normalizedLang = normalizeLang(lang);

                document.querySelectorAll('a[href]').forEach(anchor => {
                    const rawHref = anchor.getAttribute('href');
                    if (!rawHref || rawHref.startsWith('#') || rawHref.startsWith('javascript:') || rawHref.startsWith('mailto:') || rawHref.startsWith('tel:')) return;

                    try {
                        const url = new URL(rawHref, window.location.origin);
                        if (url.origin !== window.location.origin) return;

                        const isTouristLink = url.pathname === '/' || url.pathname.toLowerCase().startsWith('/dukhach');
                        if (!isTouristLink) return;

                        url.searchParams.set('lang', normalizedLang);
                        anchor.setAttribute('href', `${url.pathname}${url.search}${url.hash}`);
                    } catch (e) {
                        // Bỏ qua href không hợp lệ.
                    }
                });
            }

            function changeLanguage(lang, name) {
                if (!lang) return;

                const normalizedLang = normalizeLang(lang);
                const resolvedName = name || normalizedLang.toUpperCase();

                persistLanguage(normalizedLang);
                setLanguageUi(normalizedLang, resolvedName);
                syncTouristLinks(normalizedLang);

                window.dispatchEvent(new CustomEvent('versa-dukhach-language-changed', {
                    detail: { lang: normalizedLang, name: resolvedName, source: 'navbar' }
                }));

                const url = new URL(window.location.href);
                url.searchParams.set('lang', normalizedLang);
                window.location.href = url.toString();
            }

            languageButtons.forEach(button => {
                button.addEventListener('click', function () {
                    changeLanguage(
                        this.dataset.lang || 'vi',
                        this.dataset.name || this.textContent.trim()
                    );
                });
            });

            window.addEventListener('versa-dukhach-language-changed', function (event) {
                const detail = event.detail || {};
                if (!detail.lang || detail.source === 'navbar') return;

                const normalizedLang = normalizeLang(detail.lang);
                const resolvedName = detail.name || normalizedLang.toUpperCase();

                persistLanguage(normalizedLang);
                setLanguageUi(normalizedLang, resolvedName);
                syncTouristLinks(normalizedLang);
            });

            syncTouristLinks('@selectedLanguageCode');
        })();
    </script>

    <script>
        window.VERSA_DUKHACH_LANG = @Html.Raw(JsonSerializer.Serialize(selectedLanguageCode));
        window.VERSA_DUKHACH_LANG_NAME = @Html.Raw(JsonSerializer.Serialize(selectedLanguageName));
    </script>

<script src="~/js/dukhach-i18n.js" asp-append-version="true"></script> 
    <script src="~/js/dukhach-ai-chat.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>