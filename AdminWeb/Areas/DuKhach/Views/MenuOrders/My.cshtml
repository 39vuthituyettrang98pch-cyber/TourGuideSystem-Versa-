@model IEnumerable<AdminWeb.Models.MenuOrder>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="order-hero" style="border:1px solid var(--border);border-radius:34px;padding:32px;background:var(--surface);box-shadow:var(--shadow);margin-bottom:22px;">
    <div class="dk-kicker"><i class="fa-solid fa-receipt"></i> Đơn menu</div>
    <h1 style="font-weight:950;letter-spacing:-.04em;margin:8px 0;">Đơn hàng của tôi</h1>
    <p style="color:var(--muted);">Theo dõi các món/sản phẩm bạn đã đặt tại gian hàng trong hệ thống.</p>
</div>

@if (!Model.Any())
{
    <div style="border:1px solid var(--border);border-radius:28px;background:var(--card);padding:24px;">Bạn chưa có đơn hàng nào.</div>
}
else
{
    <div style="display:grid;gap:14px;">
        @foreach (var order in Model)
        {
            var poiName = order.Poi?.Translations.FirstOrDefault(t => t.LanguageCode == "vi")?.Name
                ?? order.Poi?.Translations.FirstOrDefault()?.Name
                ?? $"POI #{order.PoiId}";
            <a asp-action="Details" asp-route-id="@order.Id" style="display:block;border:1px solid var(--border);border-radius:24px;background:var(--card);padding:18px;box-shadow:0 14px 40px rgba(0,0,0,.12);">
                <div style="display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap;">
                    <div>
                        <strong style="font-size:18px;">@order.OrderCode</strong>
                        <div style="color:var(--muted);margin-top:4px;">@poiName · @order.Items.Count món</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-weight:950;color:var(--accent);">@order.TotalAmount.ToString("N0") @order.Currency</div>
                        <span class="badge bg-secondary">@order.Status</span>
                    </div>
                </div>
            </a>
        }
    </div>
}
