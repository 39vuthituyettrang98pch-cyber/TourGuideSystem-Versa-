@model AdminWeb.Models.OwnerProfile
@{
    ViewData["Title"] = "Sửa chủ gian hàng";
}

<div class="page-heading"><div><div class="page-title">Sửa chủ gian hàng</div><div class="page-subtitle">Cập nhật hồ sơ và trạng thái owner.</div></div></div>
<div class="card" style="padding:26px;">
    <form asp-area="" asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <div class="form-grid">
            <div class="form-group"><label class="form-label">Tài khoản</label><input class="form-control" value="@Model.User?.Username" disabled /></div>
            <div class="form-group"><label class="form-label">Email</label><input class="form-control" value="@Model.User?.Email" disabled /></div>
            <div class="form-group"><label class="form-label">Trạng thái đăng nhập</label><input class="form-control" value="@Model.User?.Status" disabled /></div>
            <div class="form-group"><label class="form-label">Tên gian hàng</label><input name="businessName" class="form-control" value="@Model.BusinessName" required /></div>
            <div class="form-group"><label class="form-label">Người đại diện</label><input name="representativeName" class="form-control" value="@Model.RepresentativeName" /></div>
            <div class="form-group"><label class="form-label">SĐT</label><input name="phone" class="form-control" value="@Model.Phone" /></div>
            <div class="form-group"><label class="form-label">Địa chỉ</label><input name="address" class="form-control" value="@Model.Address" /></div>
            <div class="form-group"><label class="form-label">Trạng thái</label><select name="status" class="form-control"><option value="Active" selected="@(Model.Status == "Active")">Active</option><option value="Pending" selected="@(Model.Status == "Pending")">Pending</option><option value="Locked" selected="@(Model.Status == "Locked")">Locked</option></select></div>
        </div>
        <div style="display:flex;gap:10px;margin-top:18px;"><button class="btn btn-primary">Lưu</button><a asp-area="" asp-action="Index" class="btn btn-secondary">Quay lại</a></div>
    </form>
</div>
