@model AdminWeb.Models.Poi

@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = "Quản lý Media";
    var poiName = Model.Translations?.FirstOrDefault(t => t.LanguageCode == "vi")?.Name ?? $"POI #{Model.Id}";
}

<div class="page-title">Thư viện Media - @poiName</div>
<div class="page-subtitle">Quản lý hình ảnh và video trình chiếu cho điểm tham quan này.</div>

<div class="toolbar">
    <a asp-area="@currentArea" asp-controller="Poi" asp-action="Index" class="btn btn-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Quay lại danh sách POI</a>
</div>

<div style="display: flex; flex-wrap: wrap; gap: 24px; margin-top: 24px;">
    <!-- Form tải lên -->
    <div class="card" style="flex: 1; min-width: 300px; max-width: 400px; height: fit-content;">
        <div class="card-header"><div class="card-title">Tải lên Media mới</div></div>
        <div class="card-body" style="padding: 20px;">
            <form asp-area="@currentArea" asp-action="UploadMedia" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="poiId" value="@Model.Id" />
                
                <div class="form-group" style="margin-bottom: 16px;">
                    <label class="form-label" style="display: block; margin-bottom: 8px; color: var(--text2); font-size: 13px;">Chọn file (Hình ảnh / Video)</label>
                    <input class="form-control" type="file" name="mediaFile" accept="image/*,video/*" required style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--text);" />
                </div>
                
                <div class="form-group" style="margin-bottom: 24px;">
                    <label class="form-label" style="display: block; margin-bottom: 8px; color: var(--text2); font-size: 13px;">Thứ tự hiển thị</label>
                    <input class="form-control" type="number" name="sortOrder" value="0" required style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--text);" />
                </div>
                
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px; border-radius: 8px; font-weight: 600; cursor: pointer;"><i class="fa-solid fa-cloud-arrow-up"></i> Tải lên</button>
            </form>
        </div>
    </div>

    <!-- Danh sách Media -->
    <div class="card" style="flex: 2; min-width: 300px;">
        <div class="card-header"><div class="card-title">Danh sách Media hiện tại</div></div>
        <div class="card-body" style="padding: 20px;">
            @if (Model.MediaAssets != null && Model.MediaAssets.Any())
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px;">
                    @foreach (var media in Model.MediaAssets.OrderBy(m => m.SortOrder))
                    {
                        <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; overflow: hidden; position: relative;">
                            @if (media.MediaType == "video")
                            {
                                <video src="@media.MediaUrl" style="width: 100%; height: 150px; object-fit: cover;" controls></video>
                                <div style="position: absolute; top: 8px; left: 8px; background: rgba(0,0,0,0.6); padding: 4px 8px; border-radius: 6px; font-size: 11px;"><i class="fa-solid fa-video"></i> Video</div>
                            }
                            else
                            {
                                <img src="@media.MediaUrl" alt="Media" style="width: 100%; height: 150px; object-fit: cover;" />
                                <div style="position: absolute; top: 8px; left: 8px; background: rgba(0,0,0,0.6); padding: 4px 8px; border-radius: 6px; font-size: 11px;"><i class="fa-solid fa-image"></i> Hình ảnh</div>
                            }
                            <div style="padding: 12px; display: flex; justify-content: space-between; align-items: center;">
                                <div style="font-size: 12px; color: var(--text2);">Thứ tự: <strong>@media.SortOrder</strong></div>
                                @if (isAdmin)
                                {
                                <form asp-area="@currentArea" asp-action="DeleteMedia" method="post" style="margin: 0;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa file media này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@media.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" style="padding: 6px 10px;" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                                </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 40px 20px; color: var(--text2);">
                    <i class="fa-solid fa-photo-film" style="font-size: 32px; margin-bottom: 12px; opacity: 0.5;"></i>
                    <p>Chưa có file hình ảnh hay video nào được tải lên cho POI này.</p>
                </div>
            }
        </div>
    </div>
</div>
