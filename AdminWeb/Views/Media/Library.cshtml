@model IEnumerable<AdminWeb.Models.MediaAsset>

@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = "Thư viện Media tổng hợp";
}

<div class="page-title">Thư viện Media tổng hợp</div>
<div class="page-subtitle">Quản lý toàn bộ hình ảnh và video của tất cả Điểm tham quan.</div>

<div class="toolbar">
    <div>
        <form asp-area="@currentArea" asp-action="Library" method="get" style="display: flex; gap: 8px;">
            <select name="poiId" class="form-control" style="padding: 6px 12px; width: 250px; font-size: 13px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: var(--text); border-radius: 8px;" onchange="this.form.submit()">
                <option value="">-- Tất cả Điểm tham quan --</option>
                @if (ViewBag.Pois != null)
                {
                    foreach (var p in (IEnumerable<AdminWeb.Models.Poi>)ViewBag.Pois)
                    {
                        var pName = p.Translations?.FirstOrDefault(t => t.LanguageCode == "vi")?.Name ?? $"POI #{p.Id}";
                        if (ViewBag.SelectedPoiId == p.Id) {
                            <!option value="@p.Id" selected>@pName</!option>
                        } else {
                            <!option value="@p.Id">@pName</!option>
                        }
                    }
                }
            </select>
            @if (ViewBag.SelectedPoiId != null)
            {
                <a asp-area="@currentArea" asp-action="Library" class="btn btn-secondary btn-sm" title="Xóa bộ lọc"><i class="fa-solid fa-xmark"></i></a>
            }
        </form>
    </div>
</div>

<div style="display: flex; flex-wrap: wrap; gap: 24px; margin-top: 24px;">
    <div class="card" style="flex: 1; min-width: 300px; max-width: 400px; height: fit-content;">
        <div class="card-header"><div class="card-title">Tải lên Media mới</div></div>
        <div class="card-body" style="padding: 20px;">
            <form asp-area="@currentArea" asp-action="UploadMedia" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="form-group" style="margin-bottom: 16px;">
                    <label class="form-label" style="display: block; margin-bottom: 8px; color: var(--text2); font-size: 13px;">Chọn Điểm tham quan (POI)</label>
                    <select class="form-control" name="poiId" required style="width: 100%; padding: 12px; border-radius: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--text);">
                        <option value="">-- Chọn POI --</option>
                        @if (ViewBag.Pois != null) {
                            foreach (var p in (IEnumerable<AdminWeb.Models.Poi>)ViewBag.Pois) {
                                var pName = p.Translations?.FirstOrDefault(t => t.LanguageCode == "vi")?.Name ?? $"POI #{p.Id}";
                                if (ViewBag.SelectedPoiId == p.Id) { <!option value="@p.Id" selected>@pName</!option> } else { <!option value="@p.Id">@pName</!option> }
                            }
                        }
                    </select>
                </div>
                <div class="form-group" style="margin-bottom: 16px;">
                    <label class="form-label">Chọn file</label>
                    <input class="form-control" type="file" name="mediaFile" accept="image/*,video/*" required />
                </div>
                <div class="form-group" style="margin-bottom: 24px;">
                    <label class="form-label">Thứ tự hiển thị</label>
                    <input class="form-control" type="number" name="sortOrder" value="0" required />
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%;"><i class="fa-solid fa-cloud-arrow-up"></i> Tải lên</button>
            </form>
        </div>
    </div>

    <div class="card" style="flex: 2; min-width: 300px;">
        <div class="card-header"><div class="card-title">Tất cả Media</div></div>
        <div class="card-body" style="padding: 20px;">
            @if (Model != null && Model.Any()) {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px;">
                    @foreach (var media in Model) {
                        var poiName = media.Poi?.Translations?.FirstOrDefault(t => t.LanguageCode == "vi")?.Name ?? $"POI #{media.PoiId}";
                        <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; overflow: hidden; position: relative;">
                            @if (media.MediaType == "video") {
                                <video src="@media.MediaUrl" style="width: 100%; height: 150px; object-fit: cover;" controls></video>
                            } else {
                                <img src="@media.MediaUrl" style="width: 100%; height: 150px; object-fit: cover;" />
                            }
                            <div style="padding: 12px;">
                                <div style="font-size: 13px; font-weight: bold; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@poiName</div>
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
                                    <div style="font-size: 12px; color: var(--text2);">Thứ tự: <strong>@media.SortOrder</strong></div>
                                    @if (isAdmin)
                                    {
                                    <form asp-area="@currentArea" asp-action="DeleteMedia" method="post" style="margin: 0;" onsubmit="return confirm('Xóa file này?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@media.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" style="padding: 6px 10px;"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            } else {
                <div style="text-align: center; padding: 40px 20px; color: var(--text2);">Chưa có media nào.</div>
            }
        </div>
    </div>
</div>
