@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var pageTitle = ViewData["Title"]?.ToString() ?? currentController;

    var isHomeSection = currentController == "Home" && currentArea == "";
    var isPoiSection = currentController is "Poi" or "PoiTranslation";
    var isApprovalSection = currentController == "Approval";
    var isTourSection = currentController is "Tour" or "TourTranslation";
    var isCategorySection = currentController is "Category" or "CategoryTranslation";
    var isMediaSection = currentController == "Media";
    var isAudioTasksSection = currentController == "AudioTasks";
    var isAnalyticsSection = currentController == "Analytics";
    var isActivityLogSection = currentController == "ActivityLog";
    var isVisitorSection = currentController == "Visitor";
    var isReviewSection = currentController == "Review";
    var isBeaconSection = currentController == "Beacon";
    var isSyncSection = currentController == "SyncVersion";
    var isUserSection = currentController == "User";
    var isSettingSection = currentController == "Setting";
    var isLanguageSection = currentController == "Language";

    var userName = string.IsNullOrWhiteSpace(User.Identity?.Name)
        ? "Tài khoản"
        : User.Identity!.Name!;

    var userRole = User.IsInRole("Admin")
        ? "Quản trị viên"
        : User.IsInRole("Editor")
            ? "Biên tập viên"
            : User.IsInRole("Reviewer")
                ? "Kiểm duyệt viên"
                : "Nhân sự";

    var initials = userName.Trim().Length > 0
        ? userName.Trim()[0].ToString().ToUpperInvariant()
        : "U";
}

<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@pageTitle - VERSA Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />

    <style>
        .sidebar-logo {
            gap: 12px;
        }

        .logo-icon {
            box-shadow: 0 18px 45px rgba(91, 140, 255, 0.28);
        }

        .admin-mini-badge {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 8px;
            border-radius: 999px;
            color: #b8c8ff;
            background: rgba(91, 140, 255, 0.12);
            border: 1px solid rgba(91, 140, 255, 0.22);
            font-size: 11px;
            font-weight: 900;
            letter-spacing: .04em;
        }

        .sidebar-section-label {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sidebar-section-label::before {
            content: "";
            width: 6px;
            height: 6px;
            border-radius: 999px;
            background: rgba(143, 150, 176, 0.8);
        }

        .nav-item {
            position: relative;
            overflow: hidden;
        }

        .nav-item.active::before {
            content: "";
            position: absolute;
            left: 0;
            top: 12px;
            bottom: 12px;
            width: 3px;
            border-radius: 999px;
            background: #5b8cff;
        }

        .nav-item .nav-chip {
            margin-left: auto;
            min-width: 24px;
            height: 22px;
            padding: 0 7px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            color: #dce7ff;
            background: rgba(91, 140, 255, 0.14);
            border: 1px solid rgba(91, 140, 255, 0.20);
            font-size: 11px;
            font-weight: 900;
        }

        .header {
            backdrop-filter: blur(18px);
        }

        .header-title strong {
            letter-spacing: -0.035em;
        }

        .header-breadcrumb {
            display: flex;
            align-items: center;
            gap: 7px;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 800;
        }

        .header-breadcrumb i {
            font-size: 10px;
            opacity: .75;
        }

        .global-search {
            max-width: 560px;
        }

        .global-search button {
            border: 0;
            outline: 0;
            background: transparent;
            color: var(--text-muted);
            font-weight: 800;
            font-size: 12px;
        }

        .quick-action-bar {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .header-avatar {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 16px;
            color: #fff;
            background: linear-gradient(135deg, #5b8cff, #7c5cff);
            box-shadow: 0 14px 34px rgba(91, 140, 255, .22);
            font-weight: 950;
            border: 0;
        }

        .app-alert {
            border-radius: 18px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 10 padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 18px;
        }

        .app-alert .btn-close {
            margin-left: auto;
            filter: invert(1);
            opacity: .7;
        }

        html[data-theme="light"] .app-alert .btn-close {
            filter: none;
        }

        .app-dropdown {
            border-radius: 18px;
            overflow: hidden;
            padding: 8px;
        }

        .app-dropdown .dropdown-item {
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            padding: 10px 12px;
        }

        .mobile-brand {
            display: none;
            align-items: center;
            gap: 10px;
            font-weight: 950;
        }

        .mobile-brand span {
            width: 36px;
            height: 36px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            color: #fff;
            background: linear-gradient(135deg, #5b8cff, #7c5cff);
        }

        @@media (max-width: 980px) {
            .mobile-brand {
                display: flex;
            }

            .header-title {
                display: none;
            }

            .global-search {
                display: none;
            }
        }

        @@media (max-width: 620px) {
            .quick-action-bar .icon-btn:nth-child(2) {
                display: none;
            }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div class="app-layout">
        <div class="sidebar-overlay" data-sidebar-close></div>

        <aside class="sidebar" id="adminSidebar">
            <a class="sidebar-logo" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="logo-icon">
                    <i class="fa-solid fa-compass"></i>
                </span>

                <span class="logo-text">
                    VERSA <strong>ADMIN</strong>
                </span>

                <span class="admin-mini-badge">CMS</span>
            </a>

            <nav class="sidebar-nav">
                <div class="sidebar-section">
                    <div class="sidebar-section-label">Tổng quan</div>

                    <a class="nav-item @(isHomeSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Dashboard</span>
                    </a>

                    <a class="nav-item"
                       asp-area="DuKhach"
                       asp-controller="Home"
                       asp-action="Index"
                       target="_blank"
                       rel="noopener">
                        <i class="fa-solid fa-globe"></i>
                        <span>Web du khách</span>
                        <span class="nav-chip">
                            <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        </span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-label">Nội dung</div>

                    <a class="nav-item @(isPoiSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Poi"
                       asp-action="Index">
                        <i class="fa-solid fa-map-pin"></i>
                        <span>Điểm tham quan</span>
                    </a>

                    <a class="nav-item @(isTourSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Tour"
                       asp-action="Index">
                        <i class="fa-solid fa-route"></i>
                        <span>Tour du lịch</span>
                    </a>

                    <a class="nav-item @(isCategorySection ? "active" : "")"
                       asp-area=""
                       asp-controller="Category"
                       asp-action="Index">
                        <i class="fa-solid fa-tags"></i>
                        <span>Danh mục</span>
                    </a>

                    <a class="nav-item @(isMediaSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Media"
                       asp-action="Library">
                        <i class="fa-solid fa-photo-film"></i>
                        <span>Thư viện media</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-section-label">Vận hành</div>

                    <a class="nav-item @(isApprovalSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Approval"
                       asp-action="PoiPending">
                        <i class="fa-solid fa-circle-check"></i>
                        <span>Duyệt POI</span>
                    </a>

                    <a class="nav-item @(isAudioTasksSection ? "active" : "")"
                       asp-area=""
                       asp-controller="AudioTasks"
                       asp-action="Index">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                        <span>Tác vụ AI Media</span>
                    </a>

                    <a class="nav-item @(isAnalyticsSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Analytics"
                       asp-action="Index">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Phân tích</span>
                    </a>

                    <a class="nav-item @(isActivityLogSection ? "active" : "")"
                       asp-area=""
                       asp-controller="ActivityLog"
                       asp-action="Index">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        <span>Lịch sử phát</span>
                    </a>

                    <a class="nav-item @(isReviewSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Review"
                       asp-action="Index">
                        <i class="fa-solid fa-star-half-stroke"></i>
                        <span>Đánh giá POI</span>
                    </a>

                    <a class="nav-item @(isVisitorSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Visitor"
                       asp-action="Index">
                        <i class="fa-solid fa-users"></i>
                        <span>Du khách</span>
                    </a>

                    <a class="nav-item @(isBeaconSection ? "active" : "")"
                       asp-area=""
                       asp-controller="Beacon"
                       asp-action="Index">
                        <i class="fa-solid fa-tower-broadcast"></i>
                        <span>Beacon BLE</span>
                    </a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-section">
                        <div class="sidebar-section-label">Hệ thống</div>

                        <a class="nav-item @(isSyncSection ? "active" : "")"
                           asp-area=""
                           asp-controller="SyncVersion"
                           asp-action="Index">
                            <i class="fa-solid fa-box-archive"></i>
                            <span>Gói đồng bộ</span>
                        </a>

                        <a class="nav-item @(isUserSection ? "active" : "")"
                           asp-area=""
                           asp-controller="User"
                           asp-action="Index">
                            <i class="fa-solid fa-user-shield"></i>
                            <span>Tài khoản & phân quyền</span>
                        </a>

                        <a class="nav-item @(isSettingSection ? "active" : "")"
                           asp-area=""
                           asp-controller="Setting"
                           asp-action="Index">
                            <i class="fa-solid fa-gear"></i>
                            <span>Cài đặt hệ thống</span>
                        </a>

                        <a class="nav-item @(isLanguageSection ? "active" : "")"
                           asp-area=""
                           asp-controller="Language"
                           asp-action="Index">
                            <i class="fa-solid fa-language"></i>
                            <span>Ngôn ngữ & giọng đọc</span>
                        </a>
                    </div>
                }
            </nav>

            <div class="sidebar-footer dropdown">
                <button class="user-card" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="user-avatar">
                        @initials
                    </span>

                    <span class="user-info">
                        <span class="user-name">@userName</span>
                        <span class="user-role">@userRole</span>
                    </span>

                    <i class="fa-solid fa-chevron-up user-chevron"></i>
                </button>

                <ul class="dropdown-menu app-dropdown">
                    <li>
                        <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                            <i class="fa-solid fa-id-badge"></i>
                            Hồ sơ
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="ChangePassword">
                            <i class="fa-solid fa-key"></i>
                            Đổi mật khẩu
                        </a>
                    </li>

                    <li>
                        <a class="dropdown-item"
                           asp-area="DuKhach"
                           asp-controller="Home"
                           asp-action="Index"
                           target="_blank"
                           rel="noopener">
                            <i class="fa-solid fa-globe"></i>
                            Mở web du khách
                        </a>
                    </li>

                    <li>
                        <hr class="dropdown-divider" />
                    </li>

                    <li>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button class="dropdown-item text-danger" type="submit">
                                <i class="fa-solid fa-right-from-bracket"></i>
                                Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </aside>

        <main class="main">
            <header class="header">
                <button class="icon-btn sidebar-toggle" type="button" data-sidebar-toggle aria-label="Mở menu">
                    <i class="fa-solid fa-bars"></i>
                </button>

                <a class="mobile-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span>
                        <i class="fa-solid fa-compass"></i>
                    </span>
                    VERSA
                </a>

                <div class="header-title">
                    <div class="header-breadcrumb">
                        <span>VERSA Admin</span>
                        <i class="fa-solid fa-chevron-right"></i>
                        <span>@currentController</span>
                    </div>

                    <strong>@pageTitle</strong>
                </div>

                <form class="global-search" asp-area="" asp-controller="Poi" asp-action="Index" method="get">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="search"
                           name="searchString"
                           placeholder="Tìm nhanh điểm tham quan..."
                           aria-label="Tìm POI" />
                    <button type="submit">Enter</button>
                </form>

                <div class="header-actions quick-action-bar">
                    <a class="icon-btn"
                       title="Tạo POI nhanh"
                       asp-area=""
                       asp-controller="Poi"
                       asp-action="Create">
                        <i class="fa-solid fa-plus"></i>
                    </a>

                    <a class="icon-btn"
                       title="Duyệt POI"
                       asp-area=""
                       asp-controller="Approval"
                       asp-action="PoiPending">
                        <i class="fa-solid fa-circle-check"></i>
                    </a>

                    <button type="button"
                            class="icon-btn"
                            id="theme-toggle"
                            title="Đổi giao diện sáng/tối"
                            aria-label="Đổi giao diện">
                        <i class="fa-solid fa-moon"></i>
                    </button>

                    <a class="icon-btn"
                       title="Tác vụ AI Media"
                       asp-area=""
                       asp-controller="AudioTasks"
                       asp-action="Index">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                    </a>

                    <div class="dropdown">
                        <button class="header-avatar" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            @initials
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end app-dropdown">
                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile">
                                    <i class="fa-solid fa-id-badge"></i>
                                    Hồ sơ
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="ChangePassword">
                                    <i class="fa-solid fa-key"></i>
                                    Đổi mật khẩu
                                </a>
                            </li>

                            <li>
                                <hr class="dropdown-divider" />
                            </li>

                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="dropdown-item text-danger" type="submit">
                                        <i class="fa-solid fa-right-from-bracket"></i>
                                        Đăng xuất
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <div class="content">
                <div class="content-inner">
                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert app-alert success" role="alert">
                            <i class="fa-solid fa-circle-check"></i>
                            <span>@successMessage</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] is string errorMessage)
                    {
                        <div class="alert app-alert error" role="alert">
                            <i class="fa-solid fa-circle-exclamation"></i>
                            <span>@errorMessage</span>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (() => {
            const root = document.documentElement;
            const sidebar = document.getElementById('adminSidebar');
            const toggle = document.querySelector('[data-sidebar-toggle]');
            const closeTargets = document.querySelectorAll('[data-sidebar-close]');
            const themeToggle = document.getElementById('theme-toggle');

            const applyTheme = theme => {
                root.dataset.theme = theme;

                const icon = themeToggle?.querySelector('i');

                if (icon) {
                    icon.classList.toggle('fa-sun', theme === 'light');
                    icon.classList.toggle('fa-moon', theme !== 'light');
                }
            };

            const savedTheme = localStorage.getItem('versa-theme') || 'dark';
            applyTheme(savedTheme);

            themeToggle?.addEventListener('click', () => {
                const next = root.dataset.theme === 'light' ? 'dark' : 'light';
                localStorage.setItem('versa-theme', next);
                applyTheme(next);
            });

            toggle?.addEventListener('click', () => {
                document.body.classList.toggle('sidebar-open');
            });

            closeTargets.forEach(target => {
                target.addEventListener('click', () => {
                    document.body.classList.remove('sidebar-open');
                });
            });

            sidebar?.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    document.body.classList.remove('sidebar-open');
                });
            });

            document.addEventListener('keydown', event => {
                if (event.key === 'Escape') {
                    document.body.classList.remove('sidebar-open');
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>