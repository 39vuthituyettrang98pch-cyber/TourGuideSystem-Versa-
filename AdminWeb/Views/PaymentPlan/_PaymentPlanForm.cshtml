@model AdminWeb.Models.PaymentPlan
<div class="card" style="padding:26px;">
    <form method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="form-grid">
            <div class="form-group"><label asp-for="PlanCode" class="form-label">Mã gói</label><input asp-for="PlanCode" class="form-control" placeholder="OWNER_BASIC" /></div>
            <div class="form-group"><label asp-for="PlanName" class="form-label">Tên gói</label><input asp-for="PlanName" class="form-control" /></div>
            <div class="form-group"><label asp-for="Audience" class="form-label">Đối tượng</label><select asp-for="Audience" class="form-control"><option value="Owner">Chủ gian hàng</option><option value="Tourist">Người dùng</option><option value="Both">Cả hai</option></select></div>
            <div class="form-group"><label asp-for="Price" class="form-label">Giá VND</label><input asp-for="Price" type="number" step="1000" class="form-control" /></div>
            <div class="form-group"><label asp-for="DurationDays" class="form-label">Thời hạn ngày</label><input asp-for="DurationDays" type="number" class="form-control" /></div>
            <div class="form-group"><label class="form-label">Trạng thái</label><select asp-for="IsActive" class="form-control"><option value="true">Bật</option><option value="false">Tắt</option></select></div>
            <div class="form-group full"><label asp-for="Description" class="form-label">Mô tả</label><textarea asp-for="Description" class="form-control" rows="4"></textarea></div>
        </div>
        <div style="display:flex;gap:10px;margin-top:18px;"><button class="btn btn-primary">Lưu</button><a asp-area="" asp-action="Index" class="btn btn-secondary">Quay lại</a></div>
    </form>
</div>
