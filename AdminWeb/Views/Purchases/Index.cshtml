@model AdminWeb.ViewModels.AdminPurchaseDashboardViewModel
@using AdminWeb.Models

@{
    ViewData["Title"] = "Thống kê lượt mua gói";
    var selectedStatus = ViewBag.Status?.ToString() ?? "All";
    var selectedPayerType = ViewBag.PayerType?.ToString() ?? "All";
    var maxRevenue = Math.Max(1m, Model.Last14Days.Any() ? Math.Max(Model.Last14Days.Max(day => day.OwnerRevenue), Model.Last14Days.Max(day => day.TouristRevenue)) : 1m);
    var maxCount = Math.Max(1, Model.Last14Days.Any() ? Math.Max(Model.Last14Days.Max(day => day.OwnerPurchases), Model.Last14Days.Max(day => day.TouristPurchases)) : 1);

    string Money(decimal value) => value.ToString("N0") + " VND";
    string DateText(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-";
    string CustomerName(PaymentTransaction payment) => payment.PayerType == "Owner"
        ? payment.OwnerProfile?.BusinessName ?? payment.OwnerProfile?.User?.Username ?? "Chủ POI"
        : payment.Tourist?.FullName ?? payment.Tourist?.Email ?? "Du khách";
    string Contact(PaymentTransaction payment) => payment.PayerType == "Owner"
        ? payment.OwnerProfile?.User?.Email ?? payment.OwnerProfile?.User?.Username ?? "-"
        : payment.Tourist?.Email ?? "-";
}

<style>
    .purchase-hero{border:1px solid rgba(255,255,255,.1);border-radius:28px;padding:26px;margin-bottom:18px;background:radial-gradient(circle at top left,rgba(45,212,191,.25),transparent 38%),linear-gradient(135deg,rgba(18,25,45,.98),rgba(10,14,25,.98));box-shadow:0 24px 80px rgba(0,0,0,.25)}
    .purchase-hero h1{margin:0;font-size:36px;font-weight:950;letter-spacing:-.045em}.purchase-hero p{margin:10px 0 0;max-width:920px;color:var(--text-muted);font-weight:760}
    .purchase-filter{display:flex;flex-wrap:wrap;gap:10px;align-items:end;margin-top:18px}.purchase-filter label{display:block;color:var(--text-muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;margin-bottom:6px}
    .purchase-filter input,.purchase-filter select{border-radius:14px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);color:var(--text-primary);padding:11px 12px}.purchase-filter option{background:#111827;color:#fff}
    .purchase-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin-bottom:18px}.purchase-stat{border:1px solid rgba(255,255,255,.1);border-radius:24px;padding:18px;background:rgba(255,255,255,.055)}
    .purchase-stat i{width:36px;height:36px;border-radius:13px;display:inline-flex;align-items:center;justify-content:center;background:rgba(45,212,191,.14);color:#67e8f9;margin-bottom:12px}.purchase-stat span{display:block;color:var(--text-muted);font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.04em}.purchase-stat strong{display:block;margin-top:6px;font-size:27px;font-weight:950;letter-spacing:-.035em}.purchase-stat small{color:var(--text-muted);font-weight:800}
    .purchase-two{display:grid;grid-template-columns:1.1fr .9fr;gap:18px}.purchase-card{border:1px solid rgba(255,255,255,.1);border-radius:26px;padding:22px;background:rgba(255,255,255,.055);margin-bottom:18px}.purchase-card h2{font-size:24px;font-weight:950;letter-spacing:-.035em;margin-bottom:6px}.purchase-card p{color:var(--text-muted);font-weight:750}
    .purchase-bars{display:grid;gap:13px;margin-top:16px}.purchase-day{display:grid;grid-template-columns:74px 1fr 170px;gap:12px;align-items:center}.purchase-track{height:12px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden}.purchase-track span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#22c55e,#38bdf8)}.purchase-track.tourist span{background:linear-gradient(90deg,#a78bfa,#f472b6)}
    .purchase-tabs{display:grid;grid-template-columns:1fr 1fr;gap:18px}.purchase-table{width:100%;border-collapse:separate;border-spacing:0 10px}.purchase-table th{color:var(--text-muted);font-size:12px;text-transform:uppercase;letter-spacing:.04em;padding:0 12px}.purchase-table td{background:rgba(255,255,255,.045);border-top:1px solid rgba(255,255,255,.08);border-bottom:1px solid rgba(255,255,255,.08);padding:13px 12px;vertical-align:middle}.purchase-table td:first-child{border-left:1px solid rgba(255,255,255,.08);border-radius:16px 0 0 16px}.purchase-table td:last-child{border-right:1px solid rgba(255,255,255,.08);border-radius:0 16px 16px 0}
    .purchase-pill{display:inline-flex;align-items:center;border-radius:999px;padding:6px 10px;font-size:12px;font-weight:950;border:1px solid rgba(255,255,255,.13);background:rgba(255,255,255,.07)}.purchase-pill.paid{color:#86efac;background:rgba(34,197,94,.12);border-color:rgba(34,197,94,.25)}.purchase-pill.pending{color:#fde68a;background:rgba(245,158,11,.12);border-color:rgba(245,158,11,.25)}.purchase-pill.cancelled,.purchase-pill.failed{color:#fecaca;background:rgba(239,68,68,.12);border-color:rgba(239,68,68,.25)}
    .buyer-list{display:grid;gap:10px}.buyer-item{display:flex;justify-content:space-between;gap:12px;border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:13px;background:rgba(255,255,255,.04)}.buyer-item strong{display:block}.buyer-item small{color:var(--text-muted);font-weight:750}.buyer-amount{text-align:right;font-weight:950;color:#5eead4}
    @@media(max-width:1180px){.purchase-grid{grid-template-columns:repeat(2,1fr)}.purchase-two,.purchase-tabs{grid-template-columns:1fr}.purchase-day{grid-template-columns:1fr}}@@media(max-width:720px){.purchase-grid{grid-template-columns:1fr}.purchase-hero h1{font-size:30px}.purchase-table{min-width:760px}.purchase-table-wrap{overflow-x:auto}}
</style>

<section class="purchase-hero">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1>Thống kê lượt mua gói</h1>
            <p>Theo dõi riêng số lượt mua của <b>Du khách</b> và <b>Chủ POI</b>, doanh thu từng nhóm, trạng thái giao dịch, gói đang hoạt động và top người mua.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a href="/Admin/Revenue" class="btn btn-primary"><i class="fa-solid fa-chart-pie"></i> Doanh thu tổng</a>
            <a href="/Admin/Payment" class="btn btn-outline-light"><i class="fa-solid fa-money-check-dollar"></i> Giao dịch</a>
        </div>
    </div>

    <form method="get" class="purchase-filter">
        <div>
            <label>Từ ngày</label>
            <input type="date" name="from" value="@Model.FromDate.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label>Đến ngày</label>
            <input type="date" name="to" value="@Model.ToDate.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label>Nhóm mua</label>
            <select name="payerType">
                <option value="All" selected="@(selectedPayerType == "All")">Tất cả</option>
                <option value="Owner" selected="@(selectedPayerType == "Owner")">Chủ POI / Owner</option>
                <option value="Tourist" selected="@(selectedPayerType == "Tourist")">Du khách</option>
            </select>
        </div>
        <div>
            <label>Trạng thái</label>
            <select name="status">
                <option value="All" selected="@(selectedStatus == "All")">Tất cả</option>
                <option value="Paid" selected="@(selectedStatus == "Paid")">Paid</option>
                <option value="Pending" selected="@(selectedStatus == "Pending")">Pending</option>
                <option value="Cancelled" selected="@(selectedStatus == "Cancelled")">Cancelled</option>
                <option value="Rejected" selected="@(selectedStatus == "Rejected")">Rejected/Failed</option>
            </select>
        </div>
        <button class="btn btn-primary" type="submit"><i class="fa-solid fa-filter"></i> Lọc</button>
    </form>
</section>

<section class="purchase-grid">
    <div class="purchase-stat"><i class="fa-solid fa-cart-shopping"></i><span>Tổng lượt mua</span><strong>@Model.TotalPurchases</strong><small>@Model.PaidPurchases đã thanh toán</small></div>
    <div class="purchase-stat"><i class="fa-solid fa-store"></i><span>Chủ POI mua gói</span><strong>@Model.OwnerPurchaseCount</strong><small>@Model.OwnerPaidCount giao dịch Paid</small></div>
    <div class="purchase-stat"><i class="fa-solid fa-person-walking-luggage"></i><span>Du khách mua gói</span><strong>@Model.TouristPurchaseCount</strong><small>@Model.TouristPaidCount giao dịch Paid</small></div>
    <div class="purchase-stat"><i class="fa-solid fa-sack-dollar"></i><span>Tổng tiền đã thu</span><strong>@Money(Model.TotalRevenue)</strong><small>Owner + Du khách</small></div>
</section>

<section class="purchase-grid">
    <div class="purchase-stat"><i class="fa-solid fa-building-user"></i><span>Doanh thu Owner</span><strong>@Money(Model.OwnerRevenue)</strong><small>@Model.ActiveOwnerSubscriptions gói Owner đang hoạt động</small></div>
    <div class="purchase-stat"><i class="fa-solid fa-crown"></i><span>Doanh thu Du khách</span><strong>@Money(Model.TouristRevenue)</strong><small>@Model.ActiveTouristSubscriptions gói Premium đang hoạt động</small></div>
    <div class="purchase-stat"><i class="fa-solid fa-hourglass-half"></i><span>Giao dịch Pending</span><strong>@Model.PendingPurchases</strong><small>Cần tiếp tục thanh toán hoặc xác nhận</small></div>
    <div class="purchase-stat"><i class="fa-solid fa-ban"></i><span>Hủy / lỗi</span><strong>@(Model.CancelledPurchases + Model.FailedPurchases)</strong><small>@Model.CancelledPurchases hủy, @Model.FailedPurchases lỗi/từ chối</small></div>
</section>

<section class="purchase-two">
    <div class="purchase-card">
        <h2>Lượt mua 14 ngày gần đây</h2>
        <p>Phân biệt gói Owner và gói Du khách Premium.</p>
        <div class="purchase-bars">
            @foreach (var day in Model.Last14Days)
            {
                var ownerCountWidth = Math.Max(4, (int)Math.Round(day.OwnerPurchases * 100.0 / maxCount));
                var touristCountWidth = Math.Max(4, (int)Math.Round(day.TouristPurchases * 100.0 / maxCount));
                var ownerRevenueWidth = Math.Max(4, (int)Math.Round(day.OwnerRevenue * 100m / maxRevenue));
                var touristRevenueWidth = Math.Max(4, (int)Math.Round(day.TouristRevenue * 100m / maxRevenue));
                <div>
                    <div class="purchase-day">
                        <strong>@day.Date.ToString("dd/MM")</strong>
                        <div class="purchase-track"><span style="width:@ownerRevenueWidth%"></span></div>
                        <small>Owner: @day.OwnerPurchases lượt · @Money(day.OwnerRevenue)</small>
                    </div>
                    <div class="purchase-day mt-1">
                        <span></span>
                        <div class="purchase-track tourist"><span style="width:@touristRevenueWidth%"></span></div>
                        <small>Du khách: @day.TouristPurchases lượt · @Money(day.TouristRevenue)</small>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="purchase-card">
        <h2>Trạng thái giao dịch</h2>
        <p>Tình hình thanh toán gói dịch vụ.</p>
        <div class="purchase-grid" style="grid-template-columns:repeat(2,1fr);margin:16px 0 0;">
            <div class="purchase-stat"><span>Paid</span><strong>@Model.PaidPurchases</strong><small>Đã kích hoạt gói</small></div>
            <div class="purchase-stat"><span>Pending</span><strong>@Model.PendingPurchases</strong><small>Đang chờ</small></div>
            <div class="purchase-stat"><span>Cancelled</span><strong>@Model.CancelledPurchases</strong><small>Đã hủy</small></div>
            <div class="purchase-stat"><span>Failed</span><strong>@Model.FailedPurchases</strong><small>Lỗi/từ chối</small></div>
        </div>
    </div>
</section>

<section class="purchase-tabs">
    <div class="purchase-card">
        <h2>Gói Owner được mua</h2>
        <p>Thống kê theo từng gói chủ POI.</p>
        @if (Model.OwnerPlanRows.Count == 0)
        {
            <div class="text-muted fw-bold">Chưa có giao dịch Owner trong khoảng thời gian này.</div>
        }
        else
        {
            <div class="purchase-table-wrap">
                <table class="purchase-table">
                    <thead><tr><th>Gói</th><th>Paid</th><th>Pending</th><th>Đang hoạt động</th><th>Doanh thu</th></tr></thead>
                    <tbody>
                        @foreach (var row in Model.OwnerPlanRows)
                        {
                            <tr><td><strong>@row.PlanName</strong><br /><small class="text-muted">@row.PlanCode</small></td><td>@row.PaidCount</td><td>@row.PendingCount</td><td>@row.ActiveSubscriptions</td><td><strong>@Money(row.Revenue)</strong></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="purchase-card">
        <h2>Gói Du khách được mua</h2>
        <p>Thống kê gói Premium của du khách.</p>
        @if (Model.TouristPlanRows.Count == 0)
        {
            <div class="text-muted fw-bold">Chưa có giao dịch Du khách trong khoảng thời gian này.</div>
        }
        else
        {
            <div class="purchase-table-wrap">
                <table class="purchase-table">
                    <thead><tr><th>Gói</th><th>Paid</th><th>Pending</th><th>Đang hoạt động</th><th>Doanh thu</th></tr></thead>
                    <tbody>
                        @foreach (var row in Model.TouristPlanRows)
                        {
                            <tr><td><strong>@row.PlanName</strong><br /><small class="text-muted">@row.PlanCode</small></td><td>@row.PaidCount</td><td>@row.PendingCount</td><td>@row.ActiveSubscriptions</td><td><strong>@Money(row.Revenue)</strong></td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>

<section class="purchase-tabs">
    <div class="purchase-card">
        <h2>Top chủ POI mua gói</h2>
        <p>Xếp theo tổng tiền đã thanh toán.</p>
        <div class="buyer-list">
            @if (Model.TopOwnerBuyers.Count == 0)
            {
                <div class="text-muted fw-bold">Chưa có chủ POI mua gói.</div>
            }
            @foreach (var buyer in Model.TopOwnerBuyers)
            {
                <div class="buyer-item"><div><strong>@buyer.DisplayName</strong><small>@buyer.Contact · @buyer.PaidCount lượt mua · gần nhất @DateText(buyer.LastPaidAt)</small></div><div class="buyer-amount">@Money(buyer.TotalPaid)</div></div>
            }
        </div>
    </div>

    <div class="purchase-card">
        <h2>Top du khách mua Premium</h2>
        <p>Xếp theo tổng tiền đã thanh toán.</p>
        <div class="buyer-list">
            @if (Model.TopTouristBuyers.Count == 0)
            {
                <div class="text-muted fw-bold">Chưa có du khách mua Premium.</div>
            }
            @foreach (var buyer in Model.TopTouristBuyers)
            {
                <div class="buyer-item"><div><strong>@buyer.DisplayName</strong><small>@buyer.Contact · @buyer.PaidCount lượt mua · gần nhất @DateText(buyer.LastPaidAt)</small></div><div class="buyer-amount">@Money(buyer.TotalPaid)</div></div>
            }
        </div>
    </div>
</section>

<section class="purchase-card">
    <h2>Danh sách giao dịch gói</h2>
    <p>Giao dịch VNPay, MoMo, miễn phí hoặc xác nhận thủ công của cả Du khách và Chủ POI.</p>
    @if (Model.RecentTransactions.Count == 0)
    {
        <div class="text-muted fw-bold">Chưa có giao dịch trong khoảng thời gian này.</div>
    }
    else
    {
        <div class="purchase-table-wrap">
            <table class="purchase-table">
                <thead>
                    <tr><th>Mã giao dịch</th><th>Người mua</th><th>Loại</th><th>Gói</th><th>Cổng</th><th>Số tiền</th><th>Trạng thái</th><th>Ngày</th></tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.RecentTransactions)
                    {
                        var statusClass = payment.Status == "Paid" ? "paid" : payment.Status == "Pending" ? "pending" : payment.Status == "Cancelled" ? "cancelled" : "failed";
                        <tr>
                            <td><strong>@payment.TransactionCode</strong><br /><small class="text-muted">@payment.GatewayOrderCode</small></td>
                            <td><strong>@CustomerName(payment)</strong><br /><small class="text-muted">@Contact(payment)</small></td>
                            <td>@(payment.PayerType == "Owner" ? "Chủ POI" : "Du khách")</td>
                            <td>@(payment.PaymentPlan?.PlanName ?? payment.Purpose)</td>
                            <td>@payment.PaymentMethod</td>
                            <td><strong>@Money(payment.Amount)</strong></td>
                            <td><span class="purchase-pill @statusClass">@payment.Status</span></td>
                            <td>@DateText(payment.PaidAt ?? payment.CreatedAt)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
