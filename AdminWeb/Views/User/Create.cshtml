@model AdminWeb.Models.User

@{
    ViewData["Title"] = "Thêm tài khoản";
    var roles = ViewBag.Roles as IEnumerable<AdminWeb.Models.Role>;
}

<div class="page-title">Thêm tài khoản hệ thống</div>
<div class="page-subtitle">Tạo tài khoản Admin, Editor, Reviewer hoặc Chủ gian hàng / chủ POI. Nếu chọn Owner, hệ thống sẽ tự tạo hồ sơ chủ gian hàng để đăng nhập được vào khu vực Owner.</div>

<div class="card" style="padding:28px;">
    <form action="/Admin/User/Create" method="post" autocomplete="off">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:16px;"></div>
        
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Tên đăng nhập</label>
                <input class="form-control" asp-for="Username" type="text" required autocomplete="off" />
            </div>
            
            <div class="form-group">
                <label class="form-label">Mật khẩu</label>
                <input class="form-control" asp-for="PasswordHash" type="password" required autocomplete="new-password" />
            </div>
            
            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="Email" type="email" required autocomplete="off" />
            </div>
            
            <div class="form-group">
                <label class="form-label">Phân quyền</label>
                <select class="form-control" asp-for="RoleId" required>
                    <option value="">-- Chọn quyền --</option>
                    @if (roles != null) {
                        foreach (var role in roles) {
                            <option value="@role.Id" data-role="@role.RoleName">@(role.Description ?? role.RoleName) (@role.RoleName)</option>
                        }
                    }
                </select>
                <span asp-validation-for="RoleId" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label class="form-label">Trạng thái</label>
                <select class="form-control" asp-for="Status">
                    <option value="active">Hoạt động</option>
                    <option value="disabled">Khóa</option>
                </select>
            </div>
        </div>

        <div id="ownerProfileFields" class="card" style="padding:18px;margin-top:18px;display:none;border-style:dashed;">
            <div style="font-weight:800;margin-bottom:6px;">Thông tin Chủ gian hàng / chủ POI</div>
            <div class="page-subtitle" style="margin-bottom:16px;">Phần này chỉ dùng khi chọn quyền Owner. Có thể để trống, hệ thống sẽ tự lấy theo username.</div>
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">Tên gian hàng / đơn vị</label>
                    <input class="form-control" name="ownerBusinessName" type="text" placeholder="VD: Quán Cà Phê Trung Tâm" />
                </div>
                <div class="form-group">
                    <label class="form-label">Người đại diện</label>
                    <input class="form-control" name="ownerRepresentativeName" type="text" placeholder="VD: Nguyễn Văn A" />
                </div>
                <div class="form-group">
                    <label class="form-label">Số điện thoại</label>
                    <input class="form-control" name="ownerPhone" type="text" />
                </div>
                <div class="form-group">
                    <label class="form-label">Địa chỉ</label>
                    <input class="form-control" name="ownerAddress" type="text" />
                </div>
            </div>
        </div>
        
        <div style="display:flex;gap:12px;margin-top:24px;">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu tài khoản</button>
            <a href="/Admin/User" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const roleSelect = document.querySelector('[name="RoleId"]');
            const ownerFields = document.getElementById('ownerProfileFields');
            if (!roleSelect || !ownerFields) return;

            function syncOwnerFields() {
                const selectedOption = roleSelect.options[roleSelect.selectedIndex];
                const roleName = (selectedOption?.dataset?.role || '').toLowerCase();
                ownerFields.style.display = roleName === 'owner' ? '' : 'none';
            }

            roleSelect.addEventListener('change', syncOwnerFields);
            syncOwnerFields();
        })();
    </script>
}
