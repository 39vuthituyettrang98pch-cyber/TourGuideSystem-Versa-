@model AdminWeb.Models.User

@{
    ViewData["Title"] = "Sửa tài khoản";
    var roles = ViewBag.Roles as IEnumerable<AdminWeb.Models.Role>;
}

<div class="page-title">Sửa tài khoản hệ thống</div>
<div class="page-subtitle">Cập nhật thông tin và phân quyền cho tài khoản <strong>@Model.Username</strong>.</div>

<div class="card" style="padding:28px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Username" />
        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Tên đăng nhập</label>
                <input class="form-control" value="@Model.Username" type="text" disabled style="opacity:0.7" />
            </div>
            <div class="form-group">
                <label class="form-label">Mật khẩu mới</label>
                <input class="form-control" name="newPassword" type="password" placeholder="Để trống nếu không đổi" />
            </div>
            <div class="form-group">
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="Email" type="email" required />
            </div>
            <div class="form-group">
                <label class="form-label">Phân quyền</label>
                <select class="form-control" asp-for="RoleId" required>
                    <option value="">-- Chọn quyền --</option>
                    @if (roles != null) {
                        foreach (var role in roles) {
                            <option value="@role.Id">@(role.Description ?? role.RoleName) (@role.RoleName)</option>
                        }
                    }
                </select>
                <span asp-validation-for="RoleId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Trạng thái</label>
                <select class="form-control" asp-for="Status">
                    <option value="active">Hoạt động</option>
                    <option value="disabled">Khóa</option>
                </select>
            </div>
        </div>
        <div style="display:flex;gap:12px;margin-top:24px;">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>
