@model AdminWeb.ViewModels.VisitorAchievementDetailsViewModel
@{
    ViewData["Title"] = "Thành tựu du khách";
}

<div class="page-heading">
    <div>
        <div class="page-title">Thành tựu du khách</div>
        <div class="page-subtitle">@Model.Tourist.FullName · @Model.Tourist.Email</div>
    </div>
    <div class="page-actions">
        <a asp-area="" asp-action="Edit" asp-route-id="@Model.Tourist.Id" class="btn btn-secondary"><i class="fa-solid fa-pen"></i> Sửa hồ sơ</a>
        <a asp-area="" asp-action="Index" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <span class="stat-icon"><i class="fa-solid fa-star"></i></span>
        <div><div class="stat-value">@Model.TotalPoints</div><div class="stat-label">Điểm khám phá</div></div>
    </div>
    <div class="stat-card">
        <span class="stat-icon"><i class="fa-solid fa-medal"></i></span>
        <div><div class="stat-value" style="font-size:18px">@Model.RankName</div><div class="stat-label">Cấp hạng hiện tại</div></div>
    </div>
    <div class="stat-card">
        <span class="stat-icon"><i class="fa-solid fa-map-pin"></i></span>
        <div><div class="stat-value">@Model.DiscoveredPoiCount / @Model.TotalPoiCount</div><div class="stat-label">POI đã khám phá</div></div>
    </div>
    <div class="stat-card">
        <span class="stat-icon"><i class="fa-solid fa-chart-simple"></i></span>
        <div><div class="stat-value">@Model.CompletionPercentage%</div><div class="stat-label">Hoàn thành bản đồ</div></div>
    </div>
</div>

<div class="card" style="margin-bottom:18px;">
    <div class="card-header">
        <div>
            <div class="card-title"><i class="fa-solid fa-trophy"></i> Huy hiệu thành tựu</div>
            <div class="card-subtitle">Mốc tiếp theo: @Model.NextRankName @(Model.PointsToNextRank > 0 ? $"· còn {Model.PointsToNextRank} điểm" : "")</div>
        </div>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;">
        @foreach (var badge in Model.Achievements)
        {
            <div style="padding:16px;border:1px solid var(--border);border-radius:14px;opacity:@(badge.IsUnlocked ? "1" : ".55");background:@(badge.IsUnlocked ? "var(--accent-glow)" : "transparent")">
                <div style="display:flex;gap:12px;align-items:center;">
                    <span style="font-size:28px;color:var(--accent)">@badge.Icon</span>
                    <div>
                        <strong>@badge.Title</strong>
                        <div style="font-size:12px;color:var(--text2)">@badge.Description</div>
                        <div style="font-size:11px;color:var(--accent);margin-top:4px">
                            @(badge.IsUnlocked ? "Đã mở khóa" : $"{badge.CurrentValue}/{badge.RequiredValue}")
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="table-wrapper">
    <div class="card-header" style="padding:18px;">
        <div>
            <div class="card-title"><i class="fa-solid fa-route"></i> Lịch sử khám phá</div>
            <div class="card-subtitle">Các POI đã check-in bằng GPS.</div>
        </div>
    </div>
    <table class="data-table">
        <thead><tr><th>POI</th><th>Phương thức</th><th>Điểm</th><th>Thời gian</th><th></th></tr></thead>
        <tbody>
            @if (Model.Discoveries.Count > 0)
            {
                foreach (var discovery in Model.Discoveries)
                {
                    <tr>
                        <td><strong>@discovery.PoiName</strong><br /><small style="color:var(--text-soft)">#@discovery.PoiId</small></td>
                        <td><span class="badge @(discovery.Method == "QR" ? "blue" : "green")">@(discovery.Method == "QR" ? "Quét QR" : "Check-in GPS")</span></td>
                        <td style="font-weight:700;color:var(--accent)">+@discovery.Points</td>
                        <td>@discovery.DiscoveredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td><a asp-area="" asp-controller="Poi" asp-action="QrCode" asp-route-id="@discovery.PoiId" class="btn btn-secondary btn-sm" title="Xem QR POI"><i class="fa-solid fa-qrcode"></i></a></td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5"><div class="empty-state"><i class="fa-solid fa-compass"></i><h2>Chưa có hành trình khám phá</h2><p>Du khách chưa check-in POI nào.</p></div></td></tr>
            }
        </tbody>
    </table>
</div>
