@model AdminWeb.Models.SystemSetting
@{
    ViewData["Title"] = "Chỉnh sửa cấu hình";
}

<div class="page-heading">
    <div>
        <div class="page-title">Chỉnh sửa cấu hình</div>
        <div class="page-subtitle">Cập nhật cặp khóa và giá trị được dùng bởi hệ thống.</div>
    </div>
</div>

<div class="form-shell">
    <section class="card">
        <div class="card-header">
            <div>
                <div class="card-title"><i class="fa-solid fa-sliders"></i> Thông số hệ thống</div>
                <div class="card-subtitle">Thay đổi có hiệu lực ngay sau khi lưu.</div>
            </div>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="SettingKey" class="form-label">Khóa cấu hình</label>
                    <input asp-for="SettingKey" class="form-control" required />
                    <span asp-validation-for="SettingKey" class="field-validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="SettingValue" class="form-label">Giá trị</label>
                    <input asp-for="SettingValue" class="form-control" required />
                    <span asp-validation-for="SettingValue" class="field-validation-error"></span>
                </div>
                <div class="form-group full">
                    <label asp-for="Description" class="form-label">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
