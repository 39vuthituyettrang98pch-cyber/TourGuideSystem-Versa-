@model AdminWeb.Models.User
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="page-title text-white">Đổi mật khẩu</div>
<div class="page-subtitle text-white">Cập nhật mật khẩu mới để bảo vệ tài khoản của bạn.</div>

<div class="row">
    <div class="col-lg-10 col-xl-8">
        <div class="card">
            
            <div class="card-header" style="display: block; border-bottom: 1px solid var(--border); padding-bottom: 16px; margin-bottom: 20px;">
                <h5 class="card-title mb-1 text-white">
                    <i class="fa-solid fa-shield-halved me-2" style="color: var(--accent);"></i> Bảo mật
                </h5>
                <p class="card-subtitle mt-1 text-white" style="font-size: 13px; margin-bottom: 0;">
                    Thiết lập mật khẩu mạnh để đảm bảo an toàn cho hệ thống.
                </p>
            </div>

            <form asp-area="" asp-action="ChangePassword" method="post">
                <div class="form-grid">
                    
                    <div class="form-group full">
                        <label for="oldPassword" class="form-label text-white">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <div style="position: relative;">
                            <i class="fa-solid fa-unlock-keyhole" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: white; font-size: 13px;"></i>
                            <input type="password" id="oldPassword" name="oldPassword" class="form-control text-white" style="padding-left: 38px; padding-right: 40px;" required />
                            <button class="toggle-pw" type="button" data-target="oldPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: transparent; border: none; color: white; cursor: pointer; padding: 4px;">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-group full">
                        <label for="newPassword" class="form-label text-white">Mật khẩu mới <span class="text-danger">*</span></label>
                        <div style="position: relative;">
                            <i class="fa-solid fa-lock" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: white; font-size: 13px;"></i>
                            <input type="password" id="newPassword" name="newPassword" class="form-control text-white" style="padding-left: 38px; padding-right: 40px;" required />
                            <button class="toggle-pw" type="button" data-target="newPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: transparent; border: none; color: white; cursor: pointer; padding: 4px;">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-group full">
                        <label for="confirmPassword" class="form-label text-white">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                        <div style="position: relative;">
                            <i class="fa-solid fa-check-double" style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: white; font-size: 13px;"></i>
                            <input type="password" id="confirmPassword" name="confirmPassword" class="form-control text-white" style="padding-left: 38px; padding-right: 40px;" required />
                            <button class="toggle-pw" type="button" data-target="confirmPassword" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: transparent; border: none; color: white; cursor: pointer; padding: 4px;">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                </div>

                <hr style="border-color: var(--border); margin: 24px 0 20px;" />

                <div style="display: flex; gap: 12px; justify-content: flex-end;">
                    <a asp-area="" asp-action="Profile" class="btn btn-secondary">
                        Hủy bỏ
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-key"></i> Đổi mật khẩu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Cập nhật Script: Duyệt qua tất cả các nút toggle và xử lý đổi màu icon
        document.querySelectorAll('.toggle-pw').forEach(button => {
            button.addEventListener('click', function () {
                const targetId = this.getAttribute('data-target');
                const passwordInput = document.getElementById(targetId);
                const icon = this.querySelector('i');
                
                if (passwordInput.type === 'password') {
                    passwordInput.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                    icon.style.color = 'var(--accent)'; // Đổi sang màu xanh khi lộ mật khẩu
                } else {
                    passwordInput.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                    icon.style.color = 'white'; // Trả về màu trắng khi ẩn
                }
            });
        });
    </script>
}