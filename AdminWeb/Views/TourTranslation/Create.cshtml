@model AdminWeb.Models.TourTranslation

@{
    ViewData["Title"] = "Thêm bản dịch Tour";
}

<div class="page-title">Thêm bản dịch mới</div>
<div class="page-subtitle">Thêm nội dung cho một ngôn ngữ mới vào Tour #@Model.TourId.</div>

<div class="card" style="padding:28px;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TourId" />

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label">Mã ngôn ngữ <span style="color:var(--danger)">*</span></label>
                <select class="form-control" asp-for="LanguageCode" required>
                    <option value="">-- Chọn ngôn ngữ --</option>
                    <option value="vi">🇻🇳 Tiếng Việt (vi)</option>
                    <option value="en">🇬🇧 English (en)</option>
                    <option value="zh">🇨🇳 中文 (zh)</option>
                    <option value="ko">🇰🇷 한국어 (ko)</option>
                    <option value="ja">🇯🇵 日本語 (ja)</option>
                    <option value="fr">🇫🇷 Français (fr)</option>
                </select>
            </div>
            <div class="form-group full">
                <label class="form-label">Tên Tour <span style="color:var(--danger)">*</span></label>
                <input class="form-control" asp-for="Title" type="text" placeholder="Nhập tên Tour..." required />
            </div>
            <div class="form-group full">
                <label class="form-label">Mô tả Tour</label>
                <textarea class="form-control" asp-for="Description" rows="5" placeholder="Nhập mô tả Tour..."></textarea>
            </div>
        </div>

        <div style="display:flex;gap:12px;flex-wrap:wrap; margin-top:24px;">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu bản dịch</button>
            <a asp-action="Index" asp-route-tourId="@Model.TourId" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>
