@model AdminWeb.Models.Tour

@{
    ViewData["Title"] = "Bản dịch Tour #" + Model.Id;
}

<div class="page-title">Quản lý bản dịch — Tour #@Model.Id</div>
<div class="page-subtitle">Quản lý nội dung đa ngôn ngữ cho lộ trình Tour.</div>

<div class="toolbar">
    <div>
        <a asp-controller="Tour" asp-action="Index" class="btn btn-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Quay lại</a>
    </div>
    <div>
        <a asp-action="Create" asp-route-tourId="@Model.Id" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Thêm ngôn ngữ mới</a>
    </div>
</div>

<div class="table-wrapper">
    <table class="data-table">
        <thead>
            <tr>
                <th>Ngôn ngữ</th>
                <th>Tên Tour</th>
                <th>Mô tả</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Translations != null && Model.Translations.Any())
            {
                foreach (var t in Model.Translations)
                {
                    <tr>
                        <td><span class="badge blue">@t.LanguageCode.ToUpper()</span></td>
                        <td style="font-weight:600;">@t.Title</td>
                        <td style="color:var(--text2); font-size:13px;">@(t.Description?.Length > 60 ? t.Description.Substring(0, 60) + "..." : t.Description)</td>
                        <td>
                            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-secondary" title="Sửa"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="Delete" method="post" style="display:inline;" onsubmit="return confirm('Xóa bản dịch này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@t.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Xóa"><i class="fa-solid fa-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" style="text-align:center; padding:32px; color:var(--text2);">
                        Chưa có bản dịch nào. Hãy thêm ngôn ngữ đầu tiên.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
