<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UserMobile.Views.AiChatPage"
             Title="AI"
             BackgroundColor="#EEF1F5">
    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16,14" RowSpacing="12">
        <Border Grid.Row="0"
                Padding="16"
                BackgroundColor="#172033"
                Stroke="#172033"
                StrokeShape="RoundRectangle 24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="VERSA AI"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="Hỏi nhanh về điểm tham quan, tour, QR và thuyết minh"
                           FontSize="12"
                           TextColor="#CFD8EA" />
                    <Label FontSize="11"
                           TextColor="#A7F3D0">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Ngôn ngữ đang chọn: " />
                                <Span Text="{Binding CurrentLanguageName}" FontAttributes="Bold" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="Đổi"
                        Clicked="OnChangeLanguageClicked"
                        BackgroundColor="#24314A"
                        TextColor="White"
                        Padding="12,8"
                        FontSize="12"
                        MinimumHeightRequest="38" />
            </Grid>
        </Border>

        <HorizontalStackLayout Grid.Row="1" Spacing="8">
            <Button Text="Gợi ý đi đâu?"
                    Command="{Binding QuickQuestionCommand}"
                    CommandParameter="Gợi ý cho tôi 5 điểm tham quan nổi bật ở Sài Gòn"
                    BackgroundColor="White"
                    TextColor="#172033"
                    FontSize="12"
                    Padding="12,8"
                    MinimumHeightRequest="38" />
            <Button Text="Nghe thuyết minh"
                    Command="{Binding QuickQuestionCommand}"
                    CommandParameter="Làm sao để nghe thuyết minh theo ngôn ngữ tôi chọn?"
                    BackgroundColor="White"
                    TextColor="#172033"
                    FontSize="12"
                    Padding="12,8"
                    MinimumHeightRequest="38" />
        </HorizontalStackLayout>

        <CollectionView x:Name="MessagesList"
                        Grid.Row="2"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                    <Label Text="Chưa có tin nhắn"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#172033" />
                    <Label Text="Nhập câu hỏi bên dưới để bắt đầu."
                           HorizontalTextAlignment="Center"
                           FontSize="12"
                           TextColor="#68748A" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="0,4" HorizontalOptions="Fill">
                        <Border Padding="13,10"
                                MaximumWidthRequest="310"
                                HorizontalOptions="{Binding HorizontalAlignment}"
                                BackgroundColor="{Binding BubbleColor}"
                                Stroke="#E5EAF2"
                                StrokeShape="RoundRectangle 18">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding SenderName}"
                                       FontAttributes="Bold"
                                       FontSize="11"
                                       TextColor="{Binding TextColor}" />
                                <Label Text="{Binding Text}"
                                       FontSize="14"
                                       LineBreakMode="WordWrap"
                                       TextColor="{Binding TextColor}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="3"
                Padding="10"
                BackgroundColor="White"
                Stroke="#E5EAF2"
                StrokeShape="RoundRectangle 24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Text="{Binding CurrentMessage}"
                       Placeholder="Hỏi AI về POI, tour, bản đồ..."
                       PlaceholderColor="#8A94A8"
                       TextColor="#172033"
                       ReturnType="Send"
                       Completed="OnEntryCompleted" />

                <Button Grid.Column="1"
                        Text="Gửi"
                        Command="{Binding SendMessageCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        BackgroundColor="#5B3FE4"
                        TextColor="White"
                        Padding="16,8"
                        MinimumHeightRequest="44" />
            </Grid>
        </Border>

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="End"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10" />
    </Grid>
</ContentPage>
