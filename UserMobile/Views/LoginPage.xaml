<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:UserMobile.Markup"
             x:Class="UserMobile.Views.LoginPage"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,34,24,24" Spacing="18">
                <Border Style="{StaticResource HeroCard}" Padding="24" Margin="0,0,0,4">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <Border WidthRequest="72" HeightRequest="72" BackgroundColor="{StaticResource Primary}" Stroke="Transparent" StrokeShape="RoundRectangle 24">
                                <Label Text="V" FontSize="32" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="VERSA Guide" TextColor="#B9AEF7" FontSize="12" FontAttributes="Bold" CharacterSpacing="1.1" />
                                <Label Text="Du lịch thông minh" TextColor="White" FontSize="24" FontAttributes="Bold" />
                                <Label Text="Nghe thuyết minh, quét QR, lưu điểm yêu thích." TextColor="#C8D1E2" FontSize="12" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="5">
                    <Label Text="{i18n:T Login_Title}" Style="{StaticResource PageTitle}" />
                    <Label Text="{i18n:T Login_Subtitle}" Style="{StaticResource PageSubtitle}" />
                </VerticalStackLayout>

                <Border Style="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 26">
                    <VerticalStackLayout Spacing="13">
                        <Label Text="{i18n:T Login_Email}" Style="{StaticResource Eyebrow}" />
                        <Border Style="{StaticResource InputCard}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="@" TextColor="{StaticResource Primary}" FontAttributes="Bold" VerticalTextAlignment="Center" />
                                <Entry Grid.Column="1"
                                       Placeholder="tenban@example.com"
                                       Text="{Binding Email}"
                                       Keyboard="Email"
                                       ReturnType="Next" />
                            </Grid>
                        </Border>

                        <Label Text="{i18n:T Login_Password}" Style="{StaticResource Eyebrow}" Margin="0,2,0,0" />
                        <Border Style="{StaticResource InputCard}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="●" TextColor="{StaticResource Primary}" VerticalTextAlignment="Center" />
                                <Entry Grid.Column="1"
                                       Placeholder="Nhập mật khẩu"
                                       Text="{Binding Password}"
                                       IsPassword="True"
                                       ReturnType="Go"
                                       ReturnCommand="{Binding LoginCommand}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource NoticeCard}" IsVisible="{Binding HasMessage}">
                            <Label Text="{Binding Message}" TextColor="{StaticResource Danger}" HorizontalTextAlignment="Center" />
                        </Border>

                        <Button Text="{i18n:T Login_Button}" Command="{Binding LoginCommand}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Text="{i18n:T Login_CreateAccount}" Clicked="OnRegisterClicked" Style="{StaticResource SecondaryButton}" FontSize="13" />
                            <Button Grid.Column="1" Text="{i18n:T Login_ForgotPassword}" Clicked="OnForgotPasswordClicked" Style="{StaticResource GhostButton}" FontSize="13" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CompactCard}" BackgroundColor="#EEFDF7" Stroke="#D5F5E9">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Style="{StaticResource IconBubble}" BackgroundColor="#D9FBEF" WidthRequest="42" HeightRequest="42" StrokeShape="RoundRectangle 14">
                            <Label Text="✓" FontSize="20" TextColor="{StaticResource Success}" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Column="1" Text="{i18n:T Login_Benefit}" Style="{StaticResource PageSubtitle}" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
