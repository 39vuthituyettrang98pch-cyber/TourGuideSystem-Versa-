<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:UserMobile.Markup"
             x:Class="UserMobile.Views.ToursPage"
             Title="{i18n:T Tab_Tour}"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="Auto,Auto,*" Padding="18,18,18,0" RowSpacing="14">
        <Border Style="{StaticResource HeroCard}" Padding="20">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="5">
                    <Label Text="{i18n:T Tours_Title}" TextColor="White" FontSize="26" FontAttributes="Bold" />
                    <Label Text="{i18n:T Tours_Subtitle}" TextColor="#C8D1E2" FontSize="13" />
                </VerticalStackLayout>
                <Label Grid.Column="1" Text="⌁" FontSize="40" TextColor="#B9AEF7" VerticalOptions="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{i18n:T Tours_Category}" Style="{StaticResource SectionTitle}" VerticalOptions="Center" />
                <Button Grid.Column="1" Text="{i18n:T Tours_ClearFilter}" FontSize="12" Padding="12,6" Clicked="OnClearFilterClicked" Style="{StaticResource SecondaryButton}" MinimumHeightRequest="38" />
            </Grid>
            <CollectionView Grid.Row="1" x:Name="CategoryList" ItemsSource="{Binding Categories}" ItemsLayout="HorizontalList" SelectionMode="Single" SelectionChanged="OnCategorySelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,8,0" Padding="13,8" BackgroundColor="White" Stroke="{StaticResource OutlineStrong}" StrokeShape="RoundRectangle 18">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding Name}" TextColor="{StaticResource Ink}" />
                                <Label Text="{Binding PoiCount, StringFormat='({0})'}" TextColor="{StaticResource Muted}" />
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Grid Grid.Row="2">
            <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}" VerticalOptions="Start" />

            <VerticalStackLayout IsVisible="{Binding IsEmpty}" VerticalOptions="Center" Spacing="10" Padding="24">
                <Label Text="🧭" FontSize="48" HorizontalTextAlignment="Center" />
                <Label Text="{i18n:T Tours_Empty}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Ink}" HorizontalTextAlignment="Center" />
                <Label Text="{Binding Message}" Style="{StaticResource EmptyStateText}" />
                <Button Text="Xem gói Premium" IsVisible="{Binding HasMessage}" Clicked="OnPremiumClicked" Style="{StaticResource SecondaryButton}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <CollectionView x:Name="TourList" ItemsSource="{Binding Tours}" SelectionMode="Single" SelectionChanged="OnTourSelectionChanged">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12" Padding="17">
                            <VerticalStackLayout Spacing="9">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Ink}" MaxLines="2" LineBreakMode="TailTruncation" />
                                    <Border Grid.Column="1" BackgroundColor="{StaticResource PrimarySoft}" Stroke="Transparent" StrokeShape="RoundRectangle 14" Padding="10,5" VerticalOptions="Start">
                                        <Label Text="Tour" TextColor="{StaticResource Primary}" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <Label Text="{Binding Description}" Style="{StaticResource PageSubtitle}" MaxLines="3" LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="12">
                                    <Label Text="{Binding DurationText}" FontSize="12" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                    <Label Text="{Binding PoiCountText}" FontSize="12" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <Label Text="{i18n:T Tours_View}" FontSize="12" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
