<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UserMobile.Views.TourDetailPage"
             Title="Chi tiết tour"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="Auto,*">
        <Border Margin="18,18,18,10"
                Padding="20"
                BackgroundColor="#182033"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 24">
            <VerticalStackLayout Spacing="8">
                <Label Text="HÀNH TRÌNH GỢI Ý"
                       Style="{StaticResource Eyebrow}"
                       TextColor="#B9AEF7" />
                <Label Text="{Binding Title}"
                       FontSize="25"
                       FontAttributes="Bold"
                       TextColor="White"
                       MaxLines="2"
                       LineBreakMode="TailTruncation" />
                <Label Text="{Binding Description}"
                       FontSize="13"
                       TextColor="#C8D1E2"
                       MaxLines="3"
                       LineBreakMode="TailTruncation" />
                <HorizontalStackLayout Spacing="18" Margin="0,4,0,0">
                    <Label Text="{Binding DurationText}" TextColor="#B9AEF7" />
                    <Label Text="{Binding PoiCountText}" TextColor="#B9AEF7" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1"
                        x:Name="PoiList"
                        Margin="18,8,18,0"
                        ItemsSource="{Binding Pois}"
                        SelectionMode="Single"
                        SelectionChanged="OnPoiSelectionChanged">
            <CollectionView.Header>
                <VerticalStackLayout Spacing="3" Margin="2,0,0,12">
                    <Label Text="Các điểm trong hành trình"
                           FontSize="19"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Ink}" />
                    <Label Text="Chạm một điểm để xem nội dung và thuyết minh."
                           Style="{StaticResource PageSubtitle}" />
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" Spacing="8">
                    <Label Text="Tour này chưa có điểm tham quan."
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="42,72,*" ColumnSpacing="12">
                            <Border WidthRequest="38"
                                    HeightRequest="38"
                                    BackgroundColor="{StaticResource Secondary}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 13"
                                    VerticalOptions="Start">
                                <Label Text="{Binding SequenceOrder}"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <Border Grid.Column="1"
                                    WidthRequest="72"
                                    HeightRequest="72"
                                    BackgroundColor="#F1F3F7"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 15">
                                <Image Source="{Binding CoverImageUrl}" Aspect="AspectFill" />
                            </Border>
                            <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Ink}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding ShortDescription}"
                                       Style="{StaticResource PageSubtitle}"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="Mở chi tiết ›"
                                       FontSize="12"
                                       TextColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
