<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:UserMobile.Markup"
             x:Class="UserMobile.Views.StartupPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid Padding="30">
        <VerticalStackLayout VerticalOptions="Center" Spacing="20">
            <Border WidthRequest="104" HeightRequest="104" HorizontalOptions="Center" BackgroundColor="{StaticResource Primary}" Stroke="Transparent" StrokeShape="RoundRectangle 34">
                <Label Text="V" HorizontalOptions="Center" VerticalOptions="Center" FontSize="46" FontAttributes="Bold" TextColor="White" />
            </Border>
            <VerticalStackLayout Spacing="8">
                <Label Text="{i18n:T WelcomeTitle}" HorizontalTextAlignment="Center" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                <Label Text="{i18n:T WelcomeSubtitle}" HorizontalTextAlignment="Center" TextColor="{StaticResource Muted}" FontSize="14" />
            </VerticalStackLayout>
            <Border Style="{StaticResource CompactCard}" HorizontalOptions="Center" Padding="14,10">
                <HorizontalStackLayout Spacing="10">
                    <ActivityIndicator IsRunning="True" WidthRequest="22" HeightRequest="22" />
                    <Label Text="Đang chuẩn bị trải nghiệm..." Style="{StaticResource PageSubtitle}" VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
