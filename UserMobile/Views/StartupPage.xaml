<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UserMobile.Views.StartupPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F7F8FC">
    <Grid Padding="32">
        <VerticalStackLayout VerticalOptions="Center" Spacing="18">
            <Border WidthRequest="92"
                    HeightRequest="92"
                    HorizontalOptions="Center"
                    BackgroundColor="#5B3FE4"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 30">
                <Label Text="V"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="40"
                       FontAttributes="Bold"
                       TextColor="White" />
            </Border>
            <VerticalStackLayout Spacing="5">
                <Label Text="VERSA Guide"
                       HorizontalTextAlignment="Center"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#182033" />
                <Label Text="Khám phá điểm đến theo cách của bạn"
                       HorizontalTextAlignment="Center"
                       TextColor="#68748A" />
            </VerticalStackLayout>
            <ActivityIndicator IsRunning="True"
                               Color="#5B3FE4"
                               Margin="0,18,0,0" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
