<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UserMobile.Views.ResetPasswordPage"
             Title="Quên mật khẩu"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="24,24,24,36" Spacing="16">
            <Border Style="{StaticResource HeroCard}" Padding="22">
                <VerticalStackLayout Spacing="6">
                    <Label Text="KHÔI PHỤC TÀI KHOẢN" TextColor="#B9AEF7" FontAttributes="Bold" FontSize="12" />
                    <Label Text="Đặt lại mật khẩu bằng OTP" TextColor="White" FontSize="28" FontAttributes="Bold" />
                    <Label Text="Nhận mã 6 số qua Gmail. Mã có hiệu lực trong 10 phút và chỉ dùng được một lần."
                           TextColor="#C8D1E2"
                           FontSize="13" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 26">
                <VerticalStackLayout Spacing="13">
                    <Label Text="EMAIL ĐÃ ĐĂNG KÝ" Style="{StaticResource Eyebrow}" />
                    <Border Style="{StaticResource InputCard}">
                        <Entry Placeholder="tenban@gmail.com"
                               Text="{Binding Email}"
                               Keyboard="Email"
                               ReturnType="Done" />
                    </Border>

                    <Button Text="Gửi mã OTP về Gmail"
                            Command="{Binding SendOtpCommand}" />

                    <VerticalStackLayout Spacing="13" IsVisible="{Binding IsOtpSent}">
                        <Label Text="MÃ OTP 6 SỐ" Style="{StaticResource Eyebrow}" Margin="0,6,0,0" />
                        <Border Style="{StaticResource InputCard}">
                            <Entry Placeholder="000000"
                                   Text="{Binding Otp}"
                                   Keyboard="Numeric"
                                   MaxLength="6"
                                   FontSize="20"
                                   CharacterSpacing="8"
                                   HorizontalTextAlignment="Center"
                                   ReturnType="Next" />
                        </Border>

                        <Label Text="MẬT KHẨU MỚI" Style="{StaticResource Eyebrow}" />
                        <Border Style="{StaticResource InputCard}">
                            <Entry Placeholder="Ít nhất 8 ký tự"
                                   Text="{Binding NewPassword}"
                                   IsPassword="True"
                                   ReturnType="Next" />
                        </Border>

                        <Label Text="XÁC NHẬN MẬT KHẨU" Style="{StaticResource Eyebrow}" />
                        <Border Style="{StaticResource InputCard}">
                            <Entry Placeholder="Nhập lại mật khẩu mới"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   ReturnType="Go"
                                   ReturnCommand="{Binding ResetPasswordCommand}" />
                        </Border>

                        <Button Text="Đổi mật khẩu"
                                Command="{Binding ResetPasswordCommand}" />

                        <Button Text="Gửi lại mã OTP"
                                Command="{Binding SendOtpCommand}"
                                Style="{StaticResource GhostButton}" />
                    </VerticalStackLayout>

                    <Border Style="{StaticResource NoticeCard}" IsVisible="{Binding HasMessage}">
                        <Label Text="{Binding Message}"
                               TextColor="{StaticResource Danger}"
                               HorizontalTextAlignment="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CompactCard}" BackgroundColor="#EEFDF7" Stroke="#D5F5E9">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Label Text="🔐" FontSize="24" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="Sau khi đổi thành công, mật khẩu mới dùng chung cho web du khách và app mobile."
                           Style="{StaticResource PageSubtitle}"
                           VerticalTextAlignment="Center" />
                </Grid>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
