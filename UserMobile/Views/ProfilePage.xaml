<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:UserMobile.Markup"
             x:Class="UserMobile.Views.ProfilePage"
             Title="{i18n:T Profile_Title}"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="18,18,18,32" Spacing="16">
            <VerticalStackLayout Spacing="4">
                <Label Text="{i18n:T Profile_Title}" Style="{StaticResource PageTitle}" />
                <Label Text="{i18n:T Profile_Subtitle}"
                       Style="{StaticResource PageSubtitle}" />
            </VerticalStackLayout>

            <Border Padding="20"
                    BackgroundColor="#182033"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 24">
                <Grid ColumnDefinitions="64,*" ColumnSpacing="15">
                    <Border WidthRequest="64"
                            HeightRequest="64"
                            BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 22">
                        <Label Text="V"
                               FontSize="27"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding WelcomeText}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="White"
                               MaxLines="2"
                               LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Profile.Email}"
                               FontSize="12"
                               TextColor="#C8D1E2"
                               IsVisible="{Binding IsLoggedIn}"
                               MaxLines="1"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Label Text="{Binding Message}"
                   TextColor="#D94A64"
                   IsVisible="{Binding HasMessage}"
                   HorizontalTextAlignment="Center" />

            <Border Padding="18"
                    IsVisible="{Binding IsLoggedIn}"
                    BackgroundColor="#F0EDFF"
                    Stroke="#D9D1FF"
                    StrokeShape="RoundRectangle 22">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAchievementsClicked" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                    <Border WidthRequest="52"
                            HeightRequest="52"
                            BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 18">
                        <Label Text="★"
                               FontSize="23"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="{Binding AchievementSummary.RankName, FallbackValue='Tân binh'}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Ink}" />
                        <Label Text="{Binding AchievementSummary.DiscoveryProgressText, FallbackValue='Bắt đầu hành trình khám phá'}"
                               FontSize="11"
                               TextColor="{StaticResource Muted}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" Spacing="1" VerticalOptions="Center">
                        <Label Text="{Binding AchievementSummary.TotalPoints, StringFormat='{0} điểm', FallbackValue='0 điểm'}"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Primary}"
                               HorizontalTextAlignment="End" />
                        <Label Text="Xem thành tựu ›"
                               FontSize="10"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Label Text="{i18n:T Profile_QuickAccess}" Style="{StaticResource Eyebrow}" Margin="2,4,0,0" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Border Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRecentClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="↶" FontSize="25" TextColor="{StaticResource Primary}" />
                        <Label Text="{i18n:T Profile_Recent}" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                        <Label Text="{i18n:T Profile_RecentHint}" Style="{StaticResource PageSubtitle}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFavoritesClicked" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="♡" FontSize="25" TextColor="{StaticResource Primary}" />
                        <Label Text="{i18n:T Profile_Favorites}" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                        <Label Text="{i18n:T Profile_FavoritesHint}" Style="{StaticResource PageSubtitle}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding IsLoggedIn}">
                <Border Style="{StaticResource Card}">
                    <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnPremiumClicked" /></Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Text="♛" FontSize="27" TextColor="#D99520" VerticalTextAlignment="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="Gói Premium" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                            <Label Text="Mở Tour, AI và xem lịch sử thanh toán" Style="{StaticResource PageSubtitle}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="24" TextColor="{StaticResource Primary}" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Style="{StaticResource Card}">
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnLeaderboardClicked" /></Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="🏆" FontSize="24" />
                            <Label Text="Bảng xếp hạng" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                            <Label Text="So tài cùng cộng đồng" Style="{StaticResource PageSubtitle}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource Card}">
                        <Border.GestureRecognizers><TapGestureRecognizer Tapped="OnOrdersClicked" /></Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="🧾" FontSize="24" />
                            <Label Text="Đơn hàng" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                            <Label Text="Theo dõi và hủy đơn" Style="{StaticResource PageSubtitle}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>


            <Label Text="{i18n:T Profile_Account}" Style="{StaticResource Eyebrow}" Margin="2,4,0,0" IsVisible="{Binding IsLoggedIn}" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding IsLoggedIn}">
                <Button Text="{i18n:T Profile_Edit}"
                        Clicked="OnEditProfileClicked"
                        Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="1"
                        Text="{i18n:T Profile_ChangePassword}"
                        Clicked="OnChangePasswordClicked"
                        Style="{StaticResource SecondaryButton}" />
            </Grid>

            <Button Text="{i18n:T Profile_ForgotPassword}"
                    Clicked="OnForgotPasswordClicked"
                    Style="{StaticResource SecondaryButton}"
                    IsVisible="{Binding IsLoggedOut}" />

            <Label Text="{i18n:T Profile_Settings}" Style="{StaticResource Eyebrow}" Margin="2,4,0,0" />
            <Border Style="{StaticResource Card}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border WidthRequest="42"
                            HeightRequest="42"
                            BackgroundColor="{StaticResource Secondary}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 14">
                        <Label Text="文"
                               FontSize="18"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="{i18n:T Profile_ContentLanguage}" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                        <Label Text="{Binding CurrentLanguage}" Style="{StaticResource PageSubtitle}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="2"
                            Text="{i18n:T Profile_Change}"
                            Clicked="OnLanguageClicked"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6"
                            MinimumHeightRequest="40" />
                </Grid>
            </Border>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="VERSA Guide" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                    <Label Text="{i18n:T Profile_About}"
                           Style="{StaticResource PageSubtitle}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="{i18n:T Profile_LoginOrRegister}"
                    Clicked="OnLoginClicked"
                    IsVisible="{Binding IsLoggedOut}" />
            <Button Text="{i18n:T Profile_Logout}"
                    Clicked="OnLogoutClicked"
                    IsVisible="{Binding IsLoggedIn}"
                    BackgroundColor="#FDECEF"
                    TextColor="#C83B55" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
