<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:UserMobile.Markup"
             x:Class="UserMobile.Views.LanguageSelectionPage"
             Title="{i18n:T SelectLanguage}"
             BackgroundColor="{StaticResource PageBackground}">
    <Grid RowDefinitions="Auto,*,Auto" Padding="22,20,22,24" RowSpacing="16">
        <Border Style="{StaticResource HeroCard}" Padding="20">
            <Grid ColumnDefinitions="56,*" ColumnSpacing="14">
                <Border WidthRequest="56" HeightRequest="56" BackgroundColor="{StaticResource Primary}" Stroke="Transparent" StrokeShape="RoundRectangle 20">
                    <Label Text="文" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                    <Label Text="{i18n:T LanguageSetupEyebrow}" TextColor="#B9AEF7" FontAttributes="Bold" FontSize="12" />
                    <Label Text="{i18n:T LanguageQuestion}" TextColor="White" FontSize="23" FontAttributes="Bold" LineBreakMode="WordWrap" />
                    <Label Text="{i18n:T LanguageHint}" TextColor="#C8D1E2" FontSize="12" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Languages}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedLanguage}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Margin="0,0,0,11" Padding="16">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal" />
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="14">
                            <Border WidthRequest="48" HeightRequest="48" BackgroundColor="{StaticResource PrimarySoft}" Stroke="Transparent" StrokeShape="RoundRectangle 16">
                                <Label Text="{Binding Code}" TextTransform="Uppercase" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding NativeName}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Ink}" />
                                <Label Text="{Binding Name}" FontSize="12" TextColor="{StaticResource Muted}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="✓" FontSize="18" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2">
            <Button Text="{i18n:T Continue}" Clicked="OnContinueClicked" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </Grid>
    </Grid>
</ContentPage>
