<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:i18n="clr-namespace:UserMobile.Markup"
             x:Class="UserMobile.Views.RegisterPage"
             Title="{i18n:T Register_Button}"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="24,24,24,36" Spacing="16">
            <Border Style="{StaticResource HeroCard}" Padding="22">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{i18n:T Register_Eyebrow}" TextColor="#B9AEF7" FontAttributes="Bold" FontSize="12" />
                    <Label Text="{i18n:T Register_Title}" TextColor="White" FontSize="28" FontAttributes="Bold" />
                    <Label Text="{i18n:T Register_Subtitle}" TextColor="#C8D1E2" FontSize="13" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 26">
                <VerticalStackLayout Spacing="13">
                    <Label Text="{i18n:T Register_FullName}" Style="{StaticResource Eyebrow}" />
                    <Border Style="{StaticResource InputCard}">
                        <Entry Placeholder="Nguyễn Văn A" Text="{Binding FullName}" ReturnType="Next" />
                    </Border>

                    <Label Text="{i18n:T Register_Email}" Style="{StaticResource Eyebrow}" />
                    <Border Style="{StaticResource InputCard}">
                        <Entry Placeholder="tenban@gmail.com" Text="{Binding Email}" Keyboard="Email" ReturnType="Next" />
                    </Border>
                    <Label Text="Chỉ dùng Gmail: ví dụ tenban@gmail.com" TextColor="#8B95A7" FontSize="12" />

                    <Label Text="{i18n:T Register_Password}" Style="{StaticResource Eyebrow}" />
                    <Border Style="{StaticResource InputCard}">
                        <Entry Placeholder="Mật khẩu, ít nhất 8 ký tự" Text="{Binding Password}" IsPassword="True" ReturnType="Next" />
                    </Border>
                    <Border Style="{StaticResource InputCard}">
                        <Entry Placeholder="Nhập lại mật khẩu" Text="{Binding ConfirmPassword}" IsPassword="True" ReturnType="Go" ReturnCommand="{Binding RegisterCommand}" />
                    </Border>

                    <Border Style="{StaticResource NoticeCard}" IsVisible="{Binding HasMessage}">
                        <Label Text="{Binding Message}" TextColor="{StaticResource Danger}" HorizontalTextAlignment="Center" />
                    </Border>

                    <Button Text="{i18n:T Register_Button}" Command="{Binding RegisterCommand}" />
                    <Button Text="{i18n:T Register_Login}" Clicked="OnLoginClicked" Style="{StaticResource SecondaryButton}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CompactCard}" BackgroundColor="#FFF8E6" Stroke="#F8E2A6">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Label Text="💡" FontSize="24" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Tài khoản dùng chung cho web du khách và app mobile." Style="{StaticResource PageSubtitle}" VerticalTextAlignment="Center" />
                </Grid>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
